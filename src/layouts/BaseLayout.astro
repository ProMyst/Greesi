---
import '../styles/global.css';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, canonical, ogImage, schema } = Astro.props;
const siteUrl = 'https://greesi.com';
const fullTitle = title.includes('Greesi') ? title : `${title} | Greesi`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage || `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Greesi" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4558936942966893" crossorigin="anonymous" is:inline></script>

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- View Transitions (Astro 6 ClientRouter) -->
  <ClientRouter />

  <!-- Dark mode: runs before paint to prevent flash -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('greesi-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = t;
    })();
  </script>
</head>

<body class="min-h-screen flex flex-col">

  <!-- Reading progress bar -->
  <div id="progress-bar"></div>

  <!-- ── Navigation ─────────────────────────────────────────── -->
  <header id="site-nav" class="nav-root nav-transparent" transition:persist>
    <nav class="nav-inner">
      <!-- Logo -->
      <a href="/" class="nav-logo">
        <svg width="82" height="24" viewBox="0 0 88 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="nav-logo-svg">
          <rect x="0" y="4" width="26" height="20" rx="10" fill="white"/>
          <line x1="9" y1="4" x2="17" y2="24" stroke="#0ea5e9" stroke-width="2.2" stroke-linecap="round"/>
          <text x="32" y="20" font-family="Inter, sans-serif" font-size="15" font-weight="600" letter-spacing="-0.5" fill="white">greesi</text>
        </svg>
      </a>

      <!-- Desktop Links -->
      <div class="nav-links">
        <div class="nav-dropdown">
          <a href="/finance" class="nav-link nav-dropdown-trigger">Finance ▾</a>
          <div class="nav-dropdown-menu">
            <div class="nav-dropdown-col">
              <p class="nav-dropdown-heading">Reviews</p>
              <a href="/finance/banking" class="nav-dropdown-link">Best Banks</a>
