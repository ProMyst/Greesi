---
import '../styles/global.css';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, canonical, ogImage, schema } = Astro.props;
const siteUrl = 'https://folvr.com';
const fullTitle = title.includes('Folvr') ? title : `${title} | Folvr`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage || `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Folvr" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4558936942966893" crossorigin="anonymous" is:inline></script>

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- View Transitions (Astro 6 ClientRouter) -->
  <ClientRouter />

  <!-- Dark mode: runs before paint to prevent flash -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('folvr-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = t;
    })();
  </script>
</head>

<body class="min-h-screen flex flex-col">

  <!-- Reading progress bar -->
  <div id="progress-bar"></div>

  <!-- ── Navigation ─────────────────────────────────────────── -->
  <header id="site-nav" class="nav-root nav-transparent" transition:persist>
    <nav class="nav-inner">
      <!-- Logo -->
      <a href="/" class="nav-logo">
        <svg class="nav-logo-mark" width="28" height="28" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="28" height="28" rx="6" fill="#1e3a5f"/>
          <path d="M8 7h13v3.5H11.5v3.5H20v3.5h-8.5V22H8V7z" fill="#0ea5e9"/>
        </svg>
        <span class="nav-logo-text">Folvr</span>
      </a>

      <!-- Desktop Links -->
      <div class="nav-links">
        <a href="/finance" class="nav-link">Finance</a>
        <a href="/finance/banking" class="nav-link">Banking</a>
        <a href="/finance/credit-cards" class="nav-link">Credit Cards</a>
        <a href="/travel" class="nav-link">Travel</a>
        <a href="/tools" class="nav-link">Tools</a>
      </div>

      <!-- Right: search + theme + hamburger -->
      <div class="nav-right">
        <button id="search-btn" class="nav-icon-btn" aria-label="Search (⌘K)">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <kbd>⌘K</kbd>
        </button>
        <button id="theme-toggle" class="nav-icon-btn" aria-label="Toggle theme">
          <svg id="icon-sun" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg id="icon-moon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button id="mobile-menu-btn" class="nav-hamburger" aria-label="Open menu" aria-expanded="false">
          <span class="ham-line"></span>
          <span class="ham-line"></span>
          <span class="ham-line"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="nav-mobile" aria-hidden="true">
      <a href="/finance" class="nav-mobile-link">Finance</a>
      <a href="/finance/banking" class="nav-mobile-link">Banking</a>
      <a href="/finance/credit-cards" class="nav-mobile-link">Credit Cards</a>
      <a href="/finance/investing" class="nav-mobile-link">Investing</a>
      <a href="/travel" class="nav-mobile-link">Travel</a>
      <a href="/tools" class="nav-mobile-link">Tools</a>
    </div>
  </header>

  <!-- Search Modal -->
  <div id="search-modal" class="search-modal-root" aria-hidden="true" role="dialog" aria-label="Search">
    <div class="search-modal-overlay" id="search-overlay"></div>
    <div class="search-modal-box">
      <div id="search-container"></div>
    </div>
  </div>

  <!-- ── Page Content ───────────────────────────────────────── -->
  <main class="flex-1" transition:animate="fade">
    <slot />
  </main>

  <!-- ── Newsletter ────────────────────────────────────────────── -->
  <section class="newsletter-root has-noise">
    <div class="newsletter-inner">
      <span class="newsletter-eyebrow">Stay in the Loop</span>
      <h2 class="newsletter-title">Better rates. Better trips. Weekly.</h2>
      <p class="newsletter-sub">The best APYs, travel deals, and card bonuses — straight to your inbox. No spam, ever.</p>
      <form class="newsletter-form" id="newsletter-form" novalidate>
        <input
          type="email"
          class="newsletter-input"
          placeholder="your@email.com"
          aria-label="Email address"
          required
        />
        <button type="submit" class="newsletter-btn">Subscribe</button>
      </form>
      <p class="newsletter-success" id="newsletter-success">You're in! Check your inbox.</p>
      <p class="newsletter-disclaimer">No spam. Unsubscribe anytime. We respect your privacy.</p>
    </div>
  </section>

  <!-- ── Footer ─────────────────────────────────────────────── -->
  <footer class="footer-root">
    <div class="footer-grid section-container">

      <div class="footer-brand">
        <a href="/" class="footer-logo">Folvr</a>
        <p class="footer-tagline">Finance smarter.<br />Travel farther.</p>
        <div class="footer-socials">
          <a href="#" aria-label="Instagram" class="social-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" aria-label="X" class="social-icon">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">Banking</h3>
        <a href="/finance/banking" class="footer-link">Best Banks 2026</a>
        <a href="/finance/review/ally" class="footer-link">Ally Bank Review</a>
        <a href="/finance/review/sofi" class="footer-link">SoFi Review</a>
        <a href="/finance/review/marcus" class="footer-link">Marcus Review</a>
        <a href="/finance/review/capital-one" class="footer-link">Capital One Review</a>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">Credit Cards</h3>
        <a href="/finance/credit-cards" class="footer-link">Best Cards 2026</a>
        <a href="/finance/review/chase-sapphire-preferred" class="footer-link">Chase Sapphire</a>
        <a href="/finance/review/capital-one-venture-x" class="footer-link">Venture X</a>
        <a href="/finance/review/amex-gold" class="footer-link">Amex Gold</a>
        <a href="/travel/travel-cards" class="footer-link">Best Travel Cards</a>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">Travel</h3>
        <a href="/travel" class="footer-link">Destinations</a>
        <a href="/travel/destinations/maldives" class="footer-link">Maldives</a>
        <a href="/travel/destinations/british-virgin-islands" class="footer-link">BVI</a>
        <a href="/travel/destinations/greek-islands" class="footer-link">Greek Islands</a>
        <a href="/travel/destinations/amalfi-coast" class="footer-link">Amalfi Coast</a>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">Legal</h3>
        <a href="/about" class="footer-link">About Us</a>
        <a href="/privacy" class="footer-link">Privacy Policy</a>
        <a href="/disclaimer" class="footer-link">Disclaimer</a>
        <a href="/finance/calculators/compound-interest" class="footer-link">Calculators</a>
        <a href="/finance/investing" class="footer-link">Investing</a>
      </div>
    </div>

    <div class="footer-bottom section-container">
      <p class="footer-disclosure">
        <strong>Affiliate Disclosure:</strong> Some links on this site are affiliate links.
        We may earn a commission at no extra cost to you. Our editorial opinions are independent.
      </p>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Folvr. All rights reserved.</p>
    </div>
  </footer>

  <!-- Custom cursor -->
  <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
  <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>

  <!-- Back to top -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  <!-- Cookie consent -->
  <div class="cookie-banner" id="cookie-banner" hidden>
    <div class="cookie-text">
      <strong>Cookie Notice</strong>
      <p>We use cookies for analytics and personalized ads via Google AdSense. <a href="/privacy">Privacy Policy</a></p>
    </div>
    <div class="cookie-actions">
      <button class="cookie-btn cookie-btn-decline" id="cookie-decline">Decline</button>
      <button class="cookie-btn cookie-btn-accept" id="cookie-accept">Accept All</button>
    </div>
  </div>

</body>
</html>

<style>
/* ── Nav ──────────────────────────────────────────────────────── */
.nav-root {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  transition: background 0.35s ease, backdrop-filter 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
}
.nav-transparent { background: transparent; border-bottom: 1px solid transparent; }
.nav-scrolled {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid rgba(30, 58, 95, 0.09);
  box-shadow: 0 1px 24px rgba(0, 0, 0, 0.07);
}
html[data-theme='dark'] .nav-scrolled {
  background: rgba(10, 18, 32, 0.92);
  border-bottom-color: rgba(255,255,255,0.06);
}

.nav-inner {
  max-width: 1152px; margin: 0 auto; padding: 0 24px;
  height: 64px; display: flex; align-items: center; justify-content: space-between;
}

.nav-logo {
  font-size: 1.25rem; font-weight: 800; letter-spacing: -0.04em;
  text-decoration: none; display: flex; align-items: center; gap: 8px; transition: color 0.3s;
}
.nav-logo-mark { flex-shrink: 0; border-radius: 6px; transition: transform 0.2s; }
.nav-logo:hover .nav-logo-mark { transform: scale(1.05); }
.nav-transparent .nav-logo { color: white; }
.nav-scrolled .nav-logo { color: var(--color-primary); }
html[data-theme='dark'] .nav-scrolled .nav-logo { color: #f1f5f9; }

.nav-links { display: none; align-items: center; gap: 32px; }
@media (min-width: 768px) { .nav-links { display: flex; } }

.nav-link {
  font-size: 0.875rem; font-weight: 500; letter-spacing: -0.01em;
  text-decoration: none; position: relative; transition: color 0.25s;
}
.nav-transparent .nav-link { color: rgba(255, 255, 255, 0.82); }
.nav-scrolled .nav-link { color: var(--color-text); }
.nav-link::after {
  content: ''; position: absolute; bottom: -3px; left: 0;
  width: 0; height: 2px; background: var(--color-accent); border-radius: 2px;
  transition: width 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}
.nav-link:hover::after { width: 100%; }
.nav-transparent .nav-link:hover { color: white; }
.nav-scrolled .nav-link:hover { color: var(--color-primary); }
html[data-theme='dark'] .nav-scrolled .nav-link:hover { color: var(--color-accent); }

.nav-hamburger {
  display: flex; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: none; padding: 8px;
}
@media (min-width: 768px) { .nav-hamburger { display: none; } }
.ham-line { display: block; width: 22px; height: 2px; border-radius: 2px; transition: background 0.3s; }
.nav-transparent .ham-line { background: white; }
.nav-scrolled .ham-line { background: var(--color-primary); }
html[data-theme='dark'] .nav-scrolled .ham-line { background: #f1f5f9; }

.nav-mobile {
  display: none; flex-direction: column; padding: 12px 24px 20px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.nav-mobile.open { display: flex; animation: fade-in 0.2s ease; }
.nav-transparent .nav-mobile { background: rgba(30, 58, 95, 0.95); }
.nav-scrolled .nav-mobile {
  background: rgba(255,255,255,0.95); backdrop-filter: blur(20px);
  border-top-color: rgba(30,58,95,0.08);
}
html[data-theme='dark'] .nav-scrolled .nav-mobile {
  background: rgba(10,18,32,0.97); border-top-color: rgba(255,255,255,0.06);
}
.nav-mobile-link {
  font-size: 1rem; font-weight: 500; padding: 12px 0;
  text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.07); transition: color 0.2s;
}
.nav-transparent .nav-mobile-link { color: rgba(255,255,255,0.85); }
.nav-scrolled .nav-mobile-link { color: var(--color-text); border-bottom-color: var(--color-border); }
.nav-mobile-link:hover { color: var(--color-accent); }

/* ── Footer ──────────────────────────────────────────────────── */
.footer-root { background: #0d1f35; color: rgba(255, 255, 255, 0.55); padding-top: 64px; }
.footer-grid { display: grid; grid-template-columns: 1fr; gap: 40px; padding-bottom: 48px; }
@media (min-width: 640px)  { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr 1fr; } }
.footer-brand {}
.footer-logo { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.04em; color: white; text-decoration: none; display: inline-block; margin-bottom: 12px; }
.footer-tagline { font-size: 0.9rem; line-height: 1.6; color: rgba(255,255,255,0.45); margin-bottom: 20px; }
.footer-socials { display: flex; gap: 12px; }
.social-icon { color: rgba(255,255,255,0.4); transition: color 0.2s; }
.social-icon:hover { color: white; }
.footer-col-heading { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 16px; }
.footer-link { display: block; font-size: 0.875rem; color: rgba(255,255,255,0.6); text-decoration: none; padding: 5px 0; transition: color 0.2s; }
.footer-link:hover { color: white; }
.footer-bottom { border-top: 1px solid rgba(255,255,255,0.07); padding: 24px; display: flex; flex-direction: column; gap: 8px; }
@media (min-width: 768px) { .footer-bottom { flex-direction: row; justify-content: space-between; align-items: center; } }
.footer-disclosure { font-size: 0.75rem; color: rgba(255,255,255,0.3); max-width: 520px; line-height: 1.6; }
.footer-copy { font-size: 0.75rem; color: rgba(255,255,255,0.25); white-space: nowrap; }
</style>

<script>
  import Lenis from 'lenis';

  let lenis: InstanceType<typeof Lenis> | null = null;
  let cursorInited = false;
  let rafId: number | null = null;

  // ── Lenis + nav + progress bar ─────────────────────────────────
  function initLenis() {
    if (rafId !== null) cancelAnimationFrame(rafId);
    lenis?.destroy();

    lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 2,
    });

    const nav = document.getElementById('site-nav');
    const bar = document.getElementById('progress-bar');

    // If the page has no colored hero at the top, start in scrolled state
    const hasHero = document.querySelector('.hero-root, section.bg-primary, section.has-hero');
    if (nav && !hasHero) {
      nav.classList.add('nav-scrolled');
      nav.classList.remove('nav-transparent');
    }

    lenis.on('scroll', ({ scroll, limit }: { scroll: number; limit: number }) => {
      if (nav) {
        const past = hasHero ? scroll > 72 : true;
        nav.classList.toggle('nav-scrolled', past);
        nav.classList.toggle('nav-transparent', !past);
      }
      if (bar && limit > 0) bar.style.width = `${(scroll / limit) * 100}%`;
    });

    function raf(time: number) {
      lenis!.raf(time);
      rafId = requestAnimationFrame(raf);
    }
    rafId = requestAnimationFrame(raf);
  }

  // ── Mobile menu ────────────────────────────────────────────────
  function initMobileMenu() {
    const btn  = document.getElementById('mobile-menu-btn') as HTMLElement | null;
    const menu = document.getElementById('mobile-menu');
    if (!btn || btn.dataset.initialized) return;
    btn.dataset.initialized = 'true';
    btn.addEventListener('click', () => {
      const open = menu?.classList.contains('open');
      menu?.classList.toggle('open', !open);
      btn.setAttribute('aria-expanded', String(!open));
      menu?.setAttribute('aria-hidden', String(!!open));
    });
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    }));
  }

  // ── Dark mode ──────────────────────────────────────────────────
  function initDarkMode() {
    const btn = document.getElementById('theme-toggle') as HTMLElement | null;
    if (!btn || btn.dataset.initialized) return;
    btn.dataset.initialized = 'true';

    function applyTheme(t: string) {
      document.documentElement.dataset.theme = t;
      const sun  = document.getElementById('icon-sun');
      const moon = document.getElementById('icon-moon');
      if (sun)  sun.style.display  = t === 'dark' ? 'block' : 'none';
      if (moon) moon.style.display = t === 'dark' ? 'none'  : 'block';
    }

    const stored = localStorage.getItem('folvr-theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    applyTheme(stored || (prefersDark ? 'dark' : 'light'));

    btn.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      applyTheme(next);
      localStorage.setItem('folvr-theme', next);
    });
  }

  // ── Custom cursor ──────────────────────────────────────────────
  function initCursor() {
    if (cursorInited || window.matchMedia('(hover: none)').matches) return;
    cursorInited = true;
    const dot  = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    if (!dot || !ring) return;

    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let rx = mx, ry = my;

    document.addEventListener('mousemove', (e: MouseEvent) => {
      mx = e.clientX; my = e.clientY;
      dot.style.left = `${mx}px`;
      dot.style.top  = `${my}px`;
    });

    (function animRing() {
      rx += (mx - rx) * 0.1;
      ry += (my - ry) * 0.1;
      ring.style.left = `${rx}px`;
      ring.style.top  = `${ry}px`;
      requestAnimationFrame(animRing);
    })();

    function bindHover() {
      document.querySelectorAll('a, button').forEach(el => {
        el.addEventListener('mouseenter', () => ring.classList.add('hovering'));
        el.addEventListener('mouseleave', () => ring.classList.remove('hovering'));
      });
    }
    bindHover();
    document.addEventListener('astro:after-swap', bindHover);
  }

  // ── Magnetic buttons ───────────────────────────────────────────
  function initMagnetic() {
    document.querySelectorAll('.btn-primary').forEach(btn => {
      const el = btn as HTMLElement;
      el.addEventListener('mousemove', (e: Event) => {
        const me = e as MouseEvent;
        const r  = el.getBoundingClientRect();
        const x  = (me.clientX - r.left  - r.width  / 2) * 0.28;
        const y  = (me.clientY - r.top   - r.height / 2) * 0.28;
        el.style.transform  = `translate(${x}px, ${y}px) translateY(-1px)`;
        el.style.transition = 'transform 0.1s ease';
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform  = '';
        el.style.transition = 'transform 0.4s cubic-bezier(0.16,1,0.3,1), background 0.2s, box-shadow 0.2s';
      });
    });
  }

  // ── 3D card tilt ───────────────────────────────────────────────
  function initTilt() {
    const TILT = '.pick-card, .story-secondary, .calc-card, .compare-card, .story-strip-item';
    document.querySelectorAll(TILT).forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: Event) => {
        const me = e as MouseEvent;
        const r  = el.getBoundingClientRect();
        const x  = (me.clientX - r.left) / r.width  - 0.5;
        const y  = (me.clientY - r.top)  / r.height - 0.5;
        el.style.transform  = `perspective(700px) rotateY(${x * 7}deg) rotateX(${-y * 7}deg) translateZ(6px)`;
        el.style.transition = 'transform 0.08s ease';
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform  = '';
        el.style.transition = 'transform 0.5s cubic-bezier(0.16,1,0.3,1), box-shadow 0.25s ease';
      });
    });
  }

  // ── Scroll reveal ──────────────────────────────────────────────
  function initScrollReveal() {
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -36px 0px' }
    );
    document.querySelectorAll('.reveal-item:not(.revealed)').forEach(el => obs.observe(el));
  }

  // ── Search (Pagefind) ──────────────────────────────────────────
  function initSearch() {
    const modal   = document.getElementById('search-modal');
    const overlay = document.getElementById('search-overlay');
    const btn     = document.getElementById('search-btn') as HTMLElement | null;
    if (!modal || btn?.dataset.initialized) return;
    if (btn) btn.dataset.initialized = 'true';

    let pfLoaded = false;

    function openSearch() {
      modal!.removeAttribute('aria-hidden');
      if (!pfLoaded) {
        pfLoaded = true;
        document.head.appendChild(Object.assign(document.createElement('link'),
          { rel: 'stylesheet', href: '/pagefind/pagefind-ui.css' }));
        const s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.onload = () => {
          new (window as any).PagefindUI({ element: '#search-container', showImages: false });
          focus();
        };
        document.head.appendChild(s);
      } else { focus(); }
    }
    function focus() {
      setTimeout(() => (document.querySelector('#search-container input') as HTMLInputElement)?.focus(), 80);
    }
    function closeSearch() { modal!.setAttribute('aria-hidden', 'true'); }

    btn?.addEventListener('click', openSearch);
    overlay?.addEventListener('click', closeSearch);
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
      if (e.key === 'Escape') closeSearch();
    });
  }

  // ── Cookie consent ─────────────────────────────────────────────
  function initCookie() {
    const banner  = document.getElementById('cookie-banner') as HTMLElement | null;
    const accept  = document.getElementById('cookie-accept');
    const decline = document.getElementById('cookie-decline');
    if (!banner || (banner as HTMLElement).dataset.initialized) return;
    (banner as HTMLElement).dataset.initialized = 'true';

    const stored = localStorage.getItem('folvr-cookie');
    if (!stored) setTimeout(() => { banner.hidden = false; }, 1200);

    accept?.addEventListener('click', () => {
      localStorage.setItem('folvr-cookie', 'accepted');
      banner.hidden = true;
    });
    decline?.addEventListener('click', () => {
      localStorage.setItem('folvr-cookie', 'declined');
      banner.hidden = true;
    });
  }

  // ── Newsletter ─────────────────────────────────────────────────
  function initNewsletter() {
    const form    = document.getElementById('newsletter-form') as HTMLFormElement | null;
    const success = document.getElementById('newsletter-success') as HTMLElement | null;
    if (!form || (form as HTMLElement).dataset.initialized) return;
    (form as HTMLElement).dataset.initialized = 'true';

    form.addEventListener('submit', (e: Event) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]') as HTMLInputElement;
      if (!input?.value || !input.validity.valid) {
        input?.focus();
        return;
      }
      form.style.display = 'none';
      if (success) success.style.display = 'block';
      // TODO: Connect to email service (Resend, ConvertKit, etc.)
    });
  }

  // ── Back to top ────────────────────────────────────────────────
  function initBackToTop() {
    const btn = document.getElementById('back-to-top') as HTMLElement | null;
    if (!btn || (btn as HTMLElement).dataset.initialized) return;
    (btn as HTMLElement).dataset.initialized = 'true';

    lenis?.on('scroll', ({ scroll }: { scroll: number }) => {
      btn.classList.toggle('visible', scroll > 400);
    });
    btn.addEventListener('click', () => lenis?.scrollTo(0, { duration: 1.4 }));
  }

  // ── Boot on every page (View Transitions aware) ────────────────
  document.addEventListener('astro:page-load', () => {
    initLenis();
    initMobileMenu();
    initDarkMode();
    initCursor();
    initMagnetic();
    initTilt();
    initScrollReveal();
    initSearch();
    initCookie();
    initNewsletter();
    initBackToTop();
  });
</script>
