<script>
  // ── Number Scramble ───────────────────────────────────────────────
  const DIGITS = '0123456789';
  function scramble(el: Element) {
    const d       = el as HTMLElement;
    const target  = parseInt(d.dataset.count  || '0');
    const suffix  = d.dataset.suffix  || '';
    const prefix  = d.dataset.prefix  || '';
    const isDecim = d.dataset.decimals === 'true';
    const dur = 1500, t0 = performance.now();
    function tick(now: number) {
      const p    = Math.min((now - t0) / dur, 1);
      const ease = 1 - Math.pow(1 - p, 4);
      const val  = Math.round(ease * target);
      if (p < 0.75) {
        const noise = Math.max(0, Math.floor((1 - p / 0.75) * 2));
        let tail = '';
        for (let i = 0; i < noise; i++) tail += DIGITS[Math.floor(Math.random() * 10)];
        d.textContent = isDecim
          ? `${prefix}${(val / 100).toFixed(2)}${tail}${suffix}`
          : `${prefix}${val}${tail}${suffix}`;
      } else {
        d.textContent = isDecim
          ? `${prefix}${(target / 100).toFixed(2)}${suffix}`
          : `${prefix}${val}${suffix}`;
      }
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const scrambleObs = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) { scramble(e.target); scrambleObs.unobserve(e.target); } }),
    { threshold: 0.5 }
  );
  document.querySelectorAll('[data-count]').forEach(el => scrambleObs.observe(el));

  // ── Tab Switcher ──────────────────────────────────────────────────
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('tab-active'));
      btn.classList.add('tab-active');
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('tab-hidden'));
      const panel = document.getElementById(`tab-${tab}`);
      if (panel) {
        panel.classList.remove('tab-hidden');
        panel.querySelectorAll('.reveal-item:not(.revealed)').forEach((el, i) => {
          setTimeout(() => el.classList.add('revealed'), i * 55);
        });
      }
    });
  });
</script>
