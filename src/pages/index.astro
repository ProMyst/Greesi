---
import BaseLayout from '../layouts/BaseLayout.astro';
import RatingBadge from '../components/shared/RatingBadge.astro';
import banks from "../data/finance/banks.json";
import creditCards from "../data/finance/credit-cards.json";
import investing from "../data/finance/investing.json";
import destinations from "../data/travel/destinations.json";

const title = "Folvr — Finance Smarter. Travel Farther.";
const description = "Compare banks, credit cards, and investing platforms. Explore the world's best coastal destinations and learn how to fund your travels with the right rewards cards.";

const topBanks = [...banks].sort((a, b) => b.rating - a.rating).slice(0, 4);
const topCards = [...creditCards].sort((a, b) => b.rating - a.rating).slice(0, 4);
const topInvesting = [...investing].sort((a, b) => b.rating - a.rating).slice(0, 4);
const topDestinations = [...destinations].sort((a, b) => b.rating - a.rating).slice(0, 4);
const travelCards = creditCards.filter(c => ['Travel', 'Premium Travel'].includes(c.category)).slice(0, 3);

// Top Performing Stories — hand-picked editorial
const leadStory = {
  href: '/finance/review/fidelity',
  eyebrow: 'Investing',
  title: 'Why Fidelity Remains the Gold Standard for Long-Term Investors',
  desc: 'Zero commissions, no account minimums, and fractional shares — Fidelity keeps pulling ahead of the pack.',
  tag: 'Editor\'s Pick',
  rating: 4.8,
};
const secondaryStories = [
  {
    href: '/finance/review/ally',
    eyebrow: 'Banking',
    title: 'Ally Bank Review 2026: Still the Best Online Savings Rate?',
    tag: 'Top Rated',
    rating: 4.7,
  },
  {
    href: '/travel/destinations/maldives',
    eyebrow: 'Travel',
    title: 'Maldives 2026: The Ultimate Overwater Bungalow Guide',
    tag: 'Trending',
    rating: 4.9,
  },
];
const stripStories = [
  { href: '/finance/review/capital-one-venture-x', eyebrow: 'Credit Cards', title: 'Capital One Venture X: Best All-Around Travel Card?', rating: 4.7 },
  { href: '/travel/destinations/british-virgin-islands', eyebrow: 'Travel', title: 'BVI Sailing Guide: Hidden Anchorages & Best Months to Go', rating: 4.9 },
  { href: '/finance/compare/ally-vs-sofi', eyebrow: 'Compare', title: 'Ally vs SoFi 2026: Which High-Yield Account Wins?', rating: null },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Folvr",
  "url": "https://folvr.com",
  "description": description
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section class="hero-root">
    <!-- Animated orbs -->
    <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-3" aria-hidden="true"></div>

    <div class="hero-inner section-container">
      <div class="hero-content">
        <!-- Eyebrow -->
        <div class="hero-eyebrow reveal-item" style="--delay:0.05s">
          <span class="eyebrow-dot"></span>
          Finance · Travel · Smart Money
        </div>

        <!-- Headline -->
        <h1 class="hero-headline">
          <span class="hero-line reveal-item" style="--delay:0.12s">Finance Your Life.</span>
          <span class="hero-line hero-line-accent reveal-item" style="--delay:0.22s">Travel Smarter.</span>
        </h1>

        <!-- Subhead -->
        <p class="hero-sub reveal-item" style="--delay:0.32s">
          Unbiased comparisons for banks, credit cards, and brokers —
          plus expert coastal travel guides to help you get more miles out of every dollar.
        </p>

        <!-- CTAs -->
        <div class="hero-ctas reveal-item" style="--delay:0.42s">
          <a href="/finance/banking" class="btn-primary">Compare Banks</a>
          <a href="/travel" class="btn-ghost">Explore Destinations</a>
        </div>

        <!-- Floating stat chips -->
        <div class="hero-chips reveal-item" style="--delay:0.54s">
          <div class="hero-chip">
            <span class="chip-num" data-count="25" data-suffix="+">0</span>
            <span class="chip-label">Products Reviewed</span>
          </div>
          <div class="hero-chip">
            <span class="chip-num" data-count="480" data-prefix="4." data-suffix="%" data-decimals="true">0</span>
            <span class="chip-label">Top Savings APY</span>
          </div>
          <div class="hero-chip">
            <span class="chip-num" data-count="10" data-suffix=" Destinations">0</span>
            <span class="chip-label">Coastal Guides</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero-scroll-hint" aria-hidden="true">
      <span class="scroll-label">Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ── Top Performing Stories ────────────────────────────────────── -->
  <section class="stories-root section-container">
    <div class="stories-header reveal-item">
      <span class="section-eyebrow">Top Performing Stories</span>
      <h2 class="stories-title">What Readers Are Exploring</h2>
    </div>

    <div class="stories-grid">
      <!-- Lead card -->
      <a href={leadStory.href} class="story-lead reveal-item card-lift" style="--delay:0.08s">
        <div class="story-lead-bg" aria-hidden="true"></div>
        <div class="story-lead-body">
          <div class="story-meta">
            <span class="story-eyebrow">{leadStory.eyebrow}</span>
            <span class="story-tag">{leadStory.tag}</span>
          </div>
          <h3 class="story-lead-title">{leadStory.title}</h3>
          <p class="story-lead-desc">{leadStory.desc}</p>
          <div class="story-lead-footer">
            <RatingBadge rating={leadStory.rating} size="sm" />
            <span class="story-read">Read →</span>
          </div>
        </div>
      </a>

      <!-- Secondary stack -->
      <div class="story-secondary-stack">
        {secondaryStories.map((s, i) => (
          <a href={s.href} class="story-secondary reveal-item card-lift" style={`--delay:${0.12 + i * 0.08}s`}>
            <div class="story-meta">
              <span class="story-eyebrow">{s.eyebrow}</span>
              <span class="story-tag">{s.tag}</span>
            </div>
            <h3 class="story-secondary-title">{s.title}</h3>
            <div class="story-secondary-footer">
              <RatingBadge rating={s.rating} size="sm" />
              <span class="story-read">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Strip row -->
    <div class="story-strip">
      {stripStories.map((s, i) => (
        <a href={s.href} class="story-strip-item reveal-item card-lift" style={`--delay:${0.06 + i * 0.07}s`}>
          <span class="story-eyebrow">{s.eyebrow}</span>
          <h4 class="story-strip-title">{s.title}</h4>
          {s.rating && <RatingBadge rating={s.rating} size="sm" />}
          {!s.rating && <span class="story-compare-tag">Compare →</span>}
        </a>
      ))}
    </div>
  </section>

  <!-- ── Stats Strip ────────────────────────────────────────────────── -->
  <div class="stats-strip">
    <div class="stats-inner section-container">
      {[
        { num: 25, suffix: '+', label: 'Financial Products' },
        { num: 10, suffix: '', label: 'Coastal Destinations' },
        { num: 94, suffix: '+', label: 'Side-by-Side Comparisons' },
        { num: 2, suffix: ' Free Calculators', label: 'Planning Tools' },
      ].map((s, i) => (
        <div class="stat-item reveal-item" style={`--delay:${i * 0.07}s`}>
          <span class="stat-num" data-count={s.num} data-suffix={s.suffix}>0</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Finance Picks (Tabbed) ─────────────────────────────────────── -->
  <section class="picks-root section-container">
    <div class="picks-header reveal-item">
      <div>
        <span class="section-eyebrow">Finance</span>
        <h2 class="picks-title">Top Picks for 2026</h2>
      </div>
      <div class="tab-bar" role="tablist">
        <button class="tab-btn tab-active" data-tab="banks" role="tab">Banks</button>
        <button class="tab-btn" data-tab="cards" role="tab">Credit Cards</button>
        <button class="tab-btn" data-tab="investing" role="tab">Investing</button>
      </div>
    </div>

    <!-- Banks tab -->
    <div id="tab-banks" class="tab-panel">
      <div class="picks-grid">
        {topBanks.map((bank, i) => (
          <a href={`/finance/review/${bank.slug}`} class="pick-card reveal-item card-lift" style={`--delay:${i * 0.06}s`}>
            <div class="pick-rank">#{i + 1}</div>
            <RatingBadge rating={bank.rating} size="sm" />
            <h3 class="pick-name">{bank.name}</h3>
            <p class="pick-type">{bank.type}</p>
            <div class="pick-stat">
              <span class="pick-stat-num">{bank.savingsApy}</span>
              <span class="pick-stat-label">savings APY</span>
            </div>
          </a>
        ))}
      </div>
      <div class="picks-viewall">
        <a href="/finance/banking" class="viewall-link">View All Banks →</a>
      </div>
    </div>

    <!-- Cards tab -->
    <div id="tab-cards" class="tab-panel tab-hidden">
      <div class="picks-grid">
        {topCards.map((card, i) => (
          <a href={`/finance/review/${card.slug}`} class="pick-card reveal-item card-lift" style={`--delay:${i * 0.06}s`}>
            <div class="pick-rank">#{i + 1}</div>
            <RatingBadge rating={card.rating} size="sm" />
            <h3 class="pick-name">{card.name}</h3>
            <p class="pick-type">{card.category}</p>
            <div class="pick-stat">
              <span class="pick-stat-num">{card.annualFee}</span>
              <span class="pick-stat-label">annual fee</span>
            </div>
          </a>
        ))}
      </div>
      <div class="picks-viewall">
        <a href="/finance/credit-cards" class="viewall-link">View All Cards →</a>
      </div>
    </div>

    <!-- Investing tab -->
    <div id="tab-investing" class="tab-panel tab-hidden">
      <div class="picks-grid">
        {topInvesting.map((platform, i) => (
          <a href={`/finance/review/${platform.slug}`} class="pick-card reveal-item card-lift" style={`--delay:${i * 0.06}s`}>
            <div class="pick-rank">#{i + 1}</div>
            <RatingBadge rating={platform.rating} size="sm" />
            <h3 class="pick-name">{platform.name}</h3>
            <p class="pick-type">{platform.type}</p>
            <p class="pick-bestfor">{platform.bestFor}</p>
          </a>
        ))}
      </div>
      <div class="picks-viewall">
        <a href="/finance/investing" class="viewall-link">View All Platforms →</a>
      </div>
    </div>
  </section>

  <!-- ── Travel Destinations ────────────────────────────────────────── -->
  <section class="travel-root">
    <div class="travel-inner section-container">
      <div class="travel-header reveal-item">
        <div>
          <span class="section-eyebrow" style="color: rgba(255,255,255,0.5)">Travel</span>
          <h2 class="travel-title">Top Coastal Destinations</h2>
          <p class="travel-sub">Shores, sails, and island escapes — ranked by our editors</p>
        </div>
        <a href="/travel" class="travel-viewall">View All →</a>
      </div>

      <div class="travel-grid">
        {topDestinations.map((dest, i) => (
          <a href={`/travel/destinations/${dest.slug}`} class="dest-card reveal-item card-lift" style={`--delay:${i * 0.07}s`}>
            <div class="dest-card-bg" style={`--hue:${185 + i * 12}deg`} aria-hidden="true"></div>
            <div class="dest-card-body">
              <div class="dest-top">
                <span class="dest-rank">#{i + 1}</span>
                <RatingBadge rating={dest.rating} size="sm" />
              </div>
              <div class="dest-bottom">
                <span class="dest-region">{dest.region}</span>
                <h3 class="dest-name">{dest.name}</h3>
                <p class="dest-meta">{dest.budgetLevel} · {dest.bestSeason.split(' ')[0]}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Travel × Finance Crossover ────────────────────────────────── -->
  <section class="crossover-root section-container">
    <div class="crossover-header reveal-item">
      <span class="section-eyebrow">Travel × Finance</span>
      <h2 class="crossover-title">Fund Your Next Trip with the Right Card</h2>
      <p class="crossover-sub">Earn points on everyday spending — redeem for flights, hotels, and upgrades</p>
    </div>

    <div class="crossover-grid">
      {travelCards.map((card, i) => (
        <a href={`/finance/review/${card.slug}`} class="crossover-card reveal-item card-lift" style={`--delay:${i * 0.08}s`}>
          <div class="crossover-card-top">
            <span class="crossover-eyebrow">{card.category}</span>
            <RatingBadge rating={card.rating} size="sm" />
          </div>
          <h3 class="crossover-card-name">{card.name}</h3>
          <p class="crossover-fee">{card.annualFee}/yr · No foreign transaction fee</p>
          <p class="crossover-desc">{card.bestFor}</p>
          <span class="crossover-cta">Read Review →</span>
        </a>
      ))}
    </div>

    <div class="crossover-footer reveal-item">
      <a href="/travel/travel-cards" class="btn-primary">Compare All Travel Cards →</a>
    </div>
  </section>

  <!-- ── Popular Comparisons ────────────────────────────────────────── -->
  <section class="compare-root">
    <div class="compare-inner section-container">
      <div class="compare-header reveal-item">
        <span class="section-eyebrow">Compare</span>
        <h2 class="compare-title">Head-to-Head Comparisons</h2>
        <p class="compare-sub">Our most-read side-by-side breakdowns</p>
      </div>

      <div class="compare-grid">
        {[
          { a: banks[1], b: banks[4] },
          { a: creditCards[0], b: creditCards[1] },
          { a: investing[0], b: investing[1] },
          { a: banks[0], b: banks[1] },
          { a: creditCards[2], b: creditCards[7] },
          { a: investing[3], b: investing[4] },
        ].map(({ a, b }, i) => (
          <a href={`/finance/compare/${a.slug}-vs-${b.slug}`} class="compare-card reveal-item card-lift" style={`--delay:${(i % 3) * 0.06}s`}>
            <div class="compare-names">
              <span class="compare-name">{a.name}</span>
              <span class="compare-vs">vs</span>
              <span class="compare-name">{b.name}</span>
            </div>
            <div class="compare-ratings">
              <RatingBadge rating={a.rating} size="sm" />
              <RatingBadge rating={b.rating} size="sm" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Calculators CTA ────────────────────────────────────────────── -->
  <section class="calc-root section-container">
    <div class="calc-header reveal-item">
      <span class="section-eyebrow">Tools</span>
      <h2 class="calc-title">Free Financial Calculators</h2>
      <p class="calc-sub">Plan your financial future with our free tools</p>
    </div>
    <div class="calc-grid">
      <a href="/finance/calculators/compound-interest" class="calc-card reveal-item card-lift" style="--delay:0.06s">
        <div class="calc-icon" aria-hidden="true">%</div>
        <h3 class="calc-name">Compound Interest</h3>
        <p class="calc-desc">See how your savings grow over time with compounding returns</p>
        <span class="calc-link">Open Calculator →</span>
      </a>
      <a href="/finance/calculators/loan" class="calc-card reveal-item card-lift" style="--delay:0.12s">
        <div class="calc-icon" aria-hidden="true">$</div>
        <h3 class="calc-name">Loan Payment</h3>
        <p class="calc-desc">Calculate monthly payments and the true cost of any loan</p>
        <span class="calc-link">Open Calculator →</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ────────────────────────────────────────────────────────── */
.hero-root {
  position: relative;
  min-height: 100svh;
  background: #0a1628;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  animation: orb-drift 18s ease-in-out infinite;
}
.hero-orb-1 {
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(14,165,233,0.18) 0%, transparent 70%);
  top: -100px; left: -150px;
  animation-delay: 0s;
}
.hero-orb-2 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(99,102,241,0.14) 0%, transparent 70%);
  bottom: -80px; right: -100px;
  animation-delay: -6s;
}
.hero-orb-3 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(16,185,129,0.10) 0%, transparent 70%);
  top: 40%; left: 55%;
  animation-delay: -12s;
}

.hero-inner {
  position: relative;
  z-index: 1;
  padding-top: 120px;
  padding-bottom: 80px;
}

.hero-content {
  max-width: 760px;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 28px;
}
.eyebrow-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.5; transform: scale(0.7); }
}

.hero-headline {
  margin: 0 0 24px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.hero-line {
  display: block;
  font-size: clamp(2.6rem, 6vw, 4.5rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.08;
  color: white;
  overflow: hidden;
}
.hero-line-accent { color: var(--color-accent); }

.hero-sub {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: rgba(255,255,255,0.5);
  line-height: 1.7;
  max-width: 580px;
  margin-bottom: 36px;
}

.hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 48px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  background: var(--color-accent);
  color: white;
  font-weight: 700;
  font-size: 0.9rem;
  padding: 13px 28px;
  border-radius: 10px;
  text-decoration: none;
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 4px 20px rgba(14,165,233,0.35);
}
.btn-primary:hover {
  background: var(--color-accent-dark);
  transform: translateY(-1px);
  box-shadow: 0 6px 28px rgba(14,165,233,0.45);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.8);
  font-weight: 600;
  font-size: 0.9rem;
  padding: 13px 28px;
  border-radius: 10px;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,0.12);
  transition: background 0.2s, color 0.2s;
  backdrop-filter: blur(8px);
}
.btn-ghost:hover {
  background: rgba(255,255,255,0.12);
  color: white;
}

.hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.hero-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 40px;
  padding: 8px 16px 8px 14px;
  backdrop-filter: blur(12px);
}
.chip-num {
  font-size: 1.05rem;
  font-weight: 800;
  color: white;
  letter-spacing: -0.02em;
  font-variant-numeric: tabular-nums;
}
.chip-label {
  font-size: 0.7rem;
  font-weight: 500;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.hero-scroll-hint {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  animation: fade-in 1.2s 1.2s both;
}
.scroll-label {
  font-size: 0.65rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.25);
}
.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
  animation: scroll-line 1.8s ease-in-out infinite;
}
@keyframes scroll-line {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  51%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

/* ── Stories ─────────────────────────────────────────────────────── */
.stories-root {
  padding: 80px 24px 0;
}
.stories-header {
  margin-bottom: 32px;
}
.stories-title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--color-text);
  margin: 6px 0 0;
}

.stories-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 16px;
}
@media (min-width: 768px) {
  .stories-grid { grid-template-columns: 1.7fr 1fr; }
}

/* Lead card */
.story-lead {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  min-height: 320px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  background: #0a1628;
}
.story-lead-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #0d2340 0%, #0a4f6e 50%, #0ea5e9 100%);
  opacity: 0.85;
}
.story-lead-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,22,40,0.9) 0%, transparent 60%);
}
.story-lead-body {
  position: relative;
  z-index: 1;
  padding: 28px;
}
.story-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}
.story-eyebrow {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent);
}
.story-tag {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.08em;
