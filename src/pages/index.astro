            <div class="g-signal-metric">
              <span class="g-signal-metric-val g-mono">29</span>
              <span class="g-signal-metric-label">Active pipelines</span>
            </div>
            <div class="g-signal-metric">
              <span class="g-signal-metric-val g-mono">Live</span>
              <span class="g-signal-metric-label">Data freshness</span>
