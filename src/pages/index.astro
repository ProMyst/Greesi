<style>
  /* ── Tokens ──────────────────────────────────────────── */
  :root {
    --black:    #080B0F;
    --black-2:  #0D1117;
    --black-3:  #161B22;
    --black-4:  #21262D;
    --border:   #21262D;
    --border-accent: #30363D;
    --gray-1:   #30363D;
    --gray-2:   #484F58;
    --gray-3:   #6E7681;
    --gray-4:   #8B949E;
    --gray-5:   #C9D1D9;
    --white:    #F0F6FC;
    --white-70: rgba(240,246,252,0.7);
    --white-40: rgba(240,246,252,0.4);
    --white-12: rgba(240,246,252,0.12);
    --white-06: rgba(240,246,252,0.06);
    --accent:        #e8ff5a;
    --accent-dim:    rgba(232,255,90,0.12);
    --accent-primary: #1F6FEB;
    --accent-glow:   rgba(31,111,235,0.18);
    --signal-green:  #39D353;
    --signal-red:    #F85149;
    --signal-blue:   #58A6FF;
    --signal-amber:  #D29922;
    --up:     #39D353;
    --up-dim: rgba(57,211,83,0.12);
    --radius:    14px;
    --radius-sm: 8px;
    --font:      'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-mono:    'JetBrains Mono', 'Fira Code', monospace;
  }

  /* ── Reset ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-family: var(--font); background: var(--black); color: var(--white); -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
  body { overflow-x: hidden; }
  a { text-decoration: none; color: inherit; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  img, svg { display: block; }

  /* ── Reveal animation ────────────────────────────────── */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  /* ── Nav ─────────────────────────────────────────────── */
  .g-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s, backdrop-filter 0.3s;
    opacity: 0;
  }
  .g-nav.scrolled {
    background: rgba(10,10,10,0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: var(--white-12);
  }
  .g-nav-inner {
    max-width: 1160px; margin: 0 auto; padding: 0 24px;
    height: 64px; display: flex; align-items: center; gap: 32px;
  }
  .g-logo { flex-shrink: 0; display: flex; align-items: center; gap: 6px; }
  .g-nav-links { display: flex; gap: 28px; margin-left: 8px; }
  .g-nav-link { font-size: 0.82rem; font-weight: 500; color: var(--gray-5); letter-spacing: 0.01em; transition: color 0.2s; }
  .g-nav-link:hover { color: var(--white); }
  .g-nav-right { margin-left: auto; }
  .g-btn-access {
    background: var(--white); color: var(--black); font-size: 0.78rem; font-weight: 600;
    padding: 8px 18px; border-radius: 99px; transition: background 0.2s, color 0.2s;
    letter-spacing: 0.01em;
  }
  .g-btn-access:hover { background: var(--gray-5); }
  .g-hamburger { display: none; flex-direction: column; gap: 5px; padding: 8px; margin-left: 12px; }
  .g-hamburger span { display: block; width: 20px; height: 1.5px; background: var(--white); border-radius: 99px; transition: transform 0.25s; }
  .g-mobile-menu {
    display: none; flex-direction: column;
    padding: 12px 24px 20px;
    border-top: 1px solid var(--white-12);
    background: rgba(10,10,10,0.96);
  }
  .g-mobile-menu.open { display: flex; }
  .g-mobile-link { padding: 12px 0; font-size: 0.9rem; font-weight: 500; color: var(--gray-5); border-bottom: 1px solid var(--white-06); }
  .g-mobile-link:last-child { border-bottom: none; }
  .g-mobile-cta { color: var(--white); font-weight: 600; margin-top: 8px; }

  @media (max-width: 680px) {
    .g-nav-links, .g-nav-right { display: none; }
    .g-hamburger { display: flex; margin-left: auto; }
  }

  /* ── Hero ────────────────────────────────────────────── */
  .g-hero {
    position: relative; min-height: 100svh;
    display: flex; align-items: center;
    background: var(--black);
    padding: 120px 24px 80px;
    overflow: hidden;
  }
  .g-hero-bg-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }
  .g-hero-glow {
    position: absolute; border-radius: 50%; pointer-events: none;
    filter: blur(80px); opacity: 0.18;
  }
  .g-hero-glow-1 {
    width: 500px; height: 500px;
