  <div class="g-hero-glow g-hero-glow-2" aria-hidden="true"></div>
  <div class="g-hero-inner">
    <div class="g-hero-eyebrow reveal">
      <span class="g-dot"></span>
      Intelligence Platform
    </div>
    <h1 class="g-hero-headline">
      <span class="g-word"><span class="g-word-inner">Signal,</span></span>
      <br/>
      <span class="g-word"><span class="g-word-inner">not</span></span>
      <span class="g-word"><span class="g-word-inner">noise.</span></span>
