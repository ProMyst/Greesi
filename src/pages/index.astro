  }
  .g-cat-card:hover { border-color: var(--white-12); background: var(--black-3); }
  .g-cat-icon { color: var(--gray-3); width: 40px; height: 40px; display: flex; align-items: center; }
  .g-cat-title { font-size: 0.95rem; font-weight: 700; color: var(--white); }
  .g-cat-body { font-size: 0.8rem; color: var(--gray-4); line-height: 1.6; flex: 1; }
  .g-cat-link { font-size: 0.75rem; font-weight: 600; color: var(--gray-3); margin-top: 4px; transition: color 0.2s; }
  .g-cat-card:hover .g-cat-link { color: var(--white); }

  /* ── Proof bar ───────────────────────────────────────── */
  .g-proof-bar {
    background: var(--black-2); border-top: 1px solid var(--white-06); border-bottom: 1px solid var(--white-06);
    padding: 48px 24px;
  }
  .g-proof-bar-inner {
    max-width: 900px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 32px;
  }
  .g-proof-item { text-align: center; display: flex; flex-direction: column; gap: 6px; }
  .g-proof-bar-num { font-size: 2.2rem; font-weight: 700; letter-spacing: -0.04em; color: var(--white); }
  .g-proof-bar-label { font-size: 0.72rem; color: var(--gray-4); font-weight: 500; text-transform: uppercase; letter-spacing: 0.07em; }

  /* ── Access CTA ──────────────────────────────────────── */
  .g-access {
    padding: 120px 24px;
    background: var(--black);
    text-align: center;
  }
  .g-access-inner { max-width: 560px; margin: 0 auto; }
  .g-access-headline {
    font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; letter-spacing: -0.035em;
    line-height: 1.1; color: var(--white); margin-bottom: 18px;
  }
  .g-access-sub { font-size: 0.9rem; color: var(--gray-4); line-height: 1.75; margin-bottom: 36px; }
  .g-access-form {
    display: flex; gap: 10px; max-width: 420px; margin: 0 auto 14px;
    flex-wrap: wrap; justify-content: center;
  }
  .g-access-input {
    flex: 1; min-width: 200px; background: var(--black-3); border: 1px solid var(--white-12);
    border-radius: 99px; padding: 13px 20px; font-size: 0.875rem; font-family: var(--font);
    color: var(--white); outline: none; transition: border-color 0.2s;
  }
  .g-access-input::placeholder { color: var(--gray-3); }
  .g-access-input:focus { border-color: var(--white-40); }
  .g-access-fine { font-size: 0.72rem; color: var(--gray-3); letter-spacing: 0.02em; }

  /* ── Footer ──────────────────────────────────────────── */
  .g-footer {
    background: var(--black-2); border-top: 1px solid var(--white-06);
    padding: 64px 24px 0;
  }
  .g-footer-inner {
    max-width: 1080px; margin: 0 auto;
    display: flex; gap: 64px; flex-wrap: wrap; margin-bottom: 48px;
  }
  .g-footer-brand { flex: 0 0 220px; display: flex; flex-direction: column; gap: 16px; }
  .g-footer-tagline { font-size: 0.78rem; color: var(--gray-3); line-height: 1.6; }
  .g-footer-cols { display: flex; gap: 48px; flex: 1; flex-wrap: wrap; }
  .g-footer-col { display: flex; flex-direction: column; gap: 10px; min-width: 120px; }
  .g-footer-col-head { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray-3); margin-bottom: 4px; }
  .g-footer-link { font-size: 0.8rem; color: var(--gray-4); transition: color 0.2s; }
  .g-footer-link:hover { color: var(--white); }
