  }
  .g-signal-card:hover { border-color: var(--white-12); background: var(--black-4); }
  .g-signal-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .g-signal-category {
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-3);
  }
  .g-signal-badge {
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 99px; background: var(--white-06); color: var(--gray-5);
  }
  .g-signal-badge.up { background: var(--up-dim); color: var(--up); }
  .g-signal-badge.neutral { background: var(--accent-dim); color: var(--accent); }
  .g-signal-body { flex: 1; }
  .g-signal-headline { font-size: 0.95rem; font-weight: 600; line-height: 1.5; color: var(--white); margin-bottom: 20px; }
  .g-signal-metrics { display: flex; gap: 20px; margin-bottom: 16px; }
  .g-signal-metric { display: flex; flex-direction: column; gap: 3px; }
  .g-signal-metric-val { font-size: 1.15rem; font-weight: 700; color: var(--white); letter-spacing: -0.02em; font-family: var(--font-mono); }
  .g-signal-metric-label { font-size: 0.62rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-3); }
  .g-signal-note { font-size: 0.78rem; color: var(--gray-4); line-height: 1.65; }
  .g-signal-cta {
    font-size: 0.78rem; font-weight: 600; color: var(--gray-4);
    border-top: 1px solid var(--white-06); padding-top: 16px;
    transition: color 0.2s;
  }
  .g-signal-cta:hover { color: var(--white); }

  /* ── Category grid ───────────────────────────────────── */
  .g-cat-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;
  }
  .g-cat-card {
    background: var(--black-2); border: 1px solid var(--white-06); border-radius: var(--radius);
    padding: 28px 24px; display: flex; flex-direction: column; gap: 12px;
