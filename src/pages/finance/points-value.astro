---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "How Much Are Travel Points Worth? 2026 Guide — Greesi";
const description = "Learn exactly what your Chase, Amex, Capital One, Citi, airline, and hotel points are worth. Compare base values vs transfer partner maximums to get the most from your rewards.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "How Much Are Travel Points Worth? 2026 Guide",
  "description": description,
  "author": { "@type": "Organization", "name": "Greesi" }
};

const transferablePrograms = [
  {
    name: 'Chase Ultimate Rewards',
    issuer: 'Chase',
    color: '#1a6fe3',
    icon: '🔵',
    baseValue: 1.0,
    portalValue: 1.25,
    maxValue: 2.1,
    bestTip: 'Transfer to World of Hyatt for outsized hotel redemptions — consistently the top transfer partner.',
    redemptions: [
      { method: 'Statement credit / cash back', value: 1.0 },
      { method: 'Chase travel portal (Sapphire Preferred)', value: 1.25 },
      { method: 'Chase travel portal (Sapphire Reserve)', value: 1.5 },
      { method: 'Transfer partners (average)', value: 1.5 },
      { method: 'Transfer partners (best — Hyatt)', value: 2.1 },
    ],
  },
  {
    name: 'Amex Membership Rewards',
    issuer: 'American Express',
    color: '#007bc1',
    icon: '🟦',
    baseValue: 0.8,
    portalValue: 1.0,
    maxValue: 2.1,
    bestTip: 'Transfer to Singapore Airlines KrisFlyer or Air France/KLM Flying Blue for premium cabin sweet spots.',
    redemptions: [
      { method: 'Statement credit', value: 0.6 },
      { method: 'Shop with points (Amazon, etc.)', value: 0.7 },
      { method: 'Amex travel portal', value: 1.0 },
      { method: 'Transfer partners (average)', value: 1.4 },
      { method: 'Transfer partners (best — Singapore / British)', value: 2.1 },
    ],
  },
  {
    name: 'Capital One Miles',
    issuer: 'Capital One',
    color: '#d03027',
    icon: '🔴',
    baseValue: 1.0,
    portalValue: 1.0,
    maxValue: 1.8,
    bestTip: 'Transfer to Turkish Airlines Miles & Smiles for Star Alliance redemptions at fixed-rate pricing.',
    redemptions: [
      { method: 'Cash back / statement credit', value: 1.0 },
      { method: 'Capital One travel portal', value: 1.0 },
      { method: 'Transfer partners (average)', value: 1.5 },
      { method: 'Transfer partners (best — Turkish / British)', value: 1.8 },
    ],
  },
  {
    name: 'Citi ThankYou Points',
    issuer: 'Citi',
    color: '#003d8f',
    icon: '🔷',
    baseValue: 1.0,
    portalValue: 1.0,
    maxValue: 1.7,
    bestTip: 'Transfer to Turkish Airlines or Air France/KLM Flying Blue for the best airline redemptions.',
    redemptions: [
      { method: 'Cash back / statement credit', value: 1.0 },
      { method: 'Citi travel portal', value: 1.0 },
      { method: 'Transfer partners (average)', value: 1.3 },
      { method: 'Transfer partners (best — Turkish)', value: 1.7 },
    ],
  },
];

const airlinePrograms = [
  { name: 'United MileagePlus', avgValue: 1.2, range: '0.8¢–1.8¢', tip: 'Best for Saver awards on United and Star Alliance partners.' },
  { name: 'Delta SkyMiles', avgValue: 1.1, range: '0.7¢–1.6¢', tip: 'Dynamic pricing — search broadly for flash sales to maximize value.' },
  { name: 'American Airlines AAdvantage', avgValue: 1.4, range: '1.0¢–2.0¢', tip: 'Great for international business class on partner airlines like Cathay Pacific.' },
  { name: 'Southwest Rapid Rewards', avgValue: 1.5, range: '1.4¢–1.7¢', tip: 'Consistent value — especially great when paired with the Companion Pass.' },
];

const hotelPrograms = [
  { name: 'Hilton Honors', avgValue: 0.5, range: '0.3¢–0.8¢', tip: 'Use for 5th-night-free award stays or aspirational Category 1–4 properties.' },
  { name: 'Marriott Bonvoy', avgValue: 0.7, range: '0.4¢–1.2¢', tip: 'Transfer to airlines at 60,000:25,000 ratio for occasional 5,000-point bonuses.' },
];

const tips = [
  { title: 'Always compare to cash price', body: 'Before redeeming, check the cash rate and divide by your points cost. If the math is under 1 cent per point, consider saving points for better opportunities.' },
  { title: 'Transfer partners beat portals', body: 'For most programs, transferring to airline or hotel partners yields 40–100% more value than booking through the issuer\'s own travel portal.' },
  { title: 'Avoid cash redemptions for premium programs', body: 'Amex Membership Rewards are worth only 0.6¢ as a statement credit. Never redeem Chase or Amex points for cash — the value erosion is severe.' },
  { title: 'Be flexible on dates and routes', body: 'Award space varies wildly. Being flexible with dates and open to one-stop routings dramatically increases your chance of finding high-value availability.' },
  { title: 'Stack transfer bonuses', body: 'Amex, Chase, and Capital One occasionally run 20–30% transfer bonuses to specific partners. Waiting for a bonus can add hundreds of dollars of value per redemption.' },
];

const faqs = [
  {
    q: 'What does "cents per point" mean?',
    a: 'It\'s the dollar value of a single point. A value of 1.5 cents per point means 10,000 points = $150 in travel. This metric lets you compare across programs and redemption options.',
  },
  {
    q: 'Are transfer partner values guaranteed?',
    a: 'No. Partner award charts change frequently (and mostly devalue). The values listed are estimates based on current sweet spots. Always verify current pricing before transferring — transfers are almost always irreversible.',
  },
  {
    q: 'What\'s the safest redemption if I\'m not sure?',
    a: 'Chase Ultimate Rewards through the travel portal (1.25¢–1.5¢) and Capital One Miles for travel statement credits (1.0¢) offer reliable, simple value without the complexity of transfers.',
  },
  {
    q: 'Why are Hilton points worth so little?',
    a: 'Hilton issues points liberally — their co-branded cards earn 3–14x points per dollar. The lower per-point value is offset by how many points you earn. A free night might cost 30,000–80,000 Hilton points vs 12,000–30,000 Marriott points.',
  },
  {
    q: 'Should I choose a card based on point value or earning rate?',
    a: 'Both matter — the formula is: value = earn rate × cents per point. A card earning 4x at 0.8¢ ($0.032/dollar) beats a card earning 2x at 1.5¢ ($0.030/dollar) — but only barely. Look at real-world redemption scenarios for your spending habits.',
  },
];
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-primary text-white py-16 has-noise">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="section-eyebrow">Points &amp; Miles Guide</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">How Much Are Travel Points Worth?</h1>
      <p class="text-white/65 text-lg max-w-2xl mx-auto">A complete breakdown of every major rewards currency — from Chase and Amex to airline miles and hotel points.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/finance" class="hover:text-accent transition-colors">Finance</a>
      <span class="mx-2">/</span>
      <span>Points Value Guide</span>
    </nav>

    <!-- Intro -->
    <section class="intro-block">
      <p class="intro-text">Not all points are created equal. A Chase Ultimate Rewards point can be worth anywhere from 1 cent to over 2 cents depending on how you redeem it — that's a 100% difference in value from the same point. Understanding point valuations is the single most important skill in travel rewards, and it's the difference between a mediocre redemption and a first-class flight you'd never otherwise afford.</p>
    </section>

    <!-- Transferable Currency Programs -->
    <section class="mb-14">
      <h2 class="section-heading">Transferable Bank Points</h2>
      <p class="section-subtext">These programs earn points with bank credit cards and let you transfer to multiple airline and hotel partners — giving them the widest range of potential value.</p>

      <div class="program-grid">
        {transferablePrograms.map(prog => {
          const barBase = (prog.baseValue / prog.maxValue) * 100;
          const barPortal = (prog.portalValue / prog.maxValue) * 100;
          return (
            <div class="program-card">
              <div class="program-header" style={`--prog-color: ${prog.color}`}>
                <div class="program-color-bar"></div>
                <div class="program-header-inner">
                  <h3 class="program-name">{prog.name}</h3>
                  <span class="program-issuer">{prog.issuer}</span>
                </div>
                <div class="program-value-pill">
                  <span class="value-pill-label">Max Value</span>
                  <span class="value-pill-num">{prog.maxValue}¢</span>
                </div>
              </div>

              <div class="value-spectrum">
                <div class="spectrum-labels">
                  <span class="spectrum-label">Base</span>
                  <span class="spectrum-label">Best</span>
                </div>
                <div class="spectrum-track">
                  <div class="spectrum-bar spectrum-bar--base" style={`width: ${barBase}%`}></div>
                  <div class="spectrum-bar spectrum-bar--portal" style={`width: ${barPortal}%`}></div>
                  <div class="spectrum-bar spectrum-bar--max" style="width: 100%"></div>
                </div>
                <div class="spectrum-markers">
                  <span style={`left: ${barBase}%`} class="spectrum-marker">{prog.baseValue}¢</span>
                  <span style={`left: ${barPortal}%`} class="spectrum-marker">{prog.portalValue}¢</span>
                  <span style="left: 100%" class="spectrum-marker spectrum-marker--end">{prog.maxValue}¢</span>
                </div>
              </div>

              <div class="redemption-table">
                {prog.redemptions.map((r, ri) => (
                  <div class={`redemption-row ${ri === prog.redemptions.length - 1 ? 'redemption-row--best' : ''}`}>
                    <span class="redemption-method">{r.method}</span>
                    <span class="redemption-value" style={ri === prog.redemptions.length - 1 ? `color: var(--color-success)` : ''}>{r.value}¢</span>
                  </div>
                ))}
              </div>

              <div class="program-tip">
                <span class="tip-icon">💡</span>
                <span class="tip-text">{prog.bestTip}</span>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Airline Miles -->
    <section class="mb-14">
      <h2 class="section-heading">Airline Miles</h2>
      <p class="section-subtext">Airline loyalty currencies have more limited transfer options but can still deliver excellent value for frequent flyers.</p>
      <div class="airline-grid">
        {airlinePrograms.map(prog => {
          const pct = Math.min(100, (prog.avgValue / 2.5) * 100);
          return (
            <div class="airline-card">
              <div class="airline-header">
                <span class="airline-name">{prog.name}</span>
                <span class="airline-avg">{prog.avgValue}¢ avg</span>
              </div>
              <div class="airline-bar-wrap">
                <div class="airline-bar" style={`width: ${pct}%`}></div>
              </div>
              <p class="airline-range">Range: {prog.range}</p>
              <p class="airline-tip">{prog.tip}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Hotel Points -->
    <section class="mb-14">
      <h2 class="section-heading">Hotel Points</h2>
      <p class="section-subtext">Hotel points tend to have lower per-point valuations but are earned at higher rates. Focus on the total value of a free night, not just cents per point.</p>
      <div class="hotel-grid">
        {hotelPrograms.map(prog => {
          const pct = Math.min(100, (prog.avgValue / 1.5) * 100);
          return (
            <div class="hotel-card">
              <div class="hotel-header">
                <span class="hotel-name">{prog.name}</span>
                <span class="hotel-avg">{prog.avgValue}¢ avg</span>
              </div>
              <div class="hotel-bar-wrap">
                <div class="hotel-bar" style={`width: ${pct}%`}></div>
              </div>
              <p class="hotel-range">Range: {prog.range}</p>
              <p class="hotel-tip">{prog.tip}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- How to Maximize -->
    <section class="mb-14">
      <h2 class="section-heading">How to Maximize Your Points Value</h2>
      <div class="tips-grid">
        {tips.map((tip, i) => (
          <div class="tip-card reveal-item" style={`--delay: ${i * 0.07}s`}>
            <div class="tip-num">{i + 1}</div>
            <div>
              <h3 class="tip-title">{tip.title}</h3>
              <p class="tip-body">{tip.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-14">
      <h2 class="section-heading">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">{faq.q}</summary>
            <p class="faq-answer">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Related Tools CTA -->
    <section class="related-cta">
      <h3 class="related-title">Put This Knowledge to Work</h3>
      <div class="related-links">
        <a href="/tools/rewards-optimizer" class="related-link">
          <span class="related-link-icon">🧮</span>
          <span>Rewards Optimizer</span>
          <span class="related-link-arrow">→</span>
        </a>
        <a href="/finance/calculators/points-transfer" class="related-link">
          <span class="related-link-icon">🔄</span>
          <span>Points Transfer Calculator</span>
          <span class="related-link-arrow">→</span>
        </a>
        <a href="/finance/credit-cards" class="related-link">
          <span class="related-link-icon">💳</span>
          <span>Best Credit Cards</span>
          <span class="related-link-arrow">→</span>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('revealed'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
</script>

<style>
  /* ── Intro ── */
  .intro-block {
    background: var(--color-surface);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 12px 12px 0;
    padding: 20px 24px;
    margin-bottom: 48px;
  }
  html[data-theme='dark'] .intro-block { background: #1a2740; }
  .intro-text { font-size: 1.05rem; line-height: 1.75; color: var(--color-text); }

  /* ── Section Headings ── */
  .section-heading {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 8px;
    color: var(--color-primary);
  }
  html[data-theme='dark'] .section-heading { color: #f1f5f9; }
  .section-subtext { font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 24px; line-height: 1.6; }

  /* ── Transferable Programs Grid ── */
  .program-grid { display: flex; flex-direction: column; gap: 24px; }

  .program-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
  }
  html[data-theme='dark'] .program-card { background: #1a2740; border-color: #2d3f55; }

  .program-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }
  html[data-theme='dark'] .program-header { border-color: #2d3f55; }

  .program-color-bar {
    width: 4px;
    height: 40px;
    border-radius: 4px;
    background: var(--prog-color);
    flex-shrink: 0;
  }
  .program-header-inner { flex: 1; }
  .program-name { font-size: 1.05rem; font-weight: 700; margin-bottom: 2px; }
  .program-issuer { font-size: 0.8rem; color: var(--color-text-muted); }
  .program-value-pill {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }
  .value-pill-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); font-weight: 600; }
  .value-pill-num { font-size: 1.4rem; font-weight: 800; color: var(--color-success); }

  /* ── Value Spectrum ── */
  .value-spectrum {
    padding: 16px 20px 8px;
    position: relative;
  }
  .spectrum-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }
  .spectrum-track {
    position: relative;
    height: 10px;
    background: var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }
  html[data-theme='dark'] .spectrum-track { background: #2d3f55; }
  .spectrum-bar {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    border-radius: 999px;
  }
  .spectrum-bar--max { background: rgba(16,185,129,0.2); }
  .spectrum-bar--portal { background: rgba(14,165,233,0.5); }
  .spectrum-bar--base { background: var(--color-accent); }

  .spectrum-markers {
    position: relative;
    height: 20px;
    margin-top: 4px;
    margin-bottom: 4px;
  }
  .spectrum-marker {
    position: absolute;
    transform: translateX(-50%);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }
  .spectrum-marker--end { transform: translateX(-100%); }

  /* ── Redemption Table ── */
  .redemption-table {
    padding: 0 20px 4px;
  }
  .redemption-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.85rem;
  }
  html[data-theme='dark'] .redemption-row { border-color: #2d3f55; }
  .redemption-row:last-child { border-bottom: none; }
  .redemption-row--best { font-weight: 700; }
  .redemption-method { color: var(--color-text-muted); }
  .redemption-value { font-weight: 700; color: var(--color-text); }

  /* ── Tip Block ── */
  .program-tip {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin: 0 20px 16px;
    padding: 12px 14px;
    background: var(--color-surface);
    border-radius: 10px;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
  html[data-theme='dark'] .program-tip { background: #0f1e30; }
  .tip-icon { font-size: 0.9rem; flex-shrink: 0; margin-top: 1px; }
  .tip-text {}

  /* ── Airline Cards ── */
  .airline-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .airline-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 18px 20px;
  }
  html[data-theme='dark'] .airline-card { background: #1a2740; border-color: #2d3f55; }
  .airline-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
  .airline-name { font-size: 0.9rem; font-weight: 700; }
  .airline-avg { font-size: 1rem; font-weight: 800; color: var(--color-accent); }
  .airline-bar-wrap { height: 6px; background: var(--color-border); border-radius: 999px; overflow: hidden; margin-bottom: 8px; }
  html[data-theme='dark'] .airline-bar-wrap { background: #2d3f55; }
  .airline-bar { height: 100%; background: var(--color-accent); border-radius: 999px; }
  .airline-range { font-size: 0.72rem; color: var(--color-text-muted); margin-bottom: 6px; }
  .airline-tip { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }

  /* ── Hotel Cards ── */
  .hotel-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .hotel-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 18px 20px;
  }
  html[data-theme='dark'] .hotel-card { background: #1a2740; border-color: #2d3f55; }
  .hotel-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
  .hotel-name { font-size: 0.9rem; font-weight: 700; }
  .hotel-avg { font-size: 1rem; font-weight: 800; color: var(--color-warning); }
  .hotel-bar-wrap { height: 6px; background: var(--color-border); border-radius: 999px; overflow: hidden; margin-bottom: 8px; }
  html[data-theme='dark'] .hotel-bar-wrap { background: #2d3f55; }
  .hotel-bar { height: 100%; background: var(--color-warning); border-radius: 999px; }
  .hotel-range { font-size: 0.72rem; color: var(--color-text-muted); margin-bottom: 6px; }
  .hotel-tip { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }

  /* ── Tips Grid ── */
  .tips-grid { display: flex; flex-direction: column; gap: 12px; }
  .tip-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 18px 20px;
  }
  html[data-theme='dark'] .tip-card { background: #1a2740; border-color: #2d3f55; }
  .tip-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .tip-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; }
  .tip-body { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }

  /* ── FAQ ── */
  .faq-list { display: flex; flex-direction: column; gap: 0; }
  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding: 0;
  }
  .faq-item:first-child { border-top: 1px solid var(--color-border); }
  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 4px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    gap: 12px;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  details[open] .faq-question::after { transform: rotate(45deg); }
  .faq-answer {
    font-size: 0.87rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    padding: 0 4px 16px;
  }

  /* ── Related CTA ── */
  .related-cta {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 28px;
  }
  html[data-theme='dark'] .related-cta { background: #1a2740; border-color: #2d3f55; }
  .related-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 16px; }
  .related-links { display: flex; flex-wrap: wrap; gap: 12px; }
  .related-link {
    display: flex;
    align-items: center;
