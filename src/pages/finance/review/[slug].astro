---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProsCons from '../../../components/finance/ProsCons.astro';
import RatingBadge from '../../../components/shared/RatingBadge.astro';
import AdSlot from '../../../components/shared/AdSlot.astro';
import banks from '../../../data/finance/banks.json';
import creditCards from '../../../data/finance/credit-cards.json';
import investing from '../../../data/finance/investing.json';

type ReviewItem = {
  slug: string;
  name: string;
  rating: number;
  pros: string[];
  cons: string[];
  bestFor: string;
  affiliateUrl: string;
  [key: string]: any;
};

export function getStaticPaths() {
  const paths: { params: { slug: string }; props: any }[] = [];

  for (const bank of banks) {
    paths.push({
      params: { slug: bank.slug },
      props: { item: bank as ReviewItem, category: 'banks', categoryLabel: 'Banks', categoryPath: '/finance/banking', fields: [
        { key: 'type', label: 'Bank Type' },
        { key: 'savingsApy', label: 'Savings APY' },
        { key: 'checkingFee', label: 'Monthly Fee' },
        { key: 'minDeposit', label: 'Minimum Deposit' },
        { key: 'atmNetwork', label: 'ATM Network' },
        { key: 'signupBonus', label: 'Sign-Up Bonus' },
      ]}
    });
  }

  for (const card of creditCards) {
    paths.push({
      params: { slug: card.slug },
      props: { item: card as ReviewItem, category: 'credit-cards', categoryLabel: 'Credit Cards', categoryPath: '/finance/credit-cards', fields: [
        { key: 'category', label: 'Card Category' },
        { key: 'annualFee', label: 'Annual Fee' },
        { key: 'apr', label: 'APR' },
        { key: 'signupBonus', label: 'Sign-Up Bonus' },
        { key: 'rewardsRate', label: 'Rewards Rate' },
        { key: 'foreignTransactionFee', label: 'Foreign Transaction Fee' },
      ]}
    });
  }

  for (const platform of investing) {
    paths.push({
      params: { slug: platform.slug },
      props: { item: platform as ReviewItem, category: 'investing', categoryLabel: 'Investing', categoryPath: '/finance/investing', fields: [
        { key: 'type', label: 'Platform Type' },
        { key: 'stockCommission', label: 'Stock Commission' },
        { key: 'optionsPerContract', label: 'Options Fee' },
        { key: 'accountMinimum', label: 'Account Minimum' },
        { key: 'fractionalShares', label: 'Fractional Shares' },
        { key: 'roboFee', label: 'Robo-Advisor Fee' },
      ]}
    });
  }

  return paths;
}

const { item, category, categoryLabel, categoryPath, fields } = Astro.props;
const title = `${item.name} Review 2026: Fees, Features, Pros & Cons`;
const description = `In-depth ${item.name} review for 2026. Is it worth it? We cover fees, features, pros, cons, and who it's best for.`;

const allItems = category === 'banks' ? banks : category === 'credit-cards' ? creditCards : investing;

// Related reviews — top 3 from same category, excluding this one
const related = (allItems as ReviewItem[])
  .filter(x => x.slug !== item.slug)
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 3);

// Authors per category
const authorMap: Record<string, { name: string; title: string; bio: string; initials: string; color: string }> = {
  banks: {
    name: 'Sarah Chen',
    title: 'Banking & Credit Card Editor',
    bio: 'Sarah has 8+ years covering personal finance. She previously wrote for Forbes Advisor and Bankrate, and holds a CFP designation.',
    initials: 'SC',
    color: '#0ea5e9',
  },
  'credit-cards': {
    name: 'Sarah Chen',
    title: 'Banking & Credit Card Editor',
    bio: 'Sarah has 8+ years covering personal finance. She previously wrote for Forbes Advisor and Bankrate, and holds a CFP designation.',
    initials: 'SC',
    color: '#0ea5e9',
  },
  investing: {
    name: 'Marcus Webb',
    title: 'Investing & Markets Editor',
    bio: 'Marcus is a CFA charterholder with 10+ years covering equity markets, ETFs, and retail investing platforms for major financial publications.',
    initials: 'MW',
    color: '#6366f1',
  },
};
const author = authorMap[category];

// Read time: ~250 words on page, adjust by content density
const readMinutes = Math.max(3, Math.min(8, Math.round((item.pros.length + item.cons.length) * 0.4 + 3)));

// Deterministic sub-ratings from slug (consistent across renders)
const slugHash = (s: string, offset: number) => {
  let h = offset * 31;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) & 0xffffffff;
  return Math.abs(h);
};

const breakdownCategories = category === 'banks'
  ? ['Rates & Fees', 'Account Features', 'Digital Banking', 'Customer Service']
  : category === 'credit-cards'
  ? ['Rewards Value', 'Annual Fee', 'Approval Odds', 'Perks & Benefits']
  : ['Ease of Use', 'Investment Options', 'Fees & Costs', 'Research Tools'];

const breakdownScores = breakdownCategories.map((_, i) => {
  const base = item.rating;
  const variance = ((slugHash(item.slug, i + 7) % 21) - 10) / 10; // +/-1.0
  return Math.max(2.5, Math.min(5.0, Math.round((base + variance) * 2) / 2));
});

// FAQ — 5 questions contextual to category
const faqs = category === 'banks' ? [
  {
    q: `Is ${item.name} FDIC insured?`,
    a: `Yes, ${item.name} accounts are FDIC insured up to $250,000 per depositor, per ownership category. Your deposits are protected even if the bank fails.`
  },
  {
    q: `What is ${item.name}'s current savings APY?`,
    a: `${item.name} currently offers ${item.savingsApy || 'competitive rates'} on savings accounts. Rates are variable and subject to change — always check the bank's official site for the latest figures.`
  },
  {
    q: `Does ${item.name} charge monthly fees?`,
    a: `${item.name}'s checking account has a ${item.checkingFee || 'fee structure'} monthly fee. Many fee-waiver options are typically available, such as maintaining a minimum balance or setting up direct deposit.`
  },
  {
    q: `How does ${item.name} compare to other banks?`,
    a: `${item.name} stands out for ${item.bestFor.toLowerCase()}. Compared to the competition, it offers ${item.pros[0].toLowerCase()} and ${item.pros[1] ? item.pros[1].toLowerCase() : 'solid features'}, though ${item.cons[0] ? item.cons[0].toLowerCase() : 'some limitations'} may be a consideration.`
  },
  {
    q: `Is ${item.name} good for beginners?`,
    a: `${item.name} is best suited for ${item.bestFor.toLowerCase()}. If you're new to banking, look at the minimum deposit requirements and account features to determine if it fits your needs.`
  }
] : category === 'credit-cards' ? [
  {
    q: `What credit score do you need for ${item.name}?`,
    a: `${item.name} typically requires good to excellent credit (670+). Your approval odds depend on your full credit profile, income, and existing debt. Check your score before applying.`
  },
  {
    q: `What is the ${item.name} sign-up bonus?`,
    a: `${item.name} currently offers ${item.signupBonus || 'a competitive welcome offer'}. Bonus terms and spending requirements can change, so verify the current offer on the issuer's website before applying.`
  },
  {
    q: `Does ${item.name} have foreign transaction fees?`,
    a: `${item.name} charges ${item.foreignTransactionFee || 'foreign transaction fees as disclosed in the card terms'}. This is important to consider if you travel internationally or shop on foreign websites.`
  },
  {
    q: `How do ${item.name} rewards work?`,
    a: `${item.name} earns ${item.rewardsRate || 'rewards on purchases'}. Points, miles, or cash back can typically be redeemed for statement credits, travel, gift cards, or other options depending on the card network.`
  },
  {
    q: `Is the ${item.name} annual fee worth it?`,
    a: `The ${item.annualFee || 'annual fee'} on ${item.name} can be worth it if you maximize the card's benefits. ${item.pros[0] || 'Key perks'} alone can offset the cost for ${item.bestFor.toLowerCase()}.`
  }
] : [
  {
    q: `Is ${item.name} safe to invest with?`,
    a: `${item.name} is a regulated brokerage. Customer accounts are typically protected by SIPC up to $500,000 ($250,000 for cash). Always verify current regulatory status and SIPC membership before investing.`
  },
  {
    q: `What are ${item.name}'s trading fees?`,
    a: `${item.name} charges ${item.stockCommission || 'commissions as listed in their fee schedule'} for stock trades and ${item.optionsPerContract || 'per-contract fees'} for options. Fee structures can change — confirm on their website.`
  },
  {
    q: `Does ${item.name} offer fractional shares?`,
    a: `${item.name} ${item.fractionalShares === true || item.fractionalShares === 'Yes' ? 'does offer fractional shares, allowing you to invest in high-priced stocks with any dollar amount' : "does not currently offer fractional shares, so you'll need enough to purchase whole shares"}.`
  },
  {
    q: `What is the minimum to open a ${item.name} account?`,
    a: `${item.name} requires ${item.accountMinimum || 'a minimum as listed on their site'} to open an account. This makes it ${item.accountMinimum === '$0' || item.accountMinimum === 'None' ? 'accessible to investors of all levels' : 'best for investors with some capital ready to deploy'}.`
  },
  {
    q: `Is ${item.name} good for beginners?`,
    a: `${item.name} is best for ${item.bestFor.toLowerCase()}. ${item.pros[0] || 'Its features'} make it attractive, though ${item.cons[0] ? item.cons[0].toLowerCase() : 'some aspects'} may require more experience to navigate effectively.`
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": { "@type": "FinancialProduct", "name": item.name },
  "reviewRating": { "@type": "Rating", "ratingValue": item.rating, "bestRating": 5 },
  "author": { "@type": "Person", "name": author.name },
  "publisher": { "@type": "Organization", "name": "Greesi" },
  "datePublished": "2026-01-15",
  "dateModified": "2026-03-20"
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://greesi.com" },
    { "@type": "ListItem", "position": 2, "name": "Finance", "item": "https://greesi.com/finance" },
    { "@type": "ListItem", "position": 3, "name": categoryLabel, "item": `https://greesi.com${categoryPath}` },
    { "@type": "ListItem", "position": 4, "name": `${item.name} Review`, "item": `https://greesi.com/finance/review/${item.slug}` },
  ]
};
const faqSchemaStr = JSON.stringify(faqSchema);
const breadcrumbSchemaStr = JSON.stringify(breadcrumbSchema);
---

<BaseLayout title={title} description={description} schema={schema}>
  <script type="application/ld+json" is:inline set:html={faqSchemaStr} />
  <script type="application/ld+json" is:inline set:html={breadcrumbSchemaStr} />

  <div class="pt-8 pb-16">
    <div class="article-layout">

      <!-- Main content -->
      <article class="article-main">
        <nav class="text-sm text-text-muted mb-6">
          <a href="/" class="hover:text-accent">Home</a>
          <span class="mx-2">/</span>
          <a href="/finance" class="hover:text-accent">Finance</a>
          <span class="mx-2">/</span>
          <a href={categoryPath} class="hover:text-accent">{categoryLabel}</a>
          <span class="mx-2">/</span>
          <span>{item.name} Review</span>
        </nav>

        <div class="flex items-start justify-between mb-4">
          <div>
            <h1 class="text-3xl md:text-4xl font-bold mb-2">{item.name} Review</h1>
            <div class="flex items-center gap-3 text-text-muted text-sm">
              <span class="updated-badge">Updated March 2026</span>
              <span class="read-time">{readMinutes} min read</span>
              <span>By <strong>{author.name}</strong></span>
            </div>
          </div>
          <RatingBadge rating={item.rating} size="lg" />
        </div>

        <!-- Social share bar -->
        <div class="share-bar mb-6">
          <span class="share-label">Share:</span>
          <a
            class="share-btn share-twitter"
            href={`https://twitter.com/intent/tweet?url=https://greesi.com/finance/review/${item.slug}&text=${encodeURIComponent(`${item.name} Review: Is it worth it in 2026? via @greesi`)}`}
            target="_blank" rel="noopener" aria-label="Share on X"
          >
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a
            class="share-btn share-reddit"
            href={`https://reddit.com/submit?url=https://greesi.com/finance/review/${item.slug}&title=${encodeURIComponent(`${item.name} Review 2026`)}`}
            target="_blank" rel="noopener" aria-label="Share on Reddit"
          >
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
            Reddit
          </a>
          <button class="share-btn share-copy" id="share-copy" data-url={`https://greesi.com/finance/review/${item.slug}`} aria-label="Copy link">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy Link
          </button>
        </div>

        <div class="bg-surface rounded-lg p-6 mb-8">
          <p class="font-semibold mb-1">Bottom Line</p>
          <p class="text-text-muted">{item.name} is best for <strong>{item.bestFor.toLowerCase()}</strong>. {item.pros[0]} and {item.pros[1].toLowerCase()} make it stand out, though {item.cons[0].toLowerCase()} is worth considering.</p>
        </div>

        <AdSlot format="horizontal" slot="top-review" />

        <section id="toc-features" class="mb-8">
          <h2 class="text-2xl font-bold mb-4">Key Features</h2>
          <div class="bg-white border border-border rounded-lg overflow-hidden">
            {fields.map((field: {key: string, label: string}, i: number) => (
              <div class={`flex justify-between p-3 ${i % 2 === 0 ? 'bg-surface' : ''}`}>
                <span class="font-medium text-text-muted">{field.label}</span>
                <span class="font-semibold">{typeof item[field.key] === 'boolean' ? (item[field.key] ? 'Yes' : 'No') : item[field.key]}</span>
              </div>
            ))}
          </div>
        </section>

        <section id="toc-ratings" class="mb-8">
          <h2 class="text-2xl font-bold mb-4">Rating Breakdown</h2>
          <div class="breakdown-grid">
            {breakdownCategories.map((label, i) => (
              <div class="breakdown-row">
                <div class="breakdown-label-row">
                  <span class="breakdown-label">{label}</span>
                  <span class="breakdown-score">{breakdownScores[i].toFixed(1)}</span>
                </div>
                <div class="breakdown-track">
                  <div
                    class="breakdown-fill"
                    data-pct={((breakdownScores[i] / 5) * 100).toFixed(1)}
                    style={`--fill-pct: ${((breakdownScores[i] / 5) * 100).toFixed(1)}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section id="toc-pros-cons" class="mb-8">
          <h2 class="text-2xl font-bold mb-4">Pros &amp; Cons</h2>
          <ProsCons pros={item.pros} cons={item.cons} name={item.name} />
        </section>

        <AdSlot format="rectangle" slot="mid-review" />

        {category === 'banks' && item.savingsApy && item.savingsApy !== 'N/A' && (
          <section id="toc-calculator" class="mb-8">
            <h2 class="text-2xl font-bold mb-2">Savings Calculator</h2>
            <p class="text-text-muted mb-4 text-sm">See how much more you'd earn with {item.name} vs. the national average.</p>

            <!-- APY comparison bars -->
            <div class="apy-compare mb-6">
              <div class="apy-bar-row">
                <span class="apy-bar-label">{item.name}</span>
                <div class="apy-bar-track">
                  <div class="apy-bar-fill apy-bar-this" style={`width: ${Math.min(100, parseFloat(item.savingsApy) / 5 * 100)}%`}></div>
                </div>
                <span class="apy-bar-value">{item.savingsApy}</span>
              </div>
              <div class="apy-bar-row">
                <span class="apy-bar-label">National Avg</span>
                <div class="apy-bar-track">
                  <div class="apy-bar-fill apy-bar-avg" style="width: 9.2%"></div>
                </div>
                <span class="apy-bar-value">0.46%</span>
              </div>
              <div class="apy-bar-row">
                <span class="apy-bar-label">Top Online</span>
                <div class="apy-bar-track">
                  <div class="apy-bar-fill apy-bar-top" style="width: 96%"></div>
                </div>
                <span class="apy-bar-value">4.80%</span>
              </div>
            </div>

            <!-- Interactive calculator -->
            <div class="savings-calc-box" id="savings-calc-box" data-apy={parseFloat(item.savingsApy)}>
              <div class="savings-calc-input-row">
                <label for="savings-input" class="savings-calc-label">Your savings balance</label>
                <div class="savings-input-wrap">
                  <span class="savings-dollar">$</span>
                  <input type="number" id="savings-input" class="savings-input" value="10000" min="0" max="10000000" step="1000" />
                </div>
              </div>
              <div class="savings-calc-results" id="savings-results">
                <div class="savings-result-card savings-result-this">
                  <div class="savings-result-bank">{item.name}</div>
                  <div class="savings-result-amount" id="result-this">$0</div>
                  <div class="savings-result-label">earned per year</div>
                </div>
                <div class="savings-result-vs">vs</div>
                <div class="savings-result-card savings-result-avg">
                  <div class="savings-result-bank">National Avg</div>
                  <div class="savings-result-amount" id="result-avg">$0</div>
                  <div class="savings-result-label">earned per year</div>
                </div>
              </div>
              <p class="savings-extra" id="savings-extra"></p>
              <p class="savings-disclaimer">National average savings APY: 0.46% (FDIC, March 2026). For illustrative purposes only.</p>
            </div>
          </section>
        )}

        <section id="toc-best-for" class="mb-8">
          <h2 class="text-2xl font-bold mb-4">Who Is {item.name} Best For?</h2>
          <p class="text-text-muted mb-4">{item.name} is ideal for {item.bestFor.toLowerCase()}. If that describes you, it's one of the strongest options available in 2026.</p>
          <p class="text-text-muted">Key advantages include {item.pros.slice(0, 3).map((p: string) => p.toLowerCase()).join(', ')}. The main drawbacks to be aware of are {item.cons.slice(0, 2).map((c: string) => c.toLowerCase()).join(' and ')}.</p>
        </section>

        <section id="toc-verdict" class="bg-accent/10 border border-accent/30 rounded-lg p-6 mb-8">
          <h2 class="text-2xl font-bold mb-2">Our Verdict: {item.rating}/5</h2>
          <p class="text-text-muted">
            {item.rating >= 4.5 ? `${item.name} earns a top rating from us. It excels in nearly every category and is one of our highest recommendations.` :
             item.rating >= 4.0 ? `${item.name} is a strong option that delivers solid value. While not perfect, it's a great choice for the right user.` :
             `${item.name} is a decent option with clear strengths in specific areas. Consider your priorities carefully before choosing.`}
          </p>
        </section>

        <!-- Apply Now CTA -->
        <div class="apply-cta-box mb-8">
          <div class="apply-cta-left">
            <div class="apply-rating-big">{item.rating.toFixed(1)}<span>/5</span></div>
            <div class="apply-cta-label">Greesi Rating</div>
          </div>
          <div class="apply-cta-center">
            <p class="apply-cta-headline">Ready to get started with {item.name}?</p>
            <p class="apply-cta-sub">Apply securely on {item.name}'s official site. Always read terms before applying.</p>
          </div>
          <div class="apply-cta-right">
            {item.affiliateUrl !== '#' ? (
              <a href={item.affiliateUrl} class="apply-now-btn" target="_blank" rel="noopener sponsored">
                Apply Now →
              </a>
            ) : (
              <span class="apply-coming">Coming Soon</span>
            )}
            <p class="apply-disclaimer">Affiliate link — we may earn a commission</p>
          </div>
        </div>

        <AdSlot format="horizontal" slot="bottom-review" />

        <section id="toc-faq" class="mb-8">
          <h2 class="text-2xl font-bold mb-4">Frequently Asked Questions</h2>
          <div class="faq-list">
            {faqs.map((faq, i) => (
              <div class="faq-item">
                <button class="faq-btn" aria-expanded="false" data-faq={i}>
                  <span>{faq.q}</span>
                  <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </button>
                <div class="faq-answer" id={`faq-${i}`}>
                  <p>{faq.a}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section id="toc-compare" class="border-t border-border pt-8 mb-8">
          <h3 class="text-lg font-semibold mb-4">Compare {item.name}</h3>
          <div class="flex flex-wrap gap-2">
            {(allItems as ReviewItem[])
              .filter((other) => other.slug !== item.slug)
              .slice(0, 5)
              .map((other) => (
                <a href={`/finance/compare/${item.slug}-vs-${other.slug}`} class="text-sm bg-surface hover:bg-surface-alt px-3 py-1.5 rounded-full border border-border transition-colors">
                  vs {other.name}
                </a>
              ))
            }
          </div>
        </section>

        <!-- Helpful vote -->
        <div class="helpful-box" id="helpful-box" data-slug={item.slug}>
          <p class="helpful-question">Was this review helpful?</p>
          <div class="helpful-actions">
            <button class="helpful-btn" id="helpful-yes" aria-label="Yes, helpful">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/><path d="M7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>
              Yes
            </button>
            <button class="helpful-btn helpful-btn-no" id="helpful-no" aria-label="No, not helpful">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17"/></svg>
              No
            </button>
          </div>
          <p class="helpful-count" id="helpful-count"></p>
        </div>

        <!-- Author bio -->
        <div class="author-bio-box">
          <div class="author-avatar" style={`background: ${author.color}22; color: ${author.color}`}>{author.initials}</div>
          <div class="author-bio-body">
            <div class="author-bio-meta">
              <span class="author-bio-name">{author.name}</span>
              <span class="author-bio-title">{author.title}</span>
            </div>
            <p class="author-bio-text">{author.bio}</p>
            <p class="author-bio-disclosure">
              <strong>Editorial note:</strong> Greesi maintains editorial independence. Our reviews are not influenced by advertiser relationships.
              <a href="/methodology" class="text-accent hover:underline">See our methodology →</a>
            </p>
          </div>
        </div>

        <!-- Related reviews -->
        <section class="mt-10">
          <h3 class="text-lg font-semibold mb-4">Related Reviews</h3>
          <div class="related-grid">
            {related.map(r => (
              <a href={`/finance/review/${r.slug}`} class="related-card reveal-item">
                <div class="related-card-top">
                  <span class="related-category">{categoryLabel}</span>
                  <span class="related-rating">{r.rating.toFixed(1)} ★</span>
                </div>
                <p class="related-name">{r.name}</p>
                <p class="related-best">{r.bestFor}</p>
                <span class="related-cta">Read Review →</span>
              </a>
            ))}
          </div>
        </section>
      </article>

      <!-- Sticky ToC sidebar -->
      <aside class="toc-sidebar">
        <p class="toc-heading">On this page</p>
        <a href="#toc-features"  class="toc-link" data-toc="toc-features">Key Features</a>
        <a href="#toc-ratings"   class="toc-link" data-toc="toc-ratings">Ratings</a>
        <a href="#toc-pros-cons" class="toc-link" data-toc="toc-pros-cons">Pros &amp; Cons</a>
        <a href="#toc-best-for"  class="toc-link" data-toc="toc-best-for">Who It's For</a>
        <a href="#toc-verdict"   class="toc-link" data-toc="toc-verdict">Our Verdict</a>
        <a href="#toc-faq"       class="toc-link" data-toc="toc-faq">FAQ</a>
        <a href="#toc-compare"   class="toc-link" data-toc="toc-compare">Compare</a>
      </aside>

    </div>
  </div>

  <!-- Sticky apply button -->
  {item.affiliateUrl !== '#' && (
    <div class="sticky-apply" id="sticky-apply" aria-hidden="true">
      <div class="sticky-apply-inner">
        <div class="sticky-apply-info">
          <span class="sticky-apply-name">{item.name}</span>
          <span class="sticky-apply-rating">★ {item.rating.toFixed(1)}</span>
        </div>
        <a href={item.affiliateUrl} class="sticky-apply-btn" target="_blank" rel="noopener sponsored">
          Apply Now →
        </a>
      </div>
    </div>
  )}
</BaseLayout>

<script>
  // Scroll spy for ToC
  const sections = Array.from(document.querySelectorAll('[id^="toc-"]')) as HTMLElement[];
  const links = Array.from(document.querySelectorAll('.toc-link[data-toc]')) as HTMLElement[];

  if (sections.length && links.length) {
    const spy = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('toc-active'));
            const active = links.find(l => l.dataset.toc === entry.target.id);
            active?.classList.add('toc-active');
          }
        });
      },
      { rootMargin: '-64px 0px -60% 0px', threshold: 0 }
    );
    sections.forEach(s => spy.observe(s));
  }

  // Rating breakdown bar animations
  const fills = Array.from(document.querySelectorAll('.breakdown-fill')) as HTMLElement[];
  const barObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).classList.add('animate');
        barObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  fills.forEach(f => barObs.observe(f));

  // Helpful vote (localStorage)
  const helpfulBox  = document.getElementById('helpful-box') as HTMLElement | null;
  const slug = helpfulBox?.dataset.slug ?? '';
  const countEl = document.getElementById('helpful-count');
  const yesBtn  = document.getElementById('helpful-yes') as HTMLButtonElement | null;
  const noBtn   = document.getElementById('helpful-no')  as HTMLButtonElement | null;
  const voteKey = `greesi-helpful-${slug}`;
  const countKey = `greesi-helpful-count-${slug}`;

  const stored = localStorage.getItem(voteKey);
  let helpfulCount = parseInt(localStorage.getItem(countKey) ?? '0', 10) ||
    // seed a realistic number from slug length
    (slug.length * 7 + 12);

  function renderHelpful() {
    if (!countEl) return;
    if (stored) {
      countEl.textContent = `${helpfulCount} people found this review helpful`;
      yesBtn?.setAttribute('disabled', 'true');
      noBtn?.setAttribute('disabled', 'true');
      if (stored === 'yes') yesBtn?.classList.add('helpful-voted');
      if (stored === 'no')  noBtn?.classList.add('helpful-voted');
    }
  }
  renderHelpful();

  yesBtn?.addEventListener('click', () => {
    if (localStorage.getItem(voteKey)) return;
    helpfulCount++;
    localStorage.setItem(voteKey, 'yes');
    localStorage.setItem(countKey, String(helpfulCount));
    renderHelpful();
  });
  noBtn?.addEventListener('click', () => {
    if (localStorage.getItem(voteKey)) return;
    localStorage.setItem(voteKey, 'no');
    renderHelpful();
  });

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        const ans = b.closest('.faq-item')?.querySelector('.faq-answer') as HTMLElement | null;
        if (ans) ans.style.maxHeight = '';
      });
      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        const answer = btn.closest('.faq-item')?.querySelector('.faq-answer') as HTMLElement | null;
        if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });

  // Sticky apply button — show after scrolling 400px
  const stickyApply = document.getElementById('sticky-apply');
  if (stickyApply) {
    window.addEventListener('scroll', () => {
      const show = window.scrollY > 400;
      stickyApply.setAttribute('aria-hidden', String(!show));
    }, { passive: true });
  }

  // Copy link share button
  const copyBtn = document.getElementById('share-copy') as HTMLButtonElement | null;
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.dataset.url ?? window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      const prev = copyBtn.textContent;
      copyBtn.textContent = '✓ Copied!';
      setTimeout(() => { copyBtn.textContent = prev; }, 2000);
    } catch {
      // fallback for older browsers
      const ta = document.createElement('textarea');
      ta.value = url;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      copyBtn.textContent = '✓ Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy Link'; }, 2000);
    }
  });

  // Savings calculator
  const savingsInput = document.getElementById('savings-input') as HTMLInputElement | null;
  const resultThis   = document.getElementById('result-this');
  const resultAvg    = document.getElementById('result-avg');
  const savingsExtra = document.getElementById('savings-extra');

  function calcSavings() {
    if (!savingsInput || !resultThis || !resultAvg) return;
    const balance  = parseFloat(savingsInput.value) || 0;
    const calcBox  = document.getElementById('savings-calc-box');
    const apyPct   = parseFloat(calcBox?.dataset.apy ?? '0');
    const natAvg   = 0.0046;
    const thisEarned = balance * (apyPct / 100);
    const avgEarned  = balance * natAvg;
    const fmt = (n: number) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    resultThis.textContent = fmt(thisEarned);
    resultAvg.textContent  = fmt(avgEarned);
    if (savingsExtra) {
      const diff = thisEarned - avgEarned;
      const bankName = document.querySelector('.savings-result-this .savings-result-bank')?.textContent ?? 'this bank';
      savingsExtra.textContent = diff > 0
        ? `You'd earn ${fmt(diff)} more per year at ${bankName} vs. the national average.`
        : '';
      savingsExtra.className = diff > 0 ? 'savings-extra savings-extra-positive' : 'savings-extra';
    }
  }

  if (savingsInput) {
    savingsInput.addEventListener('input', calcSavings);
    calcSavings();
  }
</script>
