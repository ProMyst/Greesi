---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RatingBadge from '../../../components/shared/RatingBadge.astro';
import AdSlot from '../../../components/shared/AdSlot.astro';
import banks from '../../../data/finance/banks.json';

const sorted = [...banks].sort((a, b) => b.rating - a.rating);
const title = "Best Banks 2026: Compare Savings, Checking & Fees";
const description = "Compare the best banks of 2026 side by side. See APY rates, fees, features, and our expert ratings to find the perfect bank for your needs.";
---

<BaseLayout title={title} description={description}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="text-sm text-text-muted mb-6">
      <a href="/" class="hover:text-accent">Home</a>
      <span class="mx-2">/</span>
      <a href="/finance" class="hover:text-accent">Finance</a>
      <span class="mx-2">/</span>
      <span>Best Banks</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-bold mb-4">Best Banks of 2026</h1>
    <p class="text-lg text-text-muted mb-8">We've analyzed fees, APY rates, features, and customer experience to rank the best banks available today.</p>

    <AdSlot format="horizontal" slot="top-banking" />

    <div class="space-y-4 mb-8">
      {sorted.map((bank, i) => (
        <div class="bg-white border border-border rounded-lg p-5 hover:shadow-md transition-shadow">
          <div class="flex flex-col md:flex-row md:items-center gap-4">
            <div class="flex items-center gap-3 md:w-8">
              <span class="text-2xl font-bold text-text-muted">#{i + 1}</span>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <a href={`/finance/review/${bank.slug}`} class="text-xl font-semibold hover:text-accent transition-colors">{bank.name}</a>
                <RatingBadge rating={bank.rating} size="sm" />
                <span class="text-xs bg-surface px-2 py-0.5 rounded">{bank.type}</span>
              </div>
              <p class="text-sm text-text-muted mb-3">{bank.bestFor}</p>
              <div class="flex flex-wrap gap-4 text-sm">
                <span><strong class="text-accent">{bank.savingsApy}</strong> Savings APY</span>
                <span><strong>{bank.checkingFee}</strong> Checking Fee</span>
                <span><strong>{bank.atmNetwork}</strong></span>
                {bank.signupBonus !== "None" && <span class="text-success font-medium">{bank.signupBonus} Bonus</span>}
              </div>
            </div>
            <div class="flex flex-col gap-2 md:w-40">
              <a href={`/finance/review/${bank.slug}`} class="text-center bg-accent hover:bg-accent-dark text-white text-sm font-semibold py-2 px-4 rounded-lg transition-colors">Read Review</a>
              <a href={`/finance/compare/${bank.slug}-vs-${sorted[0].slug === bank.slug ? sorted[1].slug : sorted[0].slug}`} class="text-center border border-border hover:bg-surface text-sm py-2 px-4 rounded-lg transition-colors">Compare</a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <AdSlot format="horizontal" slot="bottom-banking" />

    <section class="prose max-w-none">
      <h2 class="text-2xl font-bold mb-4">How We Rank Banks</h2>
      <p class="text-text-muted mb-4">Our bank rankings are based on a comprehensive analysis of savings APY, fee structure, ATM accessibility, mobile banking experience, customer service quality, and account features. We update our rankings regularly to reflect the latest rates and policy changes.</p>

      <h2 class="text-2xl font-bold mb-4">Online Banks vs Traditional Banks</h2>
      <p class="text-text-muted mb-4">Online banks typically offer significantly higher savings APY (3-5%) compared to traditional banks (0.01-0.05%) because they have lower overhead costs. However, traditional banks provide physical branches and wider ATM networks. Your best choice depends on whether you prioritize higher returns or in-person access.</p>
    </section>
  </div>
</BaseLayout>
