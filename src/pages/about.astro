---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About Greesi | Independent Finance Advice You Can Actually Trust";
const description = "Greesi was built because personal finance advice was broken. Learn about our mission, our story, and the team behind unbiased financial guidance for everyday people.";

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://greesi.com" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://greesi.com/about" }
  ]
};

const team = [
  {
    initials: 'SC',
    color: '#0ea5e9',
    name: 'Sarah Chen',
    title: 'Banking & Credit Card Editor',
    bio: 'CFP with 8+ years covering personal finance. Previously at Forbes Advisor and Bankrate, Sarah has reviewed hundreds of credit cards and savings accounts. She believes the right card can genuinely change your financial trajectory.',
  },
  {
    initials: 'MW',
    color: '#6366f1',
    name: 'Marcus Webb',
    title: 'Investing & Markets Editor',
    bio: 'CFA charterholder with 10+ years covering equity markets, ETFs, and brokerage platforms. Marcus cuts through the noise on investing so you can build wealth without paying for advice you don\'t need.',
  },
  {
    initials: 'JM',
    color: '#10b981',
    name: 'Jordan Miles',
    title: 'Travel Editor',
    bio: '45+ countries, former contributor to The Points Guy. Jordan has booked premium-cabin flights for pennies on the dollar and turns points strategies into real itineraries real people can follow.',
  },
  {
    initials: 'AR',
    color: '#f59e0b',
    name: 'Alex Rivera',
    title: 'Data & Research Analyst',
    bio: 'MS in Economics. Alex builds the comparison models that power our rate tables and keeps every fee, APY, and bonus figure accurate and current. If a number is on Greesi, Alex has verified it.',
  },
];

const values = [
  {
    icon: '🛡️',
    name: 'Independence',
    desc: 'We are never paid to recommend a product. Rankings and reviews reflect our honest analysis — full stop.',
  },
  {
    icon: '✅',
    name: 'Accuracy',
    desc: 'Every rate, fee, and bonus is verified against issuer sources before publishing. We update continuously.',
  },
  {
    icon: '🔍',
    name: 'Transparency',
    desc: 'All affiliate relationships are disclosed clearly. You always know when a link may earn us a commission.',
  },
  {
    icon: '💡',
    name: 'Accessibility',
    desc: 'Finance is complicated. We write for real people, not MBAs. No jargon, no condescension.',
  },
];

const stats = [
  { count: 30, suffix: '+', label: 'Products Reviewed' },
  { count: 100, suffix: '%', label: 'Editorially Independent' },
  { count: 10, suffix: '', label: 'Travel Destinations Covered' },
  { count: 0, suffix: '', label: 'Paid Placements' },
];
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-primary text-white py-20 has-noise">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-4">About Greesi</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-5 leading-tight">We're on Your Side.</h1>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto">
        Greesi was built because personal finance advice was broken. Too many recommendations were driven by commissions, not by what's actually best for you.
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="max-w-4xl mx-auto px-4 pt-6">
    <nav class="text-sm text-text-muted">
      <a href="/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span>About</span>
    </nav>
  </div>

  <!-- Our Mission -->
  <section class="max-w-3xl mx-auto px-4 py-14">
    <h2 class="section-heading">Our Mission</h2>
    <div class="prose-content">
      <p>
        Greesi exists to give everyday people the same quality of financial guidance that used to be reserved for those who could afford a private advisor. We research, rate, and explain financial products — credit cards, bank accounts, investing platforms — so you can make decisions with confidence instead of confusion.
      </p>
      <p>
        We earn money through clearly disclosed affiliate partnerships. When you sign up for a product through our links, we may receive a commission. But that arrangement never influences our rankings or what we write. Products are ranked by the data: rewards rates, fees, sign-up bonuses, and real-world usability. Not by who pays us the most.
      </p>
      <p>
        The vision is bigger than a comparison site. We want to help everyday people make smarter money moves and travel farther on less — using the tools the financial system already offers, once you know where to look.
      </p>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Our Story -->
  <section class="max-w-3xl mx-auto px-4 py-14">
    <h2 class="section-heading">Our Story</h2>
    <div class="prose-content">
      <p>
        Our founder spent years following mainstream financial advice — the kind you find on big-name sites that happen to earn massive referral fees. The recommended cards were fine. But they weren't the <em>best</em> options for the actual spending habits involved. The best options were buried in listicles optimized for affiliate revenue, not reader outcomes.
      </p>
      <p>
        The moment it clicked was booking a trip to Southeast Asia. After doing the real research — not relying on sponsored "best of" lists — the right card combination turned out to cover over $800 in travel costs through sign-up bonuses alone. The information was out there. It just wasn't presented honestly.
      </p>
      <p>
        That frustration became Greesi. A place where the math is shown, the conflicts of interest are disclosed, and the goal is simple: help you use your money to live better. More financial freedom. More of the world explored. Less left on the table because the advice you got served someone else's interests.
      </p>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Meet the Team -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <h2 class="section-heading text-center">Meet the Team</h2>
    <p class="text-text-muted text-center mb-10 max-w-xl mx-auto">Editors and analysts with real credentials and zero financial product relationships that could compromise what they write.</p>
    <div class="team-grid">
      {team.map((member) => (
        <div class="team-card">
          <div class="team-avatar" style={`background: ${member.color}22; color: ${member.color}; border: 2px solid ${member.color}44`}>
            {member.initials}
          </div>
          <div class="team-info">
            <h3 class="team-name">{member.name}</h3>
            <p class="team-title">{member.title}</p>
            <p class="team-bio">{member.bio}</p>
            <div class="team-social">
              <a href="#" aria-label={`${member.name} on LinkedIn`} class="social-link">in</a>
              <a href="#" aria-label={`${member.name} on X`} class="social-link">𝕏</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Our Values -->
  <section class="bg-surface py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="section-heading text-center">Our Values</h2>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card">
            <span class="value-icon">{v.icon}</span>
            <h3 class="value-name">{v.name}</h3>
            <p class="value-desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- By the Numbers -->
  <section class="max-w-5xl mx-auto px-4 py-14">
    <h2 class="section-heading text-center">By the Numbers</h2>
    <div class="stats-grid">
      {stats.map((s) => (
        <div class="stat-block">
          <div class="stat-number">
            <span class="count-up" data-count={s.count}>0</span>{s.suffix}
          </div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- Press / Contact CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-3">Press & Media</p>
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Working on a story?<br />We'd love to talk.</h2>
      <p class="text-text-muted mb-7 leading-relaxed">
        Journalists and researchers are welcome to reach out for data, quotes, or background on consumer finance topics. We respond to all press inquiries within 24 hours.
      </p>
      <a href="mailto:press@greesi.com" class="press-btn">
        Email press@greesi.com →
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  // Count-up animation
  const counters = document.querySelectorAll('.count-up');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.count || '0', 10);
      const duration = 1200;
      const start = performance.now();
      const animate = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target).toString();
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
      observer.unobserve(el);
    });
  }, { threshold: 0.4 });
  counters.forEach(c => observer.observe(c));
</script>

<style>
  /* ---- Typography helpers ---- */
  .section-heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }
  .section-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    max-width: 64rem;
    margin: 0 auto;
  }
  .prose-content {
    color: var(--color-text-muted);
    line-height: 1.75;
  }
  .prose-content p {
    margin-bottom: 1.25rem;
  }
  .prose-content p:last-child { margin-bottom: 0; }
  .prose-content em { font-style: italic; color: var(--color-text); }

  /* ---- Team ---- */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
  .team-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    gap: 18px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  html[data-theme='dark'] .team-card { background: var(--color-surface); }
  .team-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.09); transform: translateY(-2px); }

  .team-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .team-info { flex: 1; }
  .team-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .team-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .team-bio {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 10px;
  }
  .team-social { display: flex; gap: 8px; }
  .social-link {
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .social-link:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ---- Values ---- */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    margin-top: 0.5rem;
  }
  .value-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 24px 20px;
    text-align: center;
    transition: box-shadow 0.2s;
  }
  html[data-theme='dark'] .value-card { background: #fff1; }
  .value-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
  .value-icon { font-size: 2rem; display: block; margin-bottom: 12px; }
  .value-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .value-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ---- Stats ---- */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
  }
  .stat-block {
    text-align: center;
    padding: 28px 16px;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: #fff;
  }
  html[data-theme='dark'] .stat-block { background: var(--color-surface); }
  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 8px;
  }
  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---- Press CTA ---- */
  .press-btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .press-btn:hover { opacity: 0.9; transform: translateY(-1px); }
</style>
