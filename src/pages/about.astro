---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About Cornerstone Financial";
const description = "Learn about Cornerstone Financial's mission to provide unbiased financial product comparisons and free tools to help you make smarter money decisions.";
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-6">About Cornerstone Financial</h1>

    <div class="prose max-w-none text-text-muted space-y-4">
      <p>Cornerstone Financial is an independent financial comparison platform dedicated to helping consumers make informed decisions about banking, credit cards, and investing.</p>

      <h2 class="text-xl font-semibold text-text mt-8 mb-3">Our Mission</h2>
      <p>We believe everyone deserves access to clear, unbiased financial information. Our goal is to simplify complex financial products so you can confidently choose the right bank, credit card, or investment platform for your needs.</p>

      <h2 class="text-xl font-semibold text-text mt-8 mb-3">How We Make Money</h2>
      <p>Cornerstone Financial earns revenue through affiliate partnerships and display advertising. When you click on certain links and sign up for financial products, we may receive compensation from the provider. This never affects our rankings or reviews — our editorial content is always independent and based on objective analysis.</p>

      <h2 class="text-xl font-semibold text-text mt-8 mb-3">Our Review Process</h2>
      <p>Every product we review is evaluated on multiple factors including fees, features, user experience, customer service, and overall value. We regularly update our reviews and rankings to reflect the latest rates, terms, and product changes.</p>

      <h2 class="text-xl font-semibold text-text mt-8 mb-3">Contact Us</h2>
      <p>Have a question or suggestion? We'd love to hear from you. Reach out at <strong>contact@cornerstonens.com</strong>.</p>
    </div>
  </div>
</BaseLayout>
