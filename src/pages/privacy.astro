---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Privacy Policy | Folvr";
const description = "Folvr privacy policy. Learn how we collect, use, and protect your information when you use folvr.com.";
---

<BaseLayout title={title} description={description}>
  <div class="policy-root">
    <div class="policy-container">

      <!-- Header -->
      <div class="policy-header">
        <span class="section-eyebrow">Legal</span>
        <h1 class="policy-title">Privacy Policy</h1>
        <p class="policy-date">Last updated: March 24, 2026</p>
      </div>

      <!-- Intro -->
      <p class="policy-intro">
        Folvr ("we", "us", or "our") operates <strong>folvr.com</strong>. This Privacy Policy explains how we collect,
        use, and protect information when you visit our site. By using Folvr, you agree to the practices described below.
      </p>

      <!-- Sections -->
      <div class="policy-body">

        <section class="policy-section">
          <h2>1. Information We Collect</h2>
          <h3>Information you provide</h3>
          <p>We do not require account creation or registration. If you contact us via email, we collect your name and email address solely to respond to your inquiry.</p>
          <h3>Information collected automatically</h3>
          <p>When you visit Folvr, we and our third-party partners may automatically collect:</p>
          <ul>
            <li>IP address and approximate location (country/region)</li>
            <li>Browser type, device type, and operating system</li>
            <li>Pages visited, time spent on pages, and referring URL</li>
            <li>Clicks on links, including affiliate and advertiser links</li>
          </ul>
          <p>This information is used in aggregate to understand how visitors use our site and to improve our content.</p>
        </section>

        <section class="policy-section">
          <h2>2. Cookies and Tracking Technologies</h2>
          <p>We use cookies and similar technologies (pixels, web beacons) for the following purposes:</p>
          <ul>
            <li><strong>Analytics:</strong> We use Google Analytics or similar tools to understand site traffic patterns. Data is aggregated and anonymized.</li>
            <li><strong>Advertising:</strong> We use Google AdSense, which places cookies to serve relevant ads based on your interests. Google's use of advertising cookies enables it and its partners to serve ads based on your visit to our site and/or other sites on the internet.</li>
            <li><strong>Affiliate tracking:</strong> When you click an affiliate link, the merchant may set a cookie to track referrals for commission purposes.</li>
          </ul>
          <p>You can control or disable cookies through your browser settings. Note that disabling cookies may affect your browsing experience. You may also opt out of personalized Google advertising at <strong>google.com/settings/ads</strong>.</p>
        </section>

        <section class="policy-section">
          <h2>3. Affiliate Disclosure</h2>
          <p>
            Folvr participates in affiliate marketing programs. This means we may earn a commission when you click on certain links
            and complete a purchase or application — at no additional cost to you. Affiliate relationships never influence our editorial
            ratings, rankings, or reviews. We only recommend products we believe provide genuine value.
          </p>
          <p>All affiliate relationships are clearly disclosed on relevant pages and in our site-wide footer.</p>
        </section>

        <section class="policy-section">
          <h2>4. How We Use Your Information</h2>
          <p>We use the information we collect to:</p>
          <ul>
            <li>Operate and improve the Folvr website and its content</li>
            <li>Analyze traffic patterns and understand reader interests</li>
            <li>Serve relevant advertisements through third-party ad networks</li>
            <li>Respond to inquiries you send us directly</li>
            <li>Comply with applicable laws and regulations</li>
          </ul>
          <p>We do not sell your personal information to third parties.</p>
        </section>

        <section class="policy-section">
          <h2>5. Third-Party Links and Services</h2>
          <p>
            Folvr contains links to external websites including banks, credit card issuers, brokerages, and travel providers.
            We are not responsible for the privacy practices or content of these third-party sites. We encourage you to review
            their privacy policies before submitting any personal information.
          </p>
          <p>Third-party services used on this site may include:</p>
          <ul>
            <li>Google Analytics (analytics)</li>
            <li>Google AdSense (advertising)</li>
            <li>Vercel (hosting and performance)</li>
          </ul>
        </section>

        <section class="policy-section">
          <h2>6. Data Retention and Security</h2>
          <p>
            We retain contact information only as long as necessary to respond to your inquiry. Analytics data is retained
            per the default settings of each analytics provider.
          </p>
          <p>
            We implement reasonable technical and organizational measures to protect your information. However, no method
            of transmission over the internet is completely secure, and we cannot guarantee absolute security.
          </p>
        </section>

        <section class="policy-section">
          <h2>7. Children's Privacy</h2>
          <p>
            Folvr is not directed at children under 13 years of age. We do not knowingly collect personal information
            from children. If you believe a child has provided us with personal information, please contact us and
            we will delete it promptly.
          </p>
        </section>

        <section class="policy-section">
          <h2>8. Your Rights</h2>
          <p>Depending on your location, you may have the right to:</p>
          <ul>
            <li>Access the personal data we hold about you</li>
            <li>Request correction or deletion of your data</li>
            <li>Opt out of targeted advertising</li>
            <li>Lodge a complaint with a data protection authority</li>
          </ul>
          <p>To exercise any of these rights, contact us at the address below.</p>
        </section>

        <section class="policy-section">
          <h2>9. Changes to This Policy</h2>
          <p>
            We may update this Privacy Policy from time to time. When we do, we will revise the "Last updated" date at
            the top of this page. We encourage you to review this policy periodically. Continued use of Folvr after
            changes are posted constitutes your acceptance of the updated policy.
          </p>
        </section>

        <section class="policy-section">
          <h2>10. Contact Us</h2>
          <p>For privacy-related questions or requests, please contact us at:</p>
          <div class="policy-contact">
            <strong>Folvr</strong><br />
            <a href="mailto:privacy@folvr.com">privacy@folvr.com</a>
          </div>
        </section>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
.policy-root {
  background: white;
  padding: 80px 0 100px;
}
.policy-container {
  max-width: 720px;
  margin: 0 auto;
  padding: 0 24px;
}
.policy-header {
  margin-bottom: 36px;
  padding-bottom: 32px;
  border-bottom: 1px solid var(--color-border);
}
.policy-title {
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  color: var(--color-text);
  margin: 8px 0 10px;
}
.policy-date {
  font-size: 0.85rem;
  color: var(--color-text-muted);
}
.policy-intro {
  font-size: 1.05rem;
  line-height: 1.75;
  color: var(--color-text-muted);
  margin-bottom: 48px;
}
.policy-body {
  display: flex;
  flex-direction: column;
  gap: 40px;
}
.policy-section h2 {
  font-size: 1.15rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--color-primary);
  margin: 0 0 14px;
}
.policy-section h3 {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 18px 0 6px;
}
.policy-section p {
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--color-text-muted);
  margin-bottom: 12px;
}
.policy-section ul {
  padding-left: 20px;
  margin-bottom: 12px;
}
.policy-section li {
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--color-text-muted);
  margin-bottom: 4px;
}
.policy-contact {
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--color-text-muted);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  padding: 16px 20px;
  margin-top: 8px;
}
.policy-contact a {
  color: var(--color-accent);
  text-decoration: none;
}
.policy-contact a:hover { text-decoration: underline; }
</style>
