---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Trend Detection — Greesi";
const description = "Social and search trend signals — Reddit momentum, Google Trends velocity, and emerging topic detection before they go mainstream.";

const trendSignals = [
  { topic: 'High-yield savings accounts', platform: 'Reddit', spike: '+340%', sector: 'Finance', momentum: 'rising', timeframe: '7d' },
  { topic: 'Bitcoin ETF flows', platform: 'Google Trends', spike: '+210%', sector: 'Crypto', momentum: 'rising', timeframe: '24h' },
  { topic: 'Fed rate cut odds', platform: 'Reddit + X', spike: '+180%', sector: 'Macro', momentum: 'rising', timeframe: '3d' },
  { topic: 'Wealthfront vs Marcus', platform: 'Google Trends', spike: '+95%', sector: 'Finance', momentum: 'stable', timeframe: '7d' },
  { topic: 'Solana DeFi volume', platform: 'Reddit', spike: '+420%', sector: 'Crypto', momentum: 'rising', timeframe: '24h' },
  { topic: 'Inflation hedge assets', platform: 'Google Trends', spike: '+130%', sector: 'Macro', momentum: 'rising', timeframe: '14d' },
];

const sectorColors: Record<string, string> = {
  Finance: '#58A6FF',
  Crypto:  '#F7931A',
  Macro:   '#D29922',
};
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="tr-hero">
    <div class="tr-glow tr-glow-1" aria-hidden="true"></div>
    <div class="tr-glow tr-glow-2" aria-hidden="true"></div>
    <div class="tr-hero-inner">
      <div class="tr-eyebrow reveal-item">
        <span class="tr-dot"></span>
        Trend Detection
      </div>
      <h1 class="tr-headline reveal-item">Catch the wave<br/>before it breaks.</h1>
      <p class="tr-sub reveal-item">
        Social velocity, search momentum, and behavioral signals from Reddit, Google Trends,
        and X — surfaced days before they move markets.
      </p>
      <div class="tr-hero-actions reveal-item">
        <a href="/waitlist?interest=trends" class="tr-btn-primary">Join the Waitlist</a>
        <a href="#feed" class="tr-btn-ghost">See sample signals →</a>
      </div>
    </div>
  </section>

  <!-- Sample Trend Feed -->
  <section class="tr-feed" id="feed">
    <div class="tr-feed-inner">
      <div class="tr-section-label reveal-item">Sample Signal Feed · Live pipeline in beta</div>
      <h2 class="tr-section-headline reveal-item">What's gaining momentum right now.</h2>
      <div class="tr-feed-list">
        {trendSignals.map((t, i) => (
          <div class="tr-feed-item reveal-item" style={`--delay:${i * 0.05}s`}>
            <div class="tr-feed-left">
              <span class="tr-feed-num">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="tr-feed-body">
              <div class="tr-feed-meta">
                <span class="tr-feed-platform">{t.platform}</span>
                <span class="tr-feed-sector" style={`color:${sectorColors[t.sector] ?? '#8B949E'}`}>{t.sector}</span>
                <span class="tr-feed-timeframe">{t.timeframe}</span>
              </div>
              <p class="tr-feed-topic">{t.topic}</p>
            </div>
            <div class="tr-feed-right">
              <span class={`tr-feed-spike ${t.momentum}`}>{t.spike}</span>
              <span class="tr-feed-label">volume spike</span>
            </div>
          </div>
        ))}
      </div>
      <p class="tr-feed-note reveal-item">
        Sample data shown. Live pipeline activates with early access.
        <a href="/waitlist?interest=trends">Get notified →</a>
      </p>
    </div>
  </section>

  <!-- What's coming -->
  <section class="tr-coming">
    <div class="tr-coming-inner">
      <div class="tr-section-label reveal-item">Pipeline Roadmap</div>
      <h2 class="tr-section-headline reveal-item">The full trend intelligence stack.</h2>
      <div class="tr-coming-grid">
        {[
          { title: 'Reddit Momentum Tracker', desc: 'Subreddit mention velocity across r/investing, r/personalfinance, r/CryptoCurrency and 40+ financial communities.', status: 'In development' },
          { title: 'Google Trends Velocity', desc: 'Search volume spike detection with 15-minute granularity. Identify emerging queries before they peak.', status: 'In development' },
          { title: 'Narrative Detection Engine', desc: 'NLP-driven topic clustering across platforms. Detect coordinated narrative shifts before price discovery.', status: 'Planned' },
          { title: 'Cross-Platform Correlation', desc: 'When Reddit, Google, and X all spike on the same topic — that\'s the high-conviction signal. Automated alerts coming.', status: 'Planned' },
        ].map(item => (
          <div class="tr-coming-card reveal-item">
            <div class="tr-coming-status">{item.status}</div>
            <h3 class="tr-coming-title">{item.title}</h3>
            <p class="tr-coming-desc">{item.desc}</p>
          </div>
        ))}
      </div>
      <a href="/waitlist?interest=trends" class="tr-btn-primary reveal-item" style="margin-top:40px;display:inline-flex">
        Get notified at launch →
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  :root {
    --tr-bg: #080B0F; --tr-surface: #0D1117; --tr-border: #21262D;
    --tr-text: #F0F6FC; --tr-muted: #8B949E;
    --tr-green: #39D353; --tr-amber: #D29922; --tr-blue: #58A6FF; --tr-accent: #1F6FEB;
  }
  .tr-hero {
    background: var(--tr-bg); padding: 120px 24px 80px;
    position: relative; overflow: hidden; min-height: 60vh;
    display: flex; align-items: center;
  }
  .tr-glow { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(90px); opacity: 0.13; }
  .tr-glow-1 { width: 500px; height: 500px; top: -100px; right: 10%; background: radial-gradient(circle, #6366f1 0%, transparent 70%); animation: tgf1 11s ease-in-out infinite; }
  .tr-glow-2 { width: 350px; height: 350px; bottom: -80px; left: 5%; background: radial-gradient(circle, #1F6FEB 0%, transparent 70%); animation: tgf2 14s ease-in-out infinite; }
  @keyframes tgf1 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(-30px,25px);} }
  @keyframes tgf2 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(20px,-30px);} }
  .tr-hero-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }
  .tr-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--tr-muted); margin-bottom: 24px; }
  .tr-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--tr-blue); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:0.4;transform:scale(0.8);} }
  .tr-headline { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 400; letter-spacing: -0.02em; line-height: 1.05; color: var(--tr-text); margin-bottom: 24px; }
  .tr-sub { font-size: 1rem; color: var(--tr-muted); line-height: 1.75; max-width: 540px; margin-bottom: 36px; }
  .tr-hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .tr-btn-primary { background: var(--tr-accent); color: #fff; font-size: 0.875rem; font-weight: 600; padding: 12px 24px; border-radius: 8px; border: none; cursor: pointer; font-family: inherit; transition: background 0.2s, transform 0.15s, box-shadow 0.2s; box-shadow: 0 0 0 1px rgba(31,111,235,0.4); }
  .tr-btn-primary:hover { background: #388bfd; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(31,111,235,0.3); }
  .tr-btn-ghost { font-size: 0.875rem; font-weight: 500; color: var(--tr-muted); padding: 12px 18px; border-radius: 8px; border: 1px solid var(--tr-border); transition: color 0.2s, border-color 0.2s; }
  .tr-btn-ghost:hover { color: var(--tr-text); border-color: #30363D; }

  .tr-feed { background: var(--tr-surface); border-top: 1px solid var(--tr-border); padding: 96px 24px; }
  .tr-feed-inner { max-width: 860px; margin: 0 auto; }
  .tr-section-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--tr-muted); margin-bottom: 12px; }
  .tr-section-headline { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 400; letter-spacing: -0.02em; color: var(--tr-text); margin-bottom: 40px; }
  .tr-feed-list { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--tr-border); border-radius: 12px; overflow: hidden; }
  .tr-feed-item { display: flex; align-items: center; gap: 20px; padding: 18px 24px; border-bottom: 1px solid var(--tr-border); background: var(--tr-bg); transition: background 0.15s; }
  .tr-feed-item:last-child { border-bottom: none; }
  .tr-feed-item:hover { background: #0D1117; }
  .tr-feed-left { flex-shrink: 0; }
  .tr-feed-num { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--tr-muted); font-weight: 500; }
  .tr-feed-body { flex: 1; min-width: 0; }
  .tr-feed-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
  .tr-feed-platform { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--tr-muted); background: rgba(255,255,255,0.05); padding: 2px 7px; border-radius: 4px; }
  .tr-feed-sector { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .tr-feed-timeframe { font-size: 0.65rem; color: var(--tr-muted); font-family: 'JetBrains Mono', monospace; margin-left: auto; }
  .tr-feed-topic { font-size: 0.9rem; font-weight: 500; color: var(--tr-text); }
  .tr-feed-right { flex-shrink: 0; text-align: right; }
  .tr-feed-spike { display: block; font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 600; }
  .tr-feed-spike.rising { color: var(--tr-green); }
  .tr-feed-spike.stable { color: var(--tr-amber); }
  .tr-feed-label { font-size: 0.65rem; color: var(--tr-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .tr-feed-note { font-size: 0.78rem; color: var(--tr-muted); margin-top: 24px; }
  .tr-feed-note a { color: var(--tr-blue); }

  .tr-coming { background: var(--tr-bg); border-top: 1px solid var(--tr-border); padding: 96px 24px; }
  .tr-coming-inner { max-width: 1080px; margin: 0 auto; }
  .tr-coming-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; margin-top: 40px; }
  .tr-coming-card { background: var(--tr-surface); border: 1px solid var(--tr-border); border-radius: 12px; padding: 28px 24px; transition: border-color 0.2s; }
  .tr-coming-card:hover { border-color: #30363D; }
  .tr-coming-status { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--tr-amber); margin-bottom: 12px; }
  .tr-coming-title { font-size: 0.9rem; font-weight: 600; color: var(--tr-text); margin-bottom: 10px; }
  .tr-coming-desc { font-size: 0.82rem; color: var(--tr-muted); line-height: 1.6; }
</style>

<script>
  import { animate, stagger } from 'animejs';
  animate('.tr-eyebrow, .tr-headline, .tr-sub, .tr-hero-actions', {
    opacity: [0, 1], translateY: [28, 0], scale: [0.97, 1],
    duration: 700, ease: 'out(3)', delay: stagger(90, { start: 150 }),
  });
</script>
