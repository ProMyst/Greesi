---
export const prerender = false;
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Pipeline — Greesi";
const description = "Live trading operations dashboard.";
---

<BaseLayout title={title} description={description}>
<div class="d">

  <!-- Dual Screen Layout -->
  <div class="d-split">

    <!-- LEFT PANEL — Trading -->
    <div class="d-panel d-left">
      <div class="d-panel-head">
        <span class="d-panel-label">TRADING</span>
        <div class="d-live"><span class="d-live-dot"></span>LIVE</div>
      </div>

      <div class="d-panel-scroll" id="left-panel">
        <!-- Total P&L -->
        <div class="d-hero-row" id="pnl-hero">
          <div class="d-hero-block">
            <span class="d-hero-label">TOTAL P&L</span>
            <span class="d-hero-val" id="total-pnl">--</span>
          </div>
        </div>

        <!-- Bot cards -->
        <div id="bots-area"></div>

        <!-- Recent trades -->
        <div class="d-sub-label" style="margin-top:32px">RECENT TRADES</div>
        <div class="d-trades" id="trades-area">
          <div class="d-empty">Connecting...</div>
        </div>
      </div>
    </div>

    <!-- RIGHT PANEL — Pipeline -->
    <div class="d-panel d-right">
      <div class="d-panel-head">
        <span class="d-panel-label">PIPELINE</span>
        <span class="d-panel-count" id="total-rows">--</span>
      </div>

      <div class="d-panel-scroll" id="right-panel">
        <!-- DB totals -->
        <div class="d-db-row">
          <div class="d-db">
            <span class="d-db-label">WATCHDOG</span>
            <span class="d-db-val" id="wd-rows">--</span>
          </div>
          <div class="d-db">
            <span class="d-db-label">ALTDATA</span>
            <span class="d-db-val" id="alt-rows">--</span>
          </div>
        </div>

        <!-- Services -->
        <div class="d-sub-label" style="margin-top:32px">SERVICES</div>
        <div class="d-services" id="services"></div>
      </div>
    </div>

  </div>

</div>
</BaseLayout>

<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');

.d {
  background: #050505;
  min-height: 100vh;
  padding-top: 64px;
}

/* ── Split layout ─────────────────────────────────────── */
.d-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: calc(100vh - 64px);
}
@media (max-width: 900px) {
  .d-split { grid-template-columns: 1fr; height: auto; }
}

.d-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.d-left { border-right: 1px solid #1a1a1a; }

.d-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 32px;
  border-bottom: 1px solid #1a1a1a;
  flex-shrink: 0;
}
.d-panel-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #555;
}
.d-panel-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  font-weight: 600;
  color: #3b82f6;
  letter-spacing: 0.05em;
}

.d-live {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: #22c55e;
}
.d-live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #22c55e;
  animation: glow 2s ease-in-out infinite;
}
@keyframes glow {
  0%, 100% { box-shadow: 0 0 4px #22c55e; opacity: 1; }
  50% { box-shadow: 0 0 12px #22c55e; opacity: 0.7; }
}

.d-panel-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 32px;
  scrollbar-width: none;
}
.d-panel-scroll::-webkit-scrollbar { display: none; }

/* ── Hero P&L ─────────────────────────────────────────── */
.d-hero-row {
  margin-bottom: 40px;
}
.d-hero-block {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.d-hero-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #555;
}
.d-hero-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 4rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.03em;
  line-height: 1;
  transition: color 0.3s;
}
.d-hero-val.up { color: #22c55e; }
.d-hero-val.down { color: #ef4444; }

/* ── Bot cards ────────────────────────────────────────── */
.d-bot {
  border: 1px solid #1a1a1a;
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 12px;
  transition: border-color 0.2s;
}
.d-bot:hover { border-color: #2a2a2a; }

.d-bot-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.d-bot-name {
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: #fff;
}
.d-bot-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: #3b82f6;
  background: rgba(59,130,246,0.08);
  padding: 3px 8px;
  border-radius: 4px;
}

.d-bot-equity {
  font-family: 'JetBrains Mono', monospace;
  font-size: 2.2rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: 4px;
}
.d-bot-pnl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 20px;
}
.up { color: #22c55e; }
.down { color: #ef4444; }

.d-bot-stats {
  display: flex;
  gap: 24px;
}
.d-bot-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.d-bot-stat-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.1rem;
  font-weight: 700;
  color: #fff;
}
.d-bot-stat-lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.5rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: #555;
  text-transform: uppercase;
}

.d-bot-pos {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid #1a1a1a;
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.1em;
}
.d-pos-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
}
.d-pos-dot.on { background: #22c55e; }
.d-pos-dot.off { background: #333; }

/* ── Sub labels ───────────────────────────────────────── */
.d-sub-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #555;
  margin-bottom: 16px;
}

/* ── Trades ────────────────────────────────────────────── */
.d-trades { display: flex; flex-direction: column; gap: 2px; }
.d-trade {
  display: grid;
  grid-template-columns: 1fr 0.7fr 0.7fr 0.5fr;
  gap: 8px;
  padding: 10px 0;
  border-bottom: 1px solid #0e0e0e;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  color: #888;
  align-items: center;
}
.d-trade-pnl { font-weight: 700; }
.d-trade-exit {
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 2px 6px;
  border-radius: 3px;
  text-align: center;
}
.d-exit-target { background: rgba(34,197,94,0.08); color: #22c55e; }
.d-exit-stop { background: rgba(239,68,68,0.08); color: #ef4444; }
.d-exit-flip { background: rgba(59,130,246,0.08); color: #3b82f6; }
.d-exit-trail { background: rgba(245,158,11,0.08); color: #f59e0b; }
.d-exit-timeout { background: rgba(85,85,85,0.08); color: #555; }
.d-empty {
  color: #333;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  padding: 40px 0;
  text-align: center;
}

/* ── DB row ────────────────────────────────────────────── */
.d-db-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 12px;
}
.d-db {
  border: 1px solid #1a1a1a;
  border-radius: 12px;
  padding: 28px 24px;
  text-align: center;
}
.d-db-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #555;
  display: block;
  margin-bottom: 12px;
}
.d-db-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 2.4rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.02em;
}

/* ── Services ─────────────────────────────────────────── */
.d-services {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.d-svc {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 6px 10px;
  border: 1px solid #1a1a1a;
  border-radius: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: #555;
  text-transform: uppercase;
}
.d-svc-dot { width: 4px; height: 4px; border-radius: 50%; }
.d-svc-dot.up { background: #22c55e; }
.d-svc-dot.down { background: #ef4444; }
.d-svc-dot.warn { background: #f59e0b; }
</style>

<script>
function fmt(n: number): string {
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function fmtRows(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  return n.toLocaleString();
}

async function load() {
  try {
    const res = await fetch('/api/trading/status');
    if (!res.ok) return;
    render(await res.json());
  } catch {}
}

function render(data: any) {
  const wd = data.pipelines?.totals?.watchdog || 0;
  const alt = data.pipelines?.totals?.altdata || 0;
  const services = data.services || {};
  const running = Object.values(services).filter((s: any) => s === 'RUNNING').length;

  // Total P&L
  let totalPnl = 0;
  for (const bot of Object.values(data.bots || {}) as any[]) totalPnl += bot.pnl || 0;

  const pnlEl = document.getElementById('total-pnl');
  if (pnlEl) {
    pnlEl.textContent = (totalPnl >= 0 ? '+' : '-') + fmt(Math.abs(totalPnl));
    pnlEl.className = 'd-hero-val ' + (totalPnl >= 0 ? 'up' : 'down');
  }

  // Right panel
  const wdEl = document.getElementById('wd-rows');
  const altEl = document.getElementById('alt-rows');
  const totalEl = document.getElementById('total-rows');
  if (wdEl) wdEl.textContent = fmtRows(wd);
  if (altEl) altEl.textContent = fmtRows(alt);
  if (totalEl) totalEl.textContent = fmtRows(wd + alt) + ' rows';

  // Bot cards
  const botsArea = document.getElementById('bots-area');
  if (botsArea && data.bots) {
    botsArea.innerHTML = Object.entries(data.bots).map(([id, bot]: [string, any]) => {
      const pnlCls = bot.pnl > 0 ? 'up' : bot.pnl < 0 ? 'down' : '';
      const sign = bot.pnl >= 0 ? '+' : '';
      const pos = bot.has_position;
      const wrColor = bot.wr >= 55 ? 'up' : bot.wr < 50 ? 'down' : '';
      return `
        <div class="d-bot">
          <div class="d-bot-top">
            <span class="d-bot-name">${bot.label}</span>
            <span class="d-bot-tag">${bot.asset}</span>
          </div>
          <div class="d-bot-equity">${fmt(bot.equity)}</div>
          <div class="d-bot-pnl ${pnlCls}">${sign}${fmt(Math.abs(bot.pnl))} · ${sign}${bot.pnl_pct}%</div>
          <div class="d-bot-stats">
            <div class="d-bot-stat"><span class="d-bot-stat-val">${bot.total_trades}</span><span class="d-bot-stat-lbl">Trades</span></div>
            <div class="d-bot-stat"><span class="d-bot-stat-val ${wrColor}">${bot.wr}%</span><span class="d-bot-stat-lbl">Win Rate</span></div>
            <div class="d-bot-stat"><span class="d-bot-stat-val">${bot.wins}W / ${bot.losses}L</span><span class="d-bot-stat-lbl">Record</span></div>
          </div>
          <div class="d-bot-pos">
            <span class="d-pos-dot ${pos ? 'on' : 'off'}"></span>
            <span style="color:${pos ? '#22c55e' : '#333'}">${pos ? 'IN POSITION' : 'WAITING'}</span>
          </div>
        </div>`;
    }).join('');
  }

  // Services
  const svcEl = document.getElementById('services');
  if (svcEl) {
    svcEl.innerHTML = Object.entries(services).map(([name, status]: [string, any]) => {
      const dot = status === 'RUNNING' ? 'up' : status === 'FATAL' ? 'down' : 'warn';
      const short = name.replace('pipeline_', '').replace('paper_bot_', 'bot_');
      return `<div class="d-svc"><span class="d-svc-dot ${dot}"></span>${short}</div>`;
    }).join('');
  }

  // Trades
  const allTrades: any[] = [];
  for (const [id, bot] of Object.entries(data.bots || {}) as any[]) {
    for (const t of bot.recent_trades || []) allTrades.push({ ...t, bot: bot.label });
  }
  allTrades.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());

  const tradesArea = document.getElementById('trades-area');
  if (tradesArea) {
    if (allTrades.length === 0) {
      tradesArea.innerHTML = '<div class="d-empty">AWAITING TRADES</div>';
    } else {
      tradesArea.innerHTML = allTrades.slice(0, 20).map((t: any) => {
        const pnl = parseFloat(t.pnl_dollar || 0);
        const cls = pnl >= 0 ? 'up' : 'down';
        const exitCls = `d-exit-${t.exit_reason || 'flip'}`;
        const time = new Date(t.timestamp).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
        return `<div class="d-trade">
          <span>${t.bot} · ${t.symbol || '--'}</span>
          <span class="d-trade-pnl ${cls}">${pnl >= 0 ? '+' : ''}$${pnl.toFixed(2)}</span>
          <span>${time}</span>
          <span class="d-trade-exit ${exitCls}">${t.exit_reason || '--'}</span>
        </div>`;
      }).join('');
    }
  }
}

load();
setInterval(load, 10000);
</script>
