---
export const prerender = false;
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Command — Greesi";
const description = "Live trading operations + data pipeline dashboard.";
---

<BaseLayout title={title} description={description}>
<div class="cmd">

  <!-- Header -->
  <header class="cmd-header">
    <div class="cmd-header-inner">
      <div>
        <h1 class="cmd-title">Command</h1>
        <span class="cmd-sub">GREESI CAPITAL · LIVE OPERATIONS</span>
      </div>
      <div class="cmd-header-right">
        <div class="cmd-pulse" id="pulse"></div>
        <span class="cmd-clock" id="clock">--:--:--</span>
      </div>
    </div>
  </header>

  <main class="cmd-main" id="main">

    <!-- Loading -->
    <div class="cmd-loading" id="loading">
      <div class="cmd-spin"></div>
      <p>CONNECTING TO SYSTEMS...</p>
    </div>

    <!-- Services Status Strip -->
    <div class="cmd-strip" id="strip" style="display:none"></div>

    <!-- Bot Cards -->
    <div class="cmd-bots" id="bots" style="display:none"></div>

    <!-- Pipeline Stats -->
    <div class="cmd-section" id="pipeline-section" style="display:none">
      <div class="cmd-section-head">
        <span class="cmd-label">DATA PIPELINE</span>
        <span class="cmd-total" id="total-rows">--</span>
      </div>
      <div class="cmd-pipeline" id="pipeline"></div>
    </div>

    <!-- Recent Trades -->
    <div class="cmd-section" id="trades-section" style="display:none">
      <div class="cmd-section-head">
        <span class="cmd-label">RECENT TRADES</span>
      </div>
      <div class="cmd-table-wrap">
        <table class="cmd-table" id="trades-table">
          <thead>
            <tr><th>TIME</th><th>BOT</th><th>SYMBOL</th><th>PRICE</th><th>P&L</th><th>HOLD</th><th>EXIT</th></tr>
          </thead>
          <tbody id="trades-body"></tbody>
        </table>
      </div>
    </div>

  </main>
</div>
</BaseLayout>

<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap');

:root {
  --bg: #0a0a0a;
  --surface: #111111;
  --border: #1f1f1f;
  --text: #d4d4d4;
  --muted: #737373;
  --green: #10b981;
  --red: #ef4444;
  --amber: #f59e0b;
  --blue: #3b82f6;
  --mono: 'JetBrains Mono', 'SF Mono', monospace;
  --sans: 'Inter', -apple-system, sans-serif;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

.cmd { background: var(--bg); min-height: 100vh; padding-top: 64px; }

/* Header */
.cmd-header { background: var(--surface); border-bottom: 1px solid var(--border); }
.cmd-header-inner {
  max-width: 1400px; margin: 0 auto; padding: 20px 32px;
  display: flex; align-items: center; justify-content: space-between;
}
.cmd-title {
  font-family: var(--sans); font-size: 2.4rem; font-weight: 700;
  color: #ffffff; letter-spacing: -0.03em;
}
.cmd-sub {
  font-family: var(--mono); font-size: 0.6rem; font-weight: 500;
  color: var(--muted); letter-spacing: 0.2em; display: block; margin-top: 2px;
}
.cmd-header-right { display: flex; align-items: center; gap: 12px; }
.cmd-pulse {
  width: 8px; height: 8px; border-radius: 50%; background: var(--green);
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(16,185,129,0.4)} 50%{opacity:0.6;box-shadow:0 0 0 8px rgba(16,185,129,0)} }
.cmd-clock {
  font-family: var(--mono); font-size: 0.85rem; color: var(--muted);
  letter-spacing: 0.05em;
}

/* Main */
.cmd-main { max-width: 1400px; margin: 0 auto; padding: 16px 32px 64px; }

/* Loading */
.cmd-loading {
  display: flex; flex-direction: column; align-items: center;
  padding: 80px 0; gap: 16px; color: var(--muted);
  font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.15em;
}
.cmd-spin {
  width: 24px; height: 24px; border: 2px solid var(--border);
  border-top-color: var(--green); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Service strip */
.cmd-strip {
  display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;
}
.cmd-chip {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 12px; background: var(--surface); border: 1px solid var(--border);
  border-radius: 2px; font-family: var(--mono); font-size: 0.6rem;
  color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase;
}
.cmd-dot {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
}
.cmd-dot.up { background: var(--green); }
.cmd-dot.down { background: var(--red); }
.cmd-dot.warn { background: var(--amber); }

/* Bot cards */
.cmd-bots {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 8px; margin-bottom: 16px;
}
@media (max-width: 900px) { .cmd-bots { grid-template-columns: 1fr; } }

.cmd-bot {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 2px; padding: 20px 24px;
}
.cmd-bot-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16px;
}
.cmd-bot-name {
  font-family: var(--mono); font-size: 0.6rem; font-weight: 600;
  color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase;
}
.cmd-bot-asset {
  font-family: var(--mono); font-size: 0.55rem; color: var(--muted);
  background: var(--bg); padding: 2px 6px; border-radius: 2px;
}
.cmd-bot-equity {
  font-family: var(--mono); font-size: 2.8rem; font-weight: 700;
  color: #ffffff; letter-spacing: -0.02em; line-height: 1;
  margin-bottom: 4px;
}
.cmd-bot-pnl {
  font-family: var(--mono); font-size: 1.1rem; font-weight: 600;
  margin-bottom: 20px;
}
.cmd-bot-pnl.up { color: var(--green); }
.cmd-bot-pnl.down { color: var(--red); }
.cmd-bot-pnl.flat { color: var(--muted); }

.cmd-bot-stats {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border); border-radius: 2px; overflow: hidden;
}
.cmd-stat {
  background: var(--bg); padding: 10px 8px; text-align: center;
}
.cmd-stat-val {
  font-family: var(--mono); font-size: 1.1rem; font-weight: 600;
  color: #ffffff; display: block;
}
.cmd-stat-lbl {
  font-family: var(--sans); font-size: 0.5rem; font-weight: 600;
  color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em;
  margin-top: 4px; display: block;
}
.cmd-bot-pos {
  margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);
  font-family: var(--mono); font-size: 0.65rem; color: var(--muted);
}
.cmd-bot-pos.active { color: var(--green); }

/* Section */
.cmd-section {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 2px; padding: 20px 24px; margin-bottom: 8px;
}
.cmd-section-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16px;
}
.cmd-label {
  font-family: var(--mono); font-size: 0.6rem; font-weight: 600;
  color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase;
}
.cmd-total {
  font-family: var(--mono); font-size: 1.8rem; font-weight: 700;
  color: #ffffff; letter-spacing: -0.02em;
}

/* Pipeline grid */
.cmd-pipeline {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 4px;
}
.cmd-pipe {
  background: var(--bg); padding: 10px 12px; border-radius: 2px;
}
.cmd-pipe-name {
  font-family: var(--sans); font-size: 0.6rem; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px;
}
.cmd-pipe-rows {
  font-family: var(--mono); font-size: 1rem; font-weight: 600; color: var(--text);
}

/* Table */
.cmd-table-wrap { overflow-x: auto; }
.cmd-table {
  width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 0.7rem;
}
.cmd-table th {
  text-align: left; padding: 8px 10px;
  font-family: var(--mono); font-size: 0.55rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted);
  border-bottom: 1px solid var(--border);
}
.cmd-table td {
  padding: 8px 10px; border-bottom: 1px solid #0d0d0d; color: var(--text);
}
.cmd-table tr:nth-child(even) td { background: #0d0d0d; }
.cmd-table .up { color: var(--green); font-weight: 600; }
.cmd-table .down { color: var(--red); font-weight: 600; }
.cmd-table .exit-badge {
  font-size: 0.55rem; padding: 1px 5px; border-radius: 2px;
  text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;
}
.cmd-table .exit-target { background: rgba(16,185,129,0.1); color: var(--green); }
.cmd-table .exit-stop { background: rgba(239,68,68,0.1); color: var(--red); }
.cmd-table .exit-flip { background: rgba(59,130,246,0.1); color: var(--blue); }
.cmd-table .exit-trail { background: rgba(245,158,11,0.1); color: var(--amber); }
.cmd-table .exit-timeout { background: rgba(115,115,115,0.1); color: var(--muted); }

/* Animated counter */
@keyframes countUp {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
.cmd-animate { animation: countUp 0.3s ease-out; }
</style>

<script>
async function fetchData() {
  try {
    const res = await fetch('/api/trading/status');
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    render(data);

    document.getElementById('loading').style.display = 'none';
    document.getElementById('strip').style.display = '';
    document.getElementById('bots').style.display = '';
    document.getElementById('pipeline-section').style.display = '';
    document.getElementById('trades-section').style.display = '';

    const pulse = document.getElementById('pulse');
    if (pulse) { pulse.style.background = '#10b981'; }
  } catch (e) {
    const pulse = document.getElementById('pulse');
    if (pulse) { pulse.style.background = '#ef4444'; }
  }
}

function fmt(n: number) {
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtRows(n: number) {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}

function render(data: any) {
  // Clock
  const clock = document.getElementById('clock');
  if (clock) clock.textContent = new Date().toLocaleTimeString('en-US', { hour12: false });

  // Services strip
  const strip = document.getElementById('strip');
  if (strip && data.services) {
    const chips = Object.entries(data.services).map(([name, status]: [string, any]) => {
      const dotClass = status === 'RUNNING' ? 'up' : status === 'FATAL' ? 'down' : 'warn';
      const shortName = name.replace('pipeline_', '').replace('paper_bot_', '');
      return `<div class="cmd-chip"><div class="cmd-dot ${dotClass}"></div>${shortName}</div>`;
    }).join('');
    strip.innerHTML = chips;
  }

  // Bot cards
  const botsEl = document.getElementById('bots');
  if (botsEl && data.bots) {
    botsEl.innerHTML = Object.entries(data.bots).map(([id, bot]: [string, any]) => {
      const pnlDir = bot.pnl > 0.01 ? 'up' : bot.pnl < -0.01 ? 'down' : 'flat';
      const pnlSign = bot.pnl >= 0 ? '+' : '';
      const posText = bot.has_position ? '● IN POSITION' : '○ WAITING';
      const posClass = bot.has_position ? 'active' : '';

      return `
        <div class="cmd-bot">
          <div class="cmd-bot-head">
            <span class="cmd-bot-name">${bot.label}</span>
            <span class="cmd-bot-asset">${bot.asset}</span>
          </div>
          <div class="cmd-bot-equity cmd-animate">${fmt(bot.equity)}</div>
          <div class="cmd-bot-pnl ${pnlDir}">${pnlSign}${fmt(Math.abs(bot.pnl))} (${pnlSign}${bot.pnl_pct}%)</div>
          <div class="cmd-bot-stats">
            <div class="cmd-stat"><span class="cmd-stat-val">${bot.total_trades}</span><span class="cmd-stat-lbl">TRADES</span></div>
            <div class="cmd-stat"><span class="cmd-stat-val" style="color:${bot.wr >= 55 ? '#10b981' : bot.wr >= 50 ? '#d4d4d4' : '#ef4444'}">${bot.wr}%</span><span class="cmd-stat-lbl">WIN RATE</span></div>
            <div class="cmd-stat"><span class="cmd-stat-val">${bot.wins}W/${bot.losses}L</span><span class="cmd-stat-lbl">W / L</span></div>
          </div>
          <div class="cmd-bot-pos ${posClass}">${posText}</div>
        </div>`;
    }).join('');
  }

  // Pipeline
  if (data.pipelines) {
    const totalEl = document.getElementById('total-rows');
    if (totalEl) {
      const total = data.pipelines.totals?.combined || 0;
      totalEl.textContent = total.toLocaleString() + ' ROWS';
    }

    const pipeEl = document.getElementById('pipeline');
    if (pipeEl) {
      const all = [
        ...Object.values(data.pipelines.watchdog || {}),
        ...Object.values(data.pipelines.altdata || {}),
      ].sort((a: any, b: any) => b.rows - a.rows);

      pipeEl.innerHTML = (all as any[]).map((p: any) =>
        `<div class="cmd-pipe">
          <div class="cmd-pipe-name">${p.label}</div>
          <div class="cmd-pipe-rows">${fmtRows(p.rows)}</div>
        </div>`
      ).join('');
    }
  }

  // Trades
  const allTrades: any[] = [];
  if (data.bots) {
    for (const [id, bot] of Object.entries(data.bots) as any[]) {
      for (const t of bot.recent_trades || []) {
        allTrades.push({ ...t, bot_label: bot.label });
      }
    }
  }
  allTrades.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());

  const tbody = document.getElementById('trades-body');
  if (tbody) {
    if (allTrades.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#737373;padding:24px;font-family:var(--mono);font-size:0.7rem;">AWAITING TRADES...</td></tr>';
    } else {
      tbody.innerHTML = allTrades.slice(0, 15).map((t: any) => {
        const pnl = parseFloat(t.pnl_dollar || 0);
        const pnlClass = pnl >= 0 ? 'up' : 'down';
        const exitClass = `exit-${t.exit_reason || 'flip'}`;
        const time = new Date(t.timestamp).toLocaleString('en-US', {
          month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false,
        });
        return `<tr>
          <td>${time}</td>
          <td>${t.bot_label}</td>
          <td>${t.symbol || '—'}</td>
          <td>${t.price ? '$' + parseFloat(t.price).toLocaleString() : '—'}</td>
          <td class="${pnlClass}">${pnl >= 0 ? '+' : ''}$${pnl.toFixed(2)}</td>
          <td>${t.hold_min ? parseFloat(t.hold_min).toFixed(0) + 'm' : '—'}</td>
          <td><span class="exit-badge ${exitClass}">${t.exit_reason || '—'}</span></td>
        </tr>`;
      }).join('');
    }
  }
}

// Clock update
setInterval(() => {
  const clock = document.getElementById('clock');
  if (clock) clock.textContent = new Date().toLocaleTimeString('en-US', { hour12: false });
}, 1000);

// Fetch + auto-refresh
fetchData();
setInterval(fetchData, 15000);
</script>
