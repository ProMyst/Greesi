---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase-server';

const title = "Intelligence Dashboard — Greesi";
const description = "Live crypto signals, macro data, trend detection, and alt data — all in one platform.";

// Auth: middleware already protects this route, but get user for display
const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
const userEmail = session?.user?.email ?? '';

// Fetch latest signals across all domains
const { data: signals } = await supabase
  .from('signals')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(12);

// Fetch live crypto prices (Binance — no key, high rate limits)
type PriceMap = Record<string, { price: number; change: number }>;
let prices: PriceMap = {};
try {
  const syms = encodeURIComponent(JSON.stringify(['BTCUSDT','ETHUSDT','SOLUSDT']));
  const res = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbols=${syms}`);
  if (res.ok) {
    const rows: { symbol: string; lastPrice: string; priceChangePercent: string }[] = await res.json();
    for (const r of rows) {
      prices[r.symbol] = { price: parseFloat(r.lastPrice), change: parseFloat(r.priceChangePercent) };
    }
  }
} catch {}

const fmt = (n: number) => n >= 1000
  ? '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 })
  : '$' + n.toFixed(2);
const fmtChange = (n: number) => (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
---

<BaseLayout title={title} description={description}>
  <div class="db-root">

    <!-- Sidebar -->
    <aside class="db-sidebar" id="db-sidebar">
      <div class="db-sidebar-top">
        <a href="/" class="db-wordmark">greesi</a>
        <button class="db-collapse-btn" id="db-collapse" aria-label="Collapse sidebar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
      </div>
      <nav class="db-nav">
        <p class="db-nav-section">Intelligence</p>
        <a href="/dashboard" class="db-nav-link db-nav-link--active">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Overview
        </a>
        <a href="/crypto" class="db-nav-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11.767 19.089c4.924.868 6.14-6.025 1.216-6.894m-1.216 6.894L5.86 18.047m5.908 1.042-.347 1.97m1.563-8.864c4.924.869 6.14-6.025 1.215-6.893m-1.215 6.893-3.94-.694m5.155-6.2L8.29 5.26m5.908 1.042.348-1.97M7.48 20.364l3.126-17.727"/></svg>
          Crypto
          <span class="db-nav-badge db-nav-badge--live">LIVE</span>
        </a>
        <a href="/macro" class="db-nav-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Macro
          <span class="db-nav-badge db-nav-badge--live">LIVE</span>
        </a>
        <a href="/trends" class="db-nav-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          Trends
          <span class="db-nav-badge db-nav-badge--soon">SOON</span>
        </a>
        <a href="/alt-data" class="db-nav-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          Alt Data
          <span class="db-nav-badge db-nav-badge--soon">SOON</span>
        </a>
        <p class="db-nav-section">Editorial</p>
        <a href="/finance" class="db-nav-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          Finance Hub
        </a>
        <p class="db-nav-section">Account</p>
        <div class="db-user-row">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="db-user-email" title={userEmail}>{userEmail}</span>
        </div>
        <form action="/api/auth/signout" method="POST" style="margin-top:4px">
          <button type="submit" class="db-nav-link db-signout-btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
          </button>
        </form>
      </nav>
      <div class="db-sidebar-footer">
        <div class="db-beta-badge">PRIVATE BETA</div>
        <p class="db-beta-text">Full access launching soon.<br/><a href="/waitlist">Join the waitlist →</a></p>
      </div>
    </aside>

    <!-- Main content -->
    <main class="db-main">

      <!-- Top bar -->
      <div class="db-topbar">
        <div class="db-topbar-left">
          <h1 class="db-page-title">Overview</h1>
          <span class="db-page-sub">All intelligence domains</span>
        </div>
        <div class="db-topbar-right">
          <span class="db-updated" id="db-updated">Updated just now</span>
        </div>
      </div>

      <!-- Price strip -->
      <div class="db-price-strip">
        {[
          { sym: 'BTCUSDT', label: 'BTC' },
          { sym: 'ETHUSDT', label: 'ETH' },
          { sym: 'SOLUSDT', label: 'SOL' },
        ].map(a => {
          const p = prices[a.sym];
          const change = p?.change ?? 0;
          const dir = change >= 0.5 ? 'up' : change < -0.5 ? 'down' : 'neutral';
          return (
            <div class={`db-price-card ${dir}`}>
              <div class="db-price-sym">{a.label}</div>
              <div class="db-price-val">{p ? fmt(p.price) : '—'}</div>
              <div class={`db-price-change ${dir}`}>{p ? fmtChange(p.change) : '—'}</div>
            </div>
          );
        })}
        <a href="/waitlist" class="db-price-card db-price-card--more">
          <div class="db-price-sym">+47</div>
          <div class="db-price-val">more assets</div>
          <div class="db-price-change neutral">Full access →</div>
        </a>
      </div>

      <!-- Signal feed -->
      <div class="db-section-header">
        <h2 class="db-section-title">Recent Signals</h2>
        <div class="db-filter-row">
          <button class="db-filter-btn db-filter-btn--active" data-filter="all">All</button>
          <button class="db-filter-btn" data-filter="crypto">Crypto</button>
          <button class="db-filter-btn" data-filter="macro">Macro</button>
          <button class="db-filter-btn" data-filter="finance">Finance</button>
        </div>
      </div>

      <div class="db-signal-list" id="db-signal-list">
        {signals && signals.length > 0 ? signals.map((s: any) => (
          <div class={`db-signal-row ${s.direction}`} data-domain={s.domain}>
            <div class={`db-signal-bar ${s.direction}`}></div>
            <div class="db-signal-meta">
              <span class="db-signal-domain">{s.domain}</span>
              <span class="db-signal-type">{s.type.replace('-', ' ')}</span>
            </div>
            <div class="db-signal-body">
              <p class="db-signal-title">{s.title}</p>
            </div>
            <div class="db-signal-right">
              {s.metric_value && <span class="db-signal-metric">{s.metric_value}</span>}
              <div class="db-signal-strength">
                {Array.from({ length: 5 }, (_, i) => (
                  <span class={`db-sbar ${i < s.strength ? 'on' : ''}`}></span>
                ))}
              </div>
              <span class="db-signal-time">{new Date(s.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
            </div>
          </div>
        )) : (
          <div class="db-empty">
            <p>No signals yet. <a href="/waitlist">Join waitlist</a> to access the full feed.</p>
          </div>
        )}
      </div>

      <!-- Coming soon panels -->
      <div class="db-coming-panels">
        {[
          { title: 'Trend Velocity Chart', desc: 'Reddit + Google Trends momentum over 24h/7d/30d', domain: 'Trends' },
          { title: 'Macro Dashboard', desc: 'Yield curve, DXY, CPI — with FRED live data', domain: 'Macro' },
          { title: 'Correlation Matrix', desc: 'BTC/ETH vs SPY/DXY/Gold — D3 heatmap', domain: 'Crypto' },
          { title: 'Alt Data Feed', desc: 'Job postings, web traffic, satellite indices', domain: 'Alt Data' },
        ].map(p => (
          <div class="db-coming-panel">
            <div class="db-coming-domain">{p.domain}</div>
            <h3 class="db-coming-title">{p.title}</h3>
            <p class="db-coming-desc">{p.desc}</p>
            <div class="db-coming-lock">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Coming soon
            </div>
          </div>
        ))}
      </div>

    </main>
  </div>
</BaseLayout>

<style>
  :root {
    --db-bg: #080B0F; --db-surface: #0D1117; --db-elevated: #161B22;
    --db-border: #21262D; --db-border2: #30363D;
    --db-text: #F0F6FC; --db-muted: #8B949E; --db-dim: #484F58;
    --db-green: #39D353; --db-red: #F85149; --db-amber: #D29922;
    --db-blue: #58A6FF; --db-accent: #1F6FEB;
  }

  /* ── Layout ─────────────────────────────────────────────── */
  .db-root {
    display: flex; min-height: calc(100vh - 64px);
    background: var(--db-bg); color: var(--db-text);
    font-family: 'Inter', sans-serif;
  }

  /* ── Sidebar ─────────────────────────────────────────────── */
  .db-sidebar {
    width: 220px; flex-shrink: 0;
    background: var(--db-surface); border-right: 1px solid var(--db-border);
    display: flex; flex-direction: column;
    position: sticky; top: 64px; height: calc(100vh - 64px); overflow-y: auto;
  }
  .db-sidebar-top {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 16px 16px; border-bottom: 1px solid var(--db-border);
  }
  .db-wordmark { font-size: 0.95rem; font-weight: 700; letter-spacing: -0.04em; color: var(--db-text); }
  .db-collapse-btn {
    color: var(--db-muted); background: none; border: none; cursor: pointer; padding: 4px;
    border-radius: 4px; transition: color 0.2s; display: flex; align-items: center;
  }
  .db-collapse-btn:hover { color: var(--db-text); }
  .db-nav { padding: 12px 8px; flex: 1; }
  .db-nav-section {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--db-dim); padding: 12px 8px 6px; margin-top: 4px;
  }
  .db-nav-link {
    display: flex; align-items: center; gap: 9px;
    padding: 8px; border-radius: 6px; font-size: 0.82rem; color: var(--db-muted);
    transition: background 0.15s, color 0.15s; text-decoration: none; margin-bottom: 2px;
  }
  .db-nav-link:hover { background: var(--db-elevated); color: var(--db-text); }
  .db-nav-link--active { background: var(--db-elevated); color: var(--db-text); }
  .db-nav-badge {
    margin-left: auto; font-size: 0.55rem; font-weight: 700; letter-spacing: 0.06em;
    padding: 2px 5px; border-radius: 3px;
  }
  .db-nav-badge--live { background: rgba(57,211,83,0.15); color: var(--db-green); }
  .db-nav-badge--soon { background: rgba(210,153,34,0.15); color: var(--db-amber); }
  .db-user-row {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; margin: 0 4px;
    background: rgba(255,255,255,0.03); border-radius: 6px;
    border: 1px solid var(--db-border);
  }
  .db-user-email {
    font-size: 0.75rem; color: var(--db-muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0;
  }
  .db-signout-btn {
    background: none; border: none; cursor: pointer; font-family: inherit;
    color: var(--db-muted); transition: color 0.2s;
    text-align: left; width: 100%; padding: 8px 12px;
  }
  .db-signout-btn:hover { color: #F85149; }
  .db-sidebar-footer { padding: 16px; border-top: 1px solid var(--db-border); }
  .db-beta-badge {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
    background: rgba(31,111,235,0.15); color: var(--db-blue);
    padding: 3px 8px; border-radius: 4px; display: inline-block; margin-bottom: 8px;
  }
  .db-beta-text { font-size: 0.75rem; color: var(--db-muted); line-height: 1.5; }
  .db-beta-text a { color: var(--db-blue); }

  /* ── Main ────────────────────────────────────────────────── */
  .db-main { flex: 1; min-width: 0; padding: 0; overflow: hidden; }
  .db-topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 28px; border-bottom: 1px solid var(--db-border);
    background: var(--db-surface);
  }
  .db-page-title { font-size: 1rem; font-weight: 600; color: var(--db-text); }
  .db-page-sub { font-size: 0.75rem; color: var(--db-muted); display: block; margin-top: 2px; }
  .db-updated { font-size: 0.72rem; color: var(--db-muted); font-family: 'JetBrains Mono', monospace; }

  /* ── Price strip ─────────────────────────────────────────── */
  .db-price-strip {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--db-border);
  }
  .db-price-card {
    padding: 18px 24px; border-right: 1px solid var(--db-border);
    transition: background 0.15s;
  }
  .db-price-card:last-child { border-right: none; }
  .db-price-card:hover { background: var(--db-elevated); }
  .db-price-card--more { text-decoration: none; cursor: pointer; }
  .db-price-sym { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--db-muted); margin-bottom: 6px; font-family: 'JetBrains Mono', monospace; }
  .db-price-val { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 600; color: var(--db-text); margin-bottom: 4px; }
  .db-price-change { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 500; }
  .db-price-change.up   { color: var(--db-green); }
  .db-price-change.down { color: var(--db-red); }
  .db-price-change.neutral { color: var(--db-muted); }

  /* ── Signal feed ─────────────────────────────────────────── */
  .db-section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 28px 12px; flex-wrap: wrap; gap: 12px;
  }
  .db-section-title { font-size: 0.875rem; font-weight: 600; color: var(--db-text); }
  .db-filter-row { display: flex; gap: 6px; }
  .db-filter-btn {
    font-size: 0.72rem; font-weight: 600; padding: 5px 12px; border-radius: 6px;
    border: 1px solid var(--db-border); background: none; color: var(--db-muted);
    cursor: pointer; font-family: inherit; transition: all 0.15s;
  }
  .db-filter-btn:hover { border-color: var(--db-border2); color: var(--db-text); }
  .db-filter-btn--active { background: var(--db-elevated); border-color: var(--db-border2); color: var(--db-text); }

  .db-signal-list { padding: 0 28px 24px; display: flex; flex-direction: column; gap: 0; }
  .db-signal-row {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 0; border-bottom: 1px solid var(--db-border);
    transition: background 0.1s;
  }
  .db-signal-row:hover { background: rgba(255,255,255,0.02); margin: 0 -28px; padding: 14px 28px; }
  .db-signal-row:last-child { border-bottom: none; }
  .db-signal-bar { width: 3px; height: 32px; border-radius: 2px; flex-shrink: 0; }
  .db-signal-bar.bullish { background: var(--db-green); }
  .db-signal-bar.bearish { background: var(--db-red); }
  .db-signal-bar.neutral { background: var(--db-amber); }
  .db-signal-meta { display: flex; flex-direction: column; gap: 3px; width: 80px; flex-shrink: 0; }
  .db-signal-domain { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--db-muted); }
  .db-signal-type { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--db-dim); }
  .db-signal-body { flex: 1; min-width: 0; }
  .db-signal-title { font-size: 0.85rem; color: var(--db-text); line-height: 1.4; }
  .db-signal-right { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
  .db-signal-metric { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 600; color: var(--db-text); }
  .db-signal-strength { display: flex; gap: 2px; }
  .db-sbar { display: block; width: 12px; height: 3px; background: var(--db-border); border-radius: 1px; }
  .db-sbar.on { background: var(--db-blue); }
  .db-signal-time { font-size: 0.68rem; color: var(--db-dim); font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .db-empty { padding: 40px; text-align: center; color: var(--db-muted); }
  .db-empty a { color: var(--db-blue); }

  /* ── Coming soon panels ──────────────────────────────────── */
  .db-coming-panels {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 16px; padding: 0 28px 28px;
  }
  .db-coming-panel {
    background: var(--db-surface); border: 1px solid var(--db-border);
    border-radius: 10px; padding: 24px; position: relative; overflow: hidden;
  }
  .db-coming-panel::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(255,255,255,0.01) 8px, rgba(255,255,255,0.01) 16px);
  }
  .db-coming-domain { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--db-blue); margin-bottom: 8px; }
  .db-coming-title { font-size: 0.875rem; font-weight: 600; color: var(--db-text); margin-bottom: 8px; }
  .db-coming-desc { font-size: 0.78rem; color: var(--db-muted); line-height: 1.5; margin-bottom: 16px; }
  .db-coming-lock {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.68rem; color: var(--db-dim); font-weight: 500;
  }

  @media (max-width: 900px) {
    .db-sidebar { display: none; }
    .db-price-strip { grid-template-columns: repeat(2, 1fr); }
    .db-coming-panels { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .db-price-strip { grid-template-columns: 1fr 1fr; }
    .db-signal-right { display: none; }
  }
</style>

<script>
  import { animate, stagger } from 'animejs';

  // Entrance
  animate('.db-price-card', {
    opacity: [0, 1], translateY: [12, 0], scale: [0.97, 1],
    duration: 500, ease: 'out(3)', delay: stagger(60, { start: 100 }),
  });
  animate('.db-signal-row', {
    opacity: [0, 1], translateX: [-8, 0],
    duration: 400, ease: 'out(3)', delay: stagger(40, { start: 300 }),
  });

  // Filter buttons
  document.querySelectorAll<HTMLButtonElement>('.db-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.db-filter-btn').forEach(b => b.classList.remove('db-filter-btn--active'));
      btn.classList.add('db-filter-btn--active');
      const filter = btn.dataset.filter ?? 'all';
      document.querySelectorAll<HTMLElement>('.db-signal-row').forEach(row => {
        row.style.display = filter === 'all' || row.dataset.domain === filter ? 'flex' : 'none';
      });
    });
  });

  // Live price refresh every 60s
  async function refreshPrices() {
    try {
      const res = await fetch('/api/crypto/prices');
      if (!res.ok) return;
      const { prices, updatedAt } = await res.json();
      const map: Record<string, { price: number; change24h: number }> = { BTC: prices.BTC, ETH: prices.ETH, SOL: prices.SOL };
      document.querySelectorAll<HTMLElement>('.db-price-card[class*="up"], .db-price-card[class*="down"], .db-price-card[class*="neutral"]').forEach(card => {
        const sym = card.querySelector('.db-price-sym')?.textContent?.trim() ?? '';
        const d = map[sym];
        if (!d) return;
        const valEl = card.querySelector('.db-price-val');
        const chgEl = card.querySelector('.db-price-change');
        if (valEl) valEl.textContent = d.price >= 1000 ? '$' + d.price.toLocaleString('en-US', { maximumFractionDigits: 0 }) : '$' + d.price.toFixed(2);
        if (chgEl) {
          chgEl.textContent = (d.change24h >= 0 ? '+' : '') + d.change24h.toFixed(2) + '%';
          chgEl.className = `db-price-change ${d.change24h >= 0.5 ? 'up' : d.change24h <= -0.5 ? 'down' : 'neutral'}`;
        }
      });
      const upd = document.getElementById('db-updated');
      if (upd) upd.textContent = `Updated ${new Date(updatedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
    } catch {}
  }
  setInterval(refreshPrices, 60000);
</script>
