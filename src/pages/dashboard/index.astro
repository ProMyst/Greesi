}
.pub-signal-card:hover { border-color: #30363D; box-shadow: 0 4px 16px rgba(0,0,0,0.25); }
.pub-signal-bar { width: 3px; flex-shrink: 0; }
.pub-signal-body { flex: 1; padding: 16px 18px; min-width: 0; }
.pub-signal-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
