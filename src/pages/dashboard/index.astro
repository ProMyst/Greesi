---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Dashboard — Greesi";
const description = "Live dual-screen trading dashboard.";
---

<BaseLayout title={title} description={description}>
<div class="dash">
  <div class="dash-split">

    <!-- LEFT — Bots -->
    <div class="dash-pane">
      <div class="dash-pane-bar">
        <span class="dash-pane-title">BOTS</span>
        <div class="dash-live"><span class="dash-live-dot"></span>LIVE</div>
      </div>
      <div class="dash-scroll" id="left"></div>
    </div>

    <!-- RIGHT — Data Feed (placeholder for now) -->
    <div class="dash-pane">
      <div class="dash-pane-bar">
        <span class="dash-pane-title">DATA FEED</span>
        <span class="dash-pane-meta" id="feed-status">CONNECTING</span>
      </div>
      <div class="dash-scroll" id="right">
        <div class="dash-feed-placeholder">
          <div class="dash-feed-line"></div>
          <div class="dash-feed-line short"></div>
          <div class="dash-feed-line"></div>
          <div class="dash-feed-line short"></div>
          <div class="dash-feed-line"></div>
          <p class="dash-feed-note">Live data feed coming soon</p>
          <p class="dash-feed-sub">This panel will stream real-time signals,<br/>trade events, and pipeline activity.</p>
        </div>
      </div>
    </div>

  </div>
</div>
</BaseLayout>

<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');

.dash {
  background: #050505;
  min-height: 100vh;
  padding-top: 64px;
}

.dash-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: calc(100vh - 64px);
}
@media (max-width: 900px) {
  .dash-split { grid-template-columns: 1fr; height: auto; }
}

.dash-pane {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.dash-pane:first-child { border-right: 1px solid #151515; }

.dash-pane-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 28px;
  border-bottom: 1px solid #151515;
  flex-shrink: 0;
}
.dash-pane-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: #444;
}
.dash-pane-meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: #333;
}
.dash-live {
  display: flex; align-items: center; gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem; font-weight: 700;
  letter-spacing: 0.2em; color: #22c55e;
}
.dash-live-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: #22c55e;
  animation: glow 2s ease-in-out infinite;
}
@keyframes glow {
  0%,100% { box-shadow: 0 0 3px #22c55e; }
  50% { box-shadow: 0 0 10px #22c55e; opacity: 0.6; }
}

.dash-scroll {
  flex: 1; overflow-y: auto;
  padding: 24px 28px;
  scrollbar-width: none;
}
.dash-scroll::-webkit-scrollbar { display: none; }

/* ── Bot Box ──────────────────────────────────────── */
.dash-bot {
  border: 1px solid #181818;
  border-radius: 10px;
  padding: 28px 28px 24px;
  margin-bottom: 14px;
  transition: border-color 0.2s;
}
.dash-bot:hover { border-color: #252525; }

.dash-bot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}
.dash-bot-name {
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
}
.dash-bot-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #3b82f6;
  background: rgba(59,130,246,0.06);
  padding: 3px 8px;
  border-radius: 4px;
}

/* BIG equity number */
.dash-bot-equity {
  font-family: 'JetBrains Mono', monospace;
  font-size: 3.2rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.03em;
  line-height: 1;
  margin-bottom: 6px;
}

/* P&L — large */
.dash-bot-pnl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 28px;
}
.g { color: #22c55e; }
.r { color: #ef4444; }
.n { color: #555; }

/* Win Rate — BIG */
.dash-bot-wr {
  font-family: 'JetBrains Mono', monospace;
  font-size: 2.4rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
}
.dash-bot-wr-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #444;
  text-transform: uppercase;
  margin-bottom: 20px;
}

/* Trades + W/L — smaller */
.dash-bot-meta {
  display: flex;
  gap: 20px;
}
.dash-bot-meta-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.dash-bot-meta-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  font-weight: 600;
  color: #999;
}
.dash-bot-meta-lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.45rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: #333;
  text-transform: uppercase;
}

/* Position indicator */
.dash-bot-pos {
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid #151515;
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.12em;
}
.dash-pos-dot { width: 5px; height: 5px; border-radius: 50%; }
.dash-pos-dot.on { background: #22c55e; }
.dash-pos-dot.off { background: #222; }

/* ── Feed placeholder ─────────────────────────────── */
.dash-feed-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 12px;
  padding: 40px 0;
}
.dash-feed-line {
  width: 80%;
  height: 1px;
  background: linear-gradient(90deg, transparent, #1a1a1a 30%, #1a1a1a 70%, transparent);
  animation: feed-pulse 3s ease-in-out infinite;
}
.dash-feed-line.short { width: 50%; animation-delay: 0.5s; }
@keyframes feed-pulse {
  0%,100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}
.dash-feed-note {
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  font-weight: 500;
  color: #333;
  margin-top: 20px;
}
.dash-feed-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6rem;
  color: #222;
  text-align: center;
  line-height: 1.8;
  letter-spacing: 0.03em;
}
</style>

<script>
function fmt(n: number): string {
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

async function load() {
  try {
    const res = await fetch('/api/trading/status');
    if (!res.ok) return;
    render(await res.json());
    const meta = document.getElementById('feed-status');
    if (meta) { meta.textContent = 'STANDBY'; meta.style.color = '#333'; }
  } catch {}
}

function render(data: any) {
  const left = document.getElementById('left');
  if (!left || !data.bots) return;

  left.innerHTML = Object.entries(data.bots).map(([id, bot]: [string, any]) => {
    const pnlCls = bot.pnl > 0.01 ? 'g' : bot.pnl < -0.01 ? 'r' : 'n';
    const sign = bot.pnl >= 0 ? '+' : '';
    const pos = bot.has_position;
    const wrCls = bot.wr >= 55 ? 'g' : bot.wr < 50 ? 'r' : '';
    const eqCls = bot.pnl > 0.01 ? 'g' : bot.pnl < -0.01 ? 'r' : '';

    return `
      <div class="dash-bot">
        <div class="dash-bot-header">
          <span class="dash-bot-name">${bot.label}</span>
          <span class="dash-bot-tag">${bot.asset}</span>
        </div>
        <div class="dash-bot-equity ${eqCls}">${fmt(bot.equity)}</div>
        <div class="dash-bot-pnl ${pnlCls}">${sign}${fmt(Math.abs(bot.pnl))} · ${sign}${bot.pnl_pct}%</div>
        <div class="dash-bot-wr ${wrCls}">${bot.wr}%</div>
        <div class="dash-bot-wr-label">WIN RATE</div>
        <div class="dash-bot-meta">
          <div class="dash-bot-meta-item">
            <span class="dash-bot-meta-val">${bot.total_trades}</span>
            <span class="dash-bot-meta-lbl">TRADES</span>
          </div>
          <div class="dash-bot-meta-item">
            <span class="dash-bot-meta-val">${bot.wins}W / ${bot.losses}L</span>
            <span class="dash-bot-meta-lbl">RECORD</span>
          </div>
        </div>
        <div class="dash-bot-pos">
          <span class="dash-pos-dot ${pos ? 'on' : 'off'}"></span>
          <span style="color:${pos ? '#22c55e' : '#222'}">${pos ? 'IN POSITION' : 'WAITING'}</span>
        </div>
      </div>`;
  }).join('');
}

load();
setInterval(load, 10000);
</script>
