.pub-signal-title { font-size: 0.9rem; font-weight: 600; color: var(--pub-text); margin-bottom: 6px; line-height: 1.4; }
.pub-signal-summary { font-size: 0.78rem; color: var(--pub-muted); line-height: 1.6; margin-bottom: 10px; }
.pub-signal-metric { display: flex; align-items: center; gap: 10px; }
.pub-signal-metric-label { font-size: 0.65rem; color: var(--pub-muted); text-transform: uppercase; letter-spacing: 0.08em; }
.pub-signal-metric-val { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 600; }
.pub-signal-right { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px 16px; gap: 8px; flex-shrink: 0; }
.pub-signal-strength { display: flex; flex-direction: column; gap: 3px; }
.pub-str-dot { width: 8px; height: 8px; border-radius: 2px; background: var(--pub-border); }
.pub-str-dot.on {}
.pub-signal-dir { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
.pub-empty-state {
  display: flex; flex-direction: column; align-items: center; gap: 12px;
  padding: 48px 24px; color: var(--pub-muted); font-size: 0.82rem; text-align: center;
  border: 1px dashed var(--pub-border); border-radius: 10px;
}

/* Right column widgets */
.pub-right { display: flex; flex-direction: column; gap: 16px; }
.pub-widget {
  background: var(--pub-surface); border: 1px solid var(--pub-border);
  border-radius: 12px; padding: 18px; position: relative; overflow: hidden;
}
.pub-widget--glow::before {
  content: ''; position: absolute; width: 200px; height: 200px;
  top: -60px; right: -60px; border-radius: 50%;
  background: radial-gradient(circle, rgba(31,111,235,0.1) 0%, transparent 70%);
  pointer-events: none;
}
.pub-widget-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.pub-widget-link { font-size: 0.7rem; color: var(--pub-blue); }
.pub-widget-link:hover { text-decoration: underline; }
.pub-widget-count { font-size: 0.65rem; color: var(--pub-green); background: rgba(57,211,83,0.1); padding: 2px 7px; border-radius: 4px; font-weight: 700; }
.pub-widget-empty { font-size: 0.75rem; color: var(--pub-muted); padding: 16px 0; text-align: center; }

/* Macro */
.pub-macro-list { display: flex; flex-direction: column; gap: 2px; }
.pub-macro-row {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px; border-radius: 7px; transition: background 0.15s;
}
.pub-macro-row:hover { background: rgba(255,255,255,0.03); }
.pub-macro-icon { font-size: 0.9rem; flex-shrink: 0; }
.pub-macro-info { flex: 1; min-width: 0; }
.pub-macro-label { font-size: 0.75rem; color: var(--pub-text); display: block; }
.pub-macro-date  { font-size: 0.62rem; color: var(--pub-muted); font-family: 'JetBrains Mono', monospace; }
.pub-macro-val { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 600; color: var(--pub-text); }
.pub-macro-val.risk { color: var(--pub-red); }

/* News */
.pub-news-list { display: flex; flex-direction: column; gap: 1px; }
.pub-news-item {
  display: block; padding: 10px; border-radius: 7px;
  transition: background 0.15s; text-decoration: none;
}
.pub-news-item:hover { background: rgba(255,255,255,0.03); }
.pub-news-top { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.pub-news-source { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--pub-muted); }
.pub-news-sentiment { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 1px 5px; border-radius: 3px; }
.pub-news-sentiment.positive { color: var(--pub-green); background: rgba(57,211,83,0.1); }
.pub-news-sentiment.negative { color: var(--pub-red);   background: rgba(248,81,73,0.1); }
.pub-news-sentiment.neutral  { color: var(--pub-muted); background: rgba(139,148,158,0.1); }
.pub-news-title { font-size: 0.78rem; color: var(--pub-text); line-height: 1.45; margin-bottom: 4px; font-weight: 500; }
.pub-news-time  { font-size: 0.6rem; color: #484f58; font-family: 'JetBrains Mono', monospace; }

/* Pipeline */
.pub-pipeline-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
.pub-pipeline-row { display: flex; align-items: center; gap: 10px; }
.pub-pipeline-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.pub-pipeline-dot.success { background: var(--pub-green); box-shadow: 0 0 6px rgba(57,211,83,0.5); }
.pub-pipeline-dot.failed  { background: var(--pub-red); }
.pub-pipeline-dot.partial { background: var(--pub-amber); }
.pub-pipeline-dot.skipped,
.pub-pipeline-dot.pending { background: var(--pub-border); }
.pub-pipeline-info { flex: 1; }
.pub-pipeline-name   { font-size: 0.78rem; color: var(--pub-text); display: block; font-weight: 500; }
.pub-pipeline-cadence{ font-size: 0.62rem; color: var(--pub-muted); }
.pub-pipeline-right { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
.pub-pipeline-latency{ font-size: 0.6rem; color: var(--pub-muted); font-family: 'JetBrains Mono', monospace; }
.pub-pipeline-status { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
.pub-pipeline-status.success { color: var(--pub-green); }
.pub-pipeline-status.failed  { color: var(--pub-red); }
.pub-pipeline-status.partial { color: var(--pub-amber); }
.pub-pipeline-status.pending,
.pub-pipeline-status.skipped { color: var(--pub-muted); }
.pub-pipeline-footer { padding-top: 12px; border-top: 1px solid var(--pub-border); }
.pub-pipeline-bar-wrap { height: 4px; background: var(--pub-border); border-radius: 2px; margin-bottom: 6px; }
.pub-pipeline-bar { height: 100%; border-radius: 2px; background: var(--pub-green); transition: width 1s ease; }
.pub-pipeline-bar-label { font-size: 0.62rem; color: var(--pub-muted); }

/* Health badge */
.pub-health-badge { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; border-radius: 4px; }
.pub-health-badge.good { color: var(--pub-green); background: rgba(57,211,83,0.1); }
.pub-health-badge.warn { color: var(--pub-amber); background: rgba(210,153,34,0.1); }
.pub-health-badge.bad  { color: var(--pub-red);   background: rgba(248,81,73,0.1); }

/* Dataset */
.pub-dataset-hero { text-align: center; padding: 16px 0 12px; }
.pub-dataset-num {
  font-family: 'JetBrains Mono', monospace; font-size: 2.4rem; font-weight: 600;
  color: var(--pub-text); line-height: 1;
}
.pub-dataset-sub { font-size: 0.68rem; color: var(--pub-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px; }
.pub-dataset-breakdown { display: flex; flex-direction: column; gap: 8px; margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--pub-border); }
.pub-dataset-row { display: flex; align-items: center; gap: 10px; }
.pub-dataset-label { display: flex; align-items: center; gap: 6px; font-size: 0.72rem; color: var(--pub-muted); flex-shrink: 0; width: 90px; }
.pub-dataset-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.pub-dataset-bar-wrap { flex: 1; height: 4px; background: var(--pub-border); border-radius: 2px; overflow: hidden; }
.pub-dataset-bar-fill { height: 100%; border-radius: 2px; transition: width 1.2s ease; min-width: 2px; }
.pub-dataset-count { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--pub-muted); flex-shrink: 0; width: 40px; text-align: right; }
</style>

<script>
import { animate } from 'animejs';
import Chart from 'chart.js/auto';

// ── Entrance animations ────────────────────────────────────
animate('.pub-stat-strip, .pub-price-card, .pub-chart-section, .pub-widget', {
  opacity: [0, 1], translateY: [16, 0],
  duration: 500, ease: 'out(3)',
  delay: (_, i) => i * 40 + 100,
});

// ── Signal filter ──────────────────────────────────────────
document.getElementById('domain-filters')?.addEventListener('click', e => {
  const btn = (e.target as HTMLElement).closest('.pub-domain-btn') as HTMLElement | null;
  if (!btn) return;
  document.querySelectorAll('.pub-domain-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const domain = btn.dataset.domain;
  document.querySelectorAll<HTMLElement>('.pub-signal-card').forEach(card => {
    const match = domain === 'all' || card.dataset.domain === domain ||
      (domain === 'cross_domain' && card.dataset.domain === 'cross_domain');
    card.style.display = match ? '' : 'none';
  });
});

// ── Chart.js price chart ───────────────────────────────────
const COLORS: Record<string, string> = { BTC: '#F7931A', ETH: '#627EEA', SOL: '#9945FF' };
let chart: Chart | null = null;
let activeAssets = new Set(['BTC','ETH','SOL']);
let activeRange = '24H';

async function buildChart() {
  const ctx = document.getElementById('price-chart') as HTMLCanvasElement | null;
  if (!ctx) return;

  // Fetch price history from Binance
  const rangeToInterval: Record<string, [string,string]> = {
    '1H':  ['1m',  '60'],
    '24H': ['15m', '96'],
    '7D':  ['4h',  '42'],
  };
  const [interval, limit] = rangeToInterval[activeRange] ?? ['15m','96'];
  const symMap: Record<string, string> = { BTC:'BTCUSDT', ETH:'ETHUSDT', SOL:'SOLUSDT' };

  const datasets = [];
  const labels: string[] = [];
  let hasData = false;

  for (const asset of activeAssets) {
    const sym = symMap[asset];
    if (!sym) continue;
    try {
      const res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${sym}&interval=${interval}&limit=${limit}`);
      if (!res.ok) continue;
      const klines: number[][] = await res.json();
      if (!klines.length) continue;
      hasData = true;

      // Only build labels once
      if (labels.length === 0) {
        for (const k of klines) {
          labels.push(new Date(k[0]).toLocaleTimeString('en-US', {
            hour: '2-digit', minute: '2-digit',
            ...(activeRange === '7D' ? { month: 'short', day: 'numeric' } : {}),
          }));
        }
      }

      // Normalize to % change from first candle
      const base = parseFloat(klines[0][1] as unknown as string);
      const data = klines.map(k => parseFloat(((parseFloat(k[4] as unknown as string) / base - 1) * 100).toFixed(3)));

      datasets.push({
        label: asset,
        data,
        borderColor: COLORS[asset],
        backgroundColor: 'transparent',
        borderWidth: 1.8,
        pointRadius: 0,
        tension: 0.3,
      });
    } catch { continue; }
  }

  const empty = document.getElementById('chart-empty');
  if (!hasData) {
    ctx.style.display = 'none';
    if (empty) empty.style.display = 'flex';
    return;
  }
  if (empty) empty.style.display = 'none';
  ctx.style.display = '';

  if (chart) chart.destroy();

  chart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 400 },
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#161B22',
          borderColor: '#21262D',
          borderWidth: 1,
          titleColor: '#8B949E',
          bodyColor: '#F0F6FC',
          callbacks: {
            label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y > 0 ? '+' : ''}${ctx.parsed.y.toFixed(2)}%`,
          },
        },
      },
      scales: {
        x: {
          grid: { color: 'rgba(33,38,45,0.5)', lineWidth: 1 },
          ticks: { color: '#484f58', font: { family: 'JetBrains Mono', size: 10 }, maxTicksLimit: 8 },
          border: { color: '#21262D' },
        },
        y: {
          grid: { color: 'rgba(33,38,45,0.5)', lineWidth: 1 },
          ticks: {
            color: '#484f58', font: { family: 'JetBrains Mono', size: 10 },
            callback: v => `${Number(v) > 0 ? '+' : ''}${Number(v).toFixed(1)}%`,
          },
          border: { color: '#21262D' },
        },
      },
    },
  });
}

// ── Asset toggles ──────────────────────────────────────────
document.getElementById('asset-toggles')?.addEventListener('click', e => {
  const btn = (e.target as HTMLElement).closest('.pub-toggle-btn') as HTMLElement | null;
  if (!btn) return;
  const asset = btn.dataset.asset!;
  if (activeAssets.has(asset)) {
    if (activeAssets.size === 1) return; // keep at least 1
    activeAssets.delete(asset);
    btn.classList.remove('active');
  } else {
    activeAssets.add(asset);
    btn.classList.add('active');
  }
  buildChart();
});

// ── Range buttons ──────────────────────────────────────────
document.getElementById('range-btns')?.addEventListener('click', e => {
  const btn = (e.target as HTMLElement).closest('.pub-range-btn') as HTMLElement | null;
  if (!btn) return;
  document.querySelectorAll('.pub-range-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  activeRange = btn.dataset.range!;
  buildChart();
});

buildChart();

// ── Price refresh every 60s ────────────────────────────────
async function refreshPrices() {
  try {
    const syms = encodeURIComponent(JSON.stringify(['BTCUSDT','ETHUSDT','SOLUSDT','BNBUSDT','AVAXUSDT']));
    const res = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbols=${syms}`);
    if (!res.ok) return;
    const rows: { symbol: string; lastPrice: string; priceChangePercent: string; highPrice: string; lowPrice: string; quoteVolume: string }[] = await res.json();
    for (const r of rows) {
      const card = document.querySelector<HTMLElement>(`.pub-price-card[data-sym="${r.symbol}"]`);
      if (!card) continue;
      const price   = parseFloat(r.lastPrice);
      const change  = parseFloat(r.priceChangePercent);
      const dir     = change >= 0.5 ? 'up' : change < -0.5 ? 'down' : 'flat';
      card.className = `pub-price-card ${dir}`;
      const valEl   = card.querySelector('.pub-price-val');
      const badgeEl = card.querySelector('.pub-price-badge');
      if (valEl) valEl.textContent = price >= 1000
        ? '$' + price.toLocaleString('en-US', { maximumFractionDigits: 0 })
        : '$' + price.toFixed(2);
      if (badgeEl) {
        badgeEl.textContent = (change >= 0 ? '+' : '') + change.toFixed(2) + '%';
        badgeEl.className   = `pub-price-badge ${dir}`;
      }
    }
    const upd = document.getElementById('prices-updated');
    if (upd) upd.textContent = 'Updated ' + new Date().toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' });
  } catch {}
}
setInterval(refreshPrices, 60_000);
</script>
