---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Credit Card Rewards Optimizer — Find the Best Card for Your Spending";
const description = "Enter your monthly spending by category and instantly see which credit card puts the most money back in your pocket. Free, unbiased rewards calculator.";

const cards = [
  { slug: 'chase-sapphire-preferred', name: 'Chase Sapphire Preferred', annualFee: 95, creditOffset: 0, pointValue: 1.25, categories: { groceries: 1, dining: 3, travel: 5, gas: 1, online: 1, other: 1 }, url: 'https://creditcards.chase.com/rewards-credit-cards/sapphire/preferred', badge: "Editor's Pick" },
  { slug: 'amex-gold', name: 'Amex Gold Card', annualFee: 250, creditOffset: 240, pointValue: 1.0, categories: { groceries: 4, dining: 4, travel: 3, gas: 1, online: 1, other: 1 }, url: 'https://www.americanexpress.com/us/credit-cards/card/gold-card/', badge: 'Best for Dining' },
  { slug: 'citi-double-cash', name: 'Citi Double Cash', annualFee: 0, creditOffset: 0, pointValue: 1.0, categories: { groceries: 2, dining: 2, travel: 2, gas: 2, online: 2, other: 2 }, url: 'https://www.citi.com/credit-cards/citi-double-cash-credit-card', badge: 'Best No-Fee' },
  { slug: 'chase-freedom-unlimited', name: 'Chase Freedom Unlimited', annualFee: 0, creditOffset: 0, pointValue: 1.0, categories: { groceries: 1.5, dining: 3, travel: 5, gas: 1.5, online: 1.5, other: 1.5 }, url: 'https://creditcards.chase.com/cash-back-credit-cards/freedom/unlimited', badge: null },
  { slug: 'amex-platinum', name: 'Amex Platinum', annualFee: 695, creditOffset: 600, pointValue: 1.0, categories: { groceries: 1, dining: 1, travel: 5, gas: 1, online: 1, other: 1 }, url: 'https://www.americanexpress.com/us/credit-cards/card/platinum/', badge: 'Best for Lounge Access' },
  { slug: 'capital-one-venture-x', name: 'Capital One Venture X', annualFee: 395, creditOffset: 300, pointValue: 1.0, categories: { groceries: 2, dining: 2, travel: 10, gas: 2, online: 2, other: 2 }, url: 'https://www.capitalone.com/credit-cards/venture-x/', badge: 'Best Value Premium' },
  { slug: 'discover-it-cash-back', name: 'Discover it Cash Back', annualFee: 0, creditOffset: 0, pointValue: 1.0, categories: { groceries: 1, dining: 1, travel: 1, gas: 1, online: 1, other: 1 }, url: 'https://www.discover.com/credit-cards/cash-back/it-card.html', badge: null },
  { slug: 'wells-fargo-active-cash', name: 'Wells Fargo Active Cash', annualFee: 0, creditOffset: 0, pointValue: 1.0, categories: { groceries: 2, dining: 2, travel: 2, gas: 2, online: 2, other: 2 }, url: 'https://www.wellsfargo.com/credit-cards/active-cash/', badge: null },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Credit Card Rewards Optimizer",
  "description": description,
  "applicationCategory": "FinanceApplication",
  "offers": { "@type": "Offer", "price": "0" }
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-primary text-white py-16 has-noise">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="section-eyebrow">Free Tool</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">Credit Card Rewards Optimizer</h1>
      <p class="text-white/65 text-lg max-w-xl mx-auto">Enter your monthly spending — we'll show you exactly which card puts the most money back in your pocket.</p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-accent transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/tools" class="hover:text-accent transition-colors">Tools</a>
      <span class="mx-2">/</span>
      <span>Rewards Optimizer</span>
    </nav>

    <div class="optimizer-layout">

      <!-- Inputs Panel -->
      <aside class="inputs-panel">
        <div class="panel-header">
          <h2 class="panel-title">Your Monthly Spending</h2>
          <p class="panel-subtitle">Enter approximate monthly totals per category.</p>
        </div>
        <div class="inputs-list">
          <div class="input-row">
            <label class="input-label" for="inp-groceries">
              <span class="input-icon">🛒</span> Groceries
            </label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input id="inp-groceries" type="number" min="0" step="10" value="600" class="spend-input" data-cat="groceries" />
            </div>
          </div>
          <div class="input-row">
            <label class="input-label" for="inp-dining">
              <span class="input-icon">🍽️</span> Dining &amp; Restaurants
            </label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input id="inp-dining" type="number" min="0" step="10" value="400" class="spend-input" data-cat="dining" />
            </div>
          </div>
          <div class="input-row">
            <label class="input-label" for="inp-travel">
              <span class="input-icon">✈️</span> Travel
            </label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input id="inp-travel" type="number" min="0" step="10" value="200" class="spend-input" data-cat="travel" />
            </div>
          </div>
          <div class="input-row">
            <label class="input-label" for="inp-gas">
              <span class="input-icon">⛽</span> Gas &amp; Transit
            </label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input id="inp-gas" type="number" min="0" step="10" value="150" class="spend-input" data-cat="gas" />
            </div>
          </div>
          <div class="input-row">
            <label class="input-label" for="inp-online">
              <span class="input-icon">💻</span> Online Shopping
            </label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input id="inp-online" type="number" min="0" step="10" value="300" class="spend-input" data-cat="online" />
            </div>
          </div>
          <div class="input-row">
            <label class="input-label" for="inp-other">
              <span class="input-icon">🛍️</span> Everything Else
            </label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input id="inp-other" type="number" min="0" step="10" value="500" class="spend-input" data-cat="other" />
            </div>
          </div>
        </div>
        <div class="monthly-total-row">
          <span class="monthly-total-label">Monthly Total</span>
          <span id="monthly-total" class="monthly-total-value">$2,150</span>
        </div>
      </aside>

      <!-- Results Panel -->
      <main class="results-panel">
        <div class="results-header">
          <h2 class="results-title">Card Rankings</h2>
          <p class="results-subtitle">Sorted by estimated net annual value, best first.</p>
        </div>
        <div id="results-list" class="results-list">
          <!-- Populated by JS -->
        </div>
        <p class="disclaimer">
          Rewards calculated at face value. Point valuations are estimates. Actual value depends on redemption method. Annual credits subject to eligibility. Not financial advice.
        </p>
      </main>

    </div>
  </div>

</BaseLayout>

<script define:vars={{ cards }}>
  const catKeys = ['groceries', 'dining', 'travel', 'gas', 'online', 'other'];

  function getSpend() {
    const spend = {};
    catKeys.forEach(cat => {
      const el = document.getElementById('inp-' + cat);
      spend[cat] = parseFloat(el ? el.value : '0') || 0;
    });
    return spend;
  }

  function calcAnnualValue(card, spend) {
    let rewards = 0;
    catKeys.forEach(cat => {
      const multiplier = card.categories[cat] || 1;
      rewards += spend[cat] * 12 * multiplier * card.pointValue / 100;
    });
    return rewards - card.annualFee + card.creditOffset;
  }

  function fmt(n) {
    const abs = Math.abs(n);
    const str = abs.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    return (n < 0 ? '-$' : '$') + str;
  }

  function updateMonthlyTotal(spend) {
    const total = catKeys.reduce((s, k) => s + spend[k], 0);
    const el = document.getElementById('monthly-total');
    if (el) el.textContent = '$' + total.toLocaleString('en-US', { maximumFractionDigits: 0 });
  }

  function renderResults() {
    const spend = getSpend();
    updateMonthlyTotal(spend);

    const ranked = cards
      .map(card => ({ ...card, netValue: calcAnnualValue(card, spend) }))
      .sort((a, b) => b.netValue - a.netValue);

    const list = document.getElementById('results-list');
    if (!list) return;
    list.innerHTML = '';

    ranked.forEach((card, i) => {
      const isBest = i === 0;
      const rewardsEarned = card.netValue + card.annualFee - card.creditOffset;
      const isPositive = card.netValue >= 0;

      const item = document.createElement('div');
      item.className = 'result-card' + (isBest ? ' result-card--best' : '');

      item.innerHTML = `
        <div class="result-rank">${isBest ? '★' : i + 1}</div>
        <div class="result-body">
          <div class="result-top-row">
            <div class="result-name-wrap">
              <span class="result-name">${card.name}</span>
              ${isBest ? '<span class="best-tag">Best for You</span>' : ''}
              ${card.badge && !isBest ? `<span class="badge-tag">${card.badge}</span>` : ''}
              ${isBest && card.badge ? `<span class="badge-tag">${card.badge}</span>` : ''}
            </div>
          </div>
          <div class="result-stats">
            <div class="stat">
              <span class="stat-label">Annual Rewards</span>
              <span class="stat-value">${fmt(rewardsEarned)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Annual Fee</span>
              <span class="stat-value stat-fee">${card.annualFee > 0 ? '-$' + card.annualFee : 'None'}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Credits</span>
              <span class="stat-value stat-credit">${card.creditOffset > 0 ? '+$' + card.creditOffset : '—'}</span>
            </div>
            <div class="stat stat--net">
              <span class="stat-label">Net Annual Value</span>
              <span class="stat-value stat-net ${isPositive ? 'stat-net--pos' : 'stat-net--neg'}">${fmt(card.netValue)}</span>
            </div>
          </div>
        </div>
        <div class="result-cta-wrap">
          <a href="${card.url}" target="_blank" rel="nofollow noopener" class="apply-btn ${isBest ? 'apply-btn--best' : ''}">Apply Now →</a>
        </div>
      `;
      list.appendChild(item);
    });
  }

  document.querySelectorAll('.spend-input').forEach(input => {
    input.addEventListener('input', renderResults);
  });

  renderResults();
</script>

<style>
  /* ── Layout ── */
  .optimizer-layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 820px) {
    .optimizer-layout { grid-template-columns: 1fr; }
  }

  /* ── Inputs Panel ── */
  .inputs-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 24px;
    position: sticky;
    top: 80px;
  }
  html[data-theme='dark'] .inputs-panel { background: #1a2740; border-color: #2d3f55; }

  .panel-header { margin-bottom: 20px; }
  .panel-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
  .panel-subtitle { font-size: 0.82rem; color: var(--color-text-muted); }

  .inputs-list { display: flex; flex-direction: column; gap: 14px; }

  .input-row { display: flex; flex-direction: column; gap: 5px; }
  .input-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .input-icon { font-size: 0.95rem; }

  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-prefix {
    position: absolute;
    left: 10px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    pointer-events: none;
  }
  .spend-input {
    width: 100%;
    padding: 8px 12px 8px 22px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    background: white;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    -moz-appearance: textfield;
  }
  .spend-input::-webkit-outer-spin-button,
  .spend-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .spend-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(14,165,233,0.15);
  }
  html[data-theme='dark'] .spend-input { background: #0f1e30; color: #f1f5f9; border-color: #2d3f55; }

  .monthly-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }
  .monthly-total-label { font-size: 0.85rem; font-weight: 600; color: var(--color-text-muted); }
  .monthly-total-value { font-size: 1.1rem; font-weight: 700; color: var(--color-primary); }
  html[data-theme='dark'] .monthly-total-value { color: #f1f5f9; }

  /* ── Results Panel ── */
  .results-panel {}
  .results-header { margin-bottom: 20px; }
  .results-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 4px; }
  .results-subtitle { font-size: 0.82rem; color: var(--color-text-muted); }

  .results-list { display: flex; flex-direction: column; gap: 12px; }

  /* ── Result Card ── */
  .result-card {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: 16px;
    align-items: center;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 18px 20px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  html[data-theme='dark'] .result-card { background: #1a2740; border-color: #2d3f55; }
  .result-card:hover {
    box-shadow: 0 6px 24px rgba(30,58,95,0.1);
    transform: translateY(-1px);
  }
  .result-card--best {
    border-color: var(--color-accent);
    border-width: 2px;
    background: linear-gradient(135deg, rgba(14,165,233,0.04), white);
    box-shadow: 0 4px 20px rgba(14,165,233,0.12);
  }
  html[data-theme='dark'] .result-card--best {
    background: linear-gradient(135deg, rgba(14,165,233,0.08), #1a2740);
  }

  .result-rank {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.95rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  html[data-theme='dark'] .result-rank { background: #0f1e30; }
  .result-card--best .result-rank {
    background: var(--color-accent);
    color: white;
    font-size: 1rem;
  }

  .result-body { min-width: 0; }
  .result-top-row { margin-bottom: 12px; }
  .result-name-wrap { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
  .result-name { font-size: 1rem; font-weight: 700; }

  .best-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--color-accent);
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .badge-tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(14,165,233,0.1);
    color: var(--color-accent);
    border: 1px solid rgba(14,165,233,0.25);
  }

  .result-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  @media (max-width: 640px) {
    .result-card { grid-template-columns: 36px 1fr; }
    .result-cta-wrap { grid-column: 1 / -1; }
    .result-stats { grid-template-columns: repeat(2, 1fr); }
  }

  .stat { display: flex; flex-direction: column; gap: 2px; }
  .stat-label { font-size: 0.7rem; color: var(--color-text-muted); font-weight: 500; white-space: nowrap; }
  .stat-value { font-size: 0.95rem; font-weight: 600; }
  .stat-fee { color: var(--color-danger); }
  .stat-credit { color: var(--color-success); }
  .stat--net .stat-label { font-weight: 700; color: var(--color-text); }
  .stat-net { font-size: 1.05rem; font-weight: 800; }
  .stat-net--pos { color: var(--color-success); }
  .stat-net--neg { color: var(--color-danger); }

  /* ── Apply Button ── */
  .result-cta-wrap { flex-shrink: 0; }
  .apply-btn {
    display: inline-block;
    padding: 9px 16px;
    border-radius: 9px;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    background: var(--color-surface);
    color: var(--color-primary);
    border: 1px solid var(--color-border);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  html[data-theme='dark'] .apply-btn { background: #0f1e30; color: #f1f5f9; border-color: #2d3f55; }
  .apply-btn:hover { background: var(--color-accent); color: white; border-color: var(--color-accent); }
  .apply-btn--best {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
  .apply-btn--best:hover { background: var(--color-accent-dark); border-color: var(--color-accent-dark); }

  /* ── Disclaimer ── */
  .disclaimer {
    margin-top: 20px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding: 12px 16px;
    background: var(--color-surface);
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }
  html[data-theme='dark'] .disclaimer { background: #1a2740; border-color: #2d3f55; }
</style>
