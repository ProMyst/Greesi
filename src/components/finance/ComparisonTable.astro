---
interface Props {
  itemA: any;
  itemB: any;
  fields: { key: string; label: string }[];
  type: string;
}

const { itemA, itemB, fields, type } = Astro.props;

function getFieldValue(item: any, key: string): string {
  const val = item[key];
  if (typeof val === 'boolean') return val ? 'Yes' : 'No';
  if (Array.isArray(val)) return val.join(', ');
  return String(val ?? 'N/A');
}
---

<div class="overflow-x-auto">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-primary text-white">
        <th class="p-3 text-left font-semibold w-1/3">Feature</th>
        <th class="p-3 text-center font-semibold w-1/3">{itemA.name}</th>
        <th class="p-3 text-center font-semibold w-1/3">{itemB.name}</th>
      </tr>
    </thead>
    <tbody>
      {fields.map((field, i) => (
        <tr class={i % 2 === 0 ? 'bg-surface' : 'bg-white'}>
          <td class="p-3 font-medium text-text-muted">{field.label}</td>
          <td class="p-3 text-center">{getFieldValue(itemA, field.key)}</td>
          <td class="p-3 text-center">{getFieldValue(itemB, field.key)}</td>
        </tr>
      ))}
      <tr class="bg-surface-alt">
        <td class="p-3 font-medium text-text-muted">Our Rating</td>
        <td class="p-3 text-center font-bold text-accent">{itemA.rating}/5</td>
        <td class="p-3 text-center font-bold text-accent">{itemB.rating}/5</td>
      </tr>
    </tbody>
  </table>
</div>
